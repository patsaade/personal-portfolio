---
// Privacy policy — cookieless Vercel Web Analytics + Speed Insights, local-only theme storage.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { SOCIALS } from '../consts';

const para = css({ color: 'textMuted', lineHeight: 1.8, mb: '1rem' });
const h2 = css({ fontSize: '1.3rem', fontWeight: 700, mt: '2.25rem', mb: '0.75rem' });
const list = css({ color: 'textMuted', lineHeight: 1.9, pl: '1.25rem', mb: '1rem' });
const link = css({ color: 'primary', textDecoration: 'underline', _hover: { color: 'primaryHover' } });

const updated = 'June 20, 2026';
---

<BaseLayout
  title="Privacy Policy"
  description="How patricksaade.com handles data: cookieless, privacy-friendly analytics and no personal tracking."
>
  <PageHeader breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Privacy' }]} eyebrow="Legal" title="Privacy policy" description={`Last updated: ${updated}`} />

  <p class={para}>
    This site (<strong class={css({ color: 'text' })}>patricksaade.com</strong>) is a personal
    blog and portfolio. It is intentionally privacy-respecting: there are no accounts, no
    sign-ups, no advertising, and no third-party tracking or marketing cookies.
  </p>

  <h2 class={h2}>Analytics</h2>
  <p class={para}>
    The site uses <strong class={css({ color: 'text' })}>Vercel Web Analytics</strong> and
    <strong class={css({ color: 'text' })}>Vercel Speed Insights</strong> — both
    privacy-friendly and <strong class={css({ color: 'text' })}>cookieless</strong>. Web
    Analytics records aggregate, anonymized visit data (page views, referrer, approximate
    country, device/browser type); Speed Insights records anonymized page-performance metrics
    (load times and Core Web Vitals). Neither uses cookies, builds advertising profiles, nor
    tracks you across other websites, and <strong class={css({ color: 'text' })}>no</strong>
    personally identifiable information is collected or stored. See Vercel's
    <a class={link} href="https://vercel.com/docs/analytics/privacy-policy" target="_blank" rel="noopener">Web Analytics</a>
    and
    <a class={link} href="https://vercel.com/docs/speed-insights/privacy-policy" target="_blank" rel="noopener">Speed Insights</a>
    privacy documentation for details.
  </p>

  <h2 class={h2}>Cookies & local storage</h2>
  <p class={para}>
    This site sets <strong class={css({ color: 'text' })}>no cookies</strong>. Your theme
    preference (light/dark mode and chosen color palette) is saved in your browser's
    <code class={css({ fontFamily: 'mono', fontSize: '0.9em' })}>localStorage</code>. That
    value stays on your device, is never transmitted to a server, and you can clear it any
    time via your browser settings. Other interactive features — including the daily
    <strong class={css({ color: 'text' })}>Term of the Day</strong> ticker and glossary
    search — run entirely in your browser and store nothing.
  </p>

  <h2 class={h2}>Hosting & server logs</h2>
  <p class={para}>
    The site is hosted on <a class={link} href="https://vercel.com" target="_blank" rel="noopener">Vercel</a>,
    which may process standard request data (such as IP address and user-agent) transiently
    to deliver pages and protect against abuse, per
    <a class={link} href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener">Vercel's privacy policy</a>.
    This site's owner does not maintain its own separate logs of visitors.
  </p>

  <h2 class={h2}>External links</h2>
  <p class={para}>
    Posts and pages link to third-party resources (e.g. LinkedIn, GitHub, and tool/vendor
    documentation). Those sites have their own privacy practices, which this policy does not
    cover.
  </p>

  <h2 class={h2}>Your choices</h2>
  <ul class={list}>
    <li>Use your browser's "Do Not Track" / privacy settings — analytics here is already cookieless and anonymous.</li>
    <li>Clear site data / <code class={css({ fontFamily: 'mono', fontSize: '0.9em' })}>localStorage</code> to reset your saved theme preference.</li>
    <li>Block scripts for <code class={css({ fontFamily: 'mono', fontSize: '0.9em' })}>patricksaade.com</code> — the site still renders and reads normally.</li>
  </ul>

  <h2 class={h2}>Contact</h2>
  <p class={para}>
    Questions about this policy, or want to report a security issue? Reach out via
    <a class={link} href={SOCIALS.linkedin} target="_blank" rel="noopener">LinkedIn</a> or
    <a class={link} href={SOCIALS.github} target="_blank" rel="noopener">GitHub</a>. Security
    contact details are also published at
    <a class={link} href="/.well-known/security.txt">/.well-known/security.txt</a>.
  </p>

  <h2 class={h2}>Changes</h2>
  <p class={para}>
    This policy may be updated as the site evolves. Material changes will be reflected by the
    "last updated" date above.
  </p>
</BaseLayout>
