---
// MITRE ATT&CK technique detail — one prerendered page per technique, with the
// site's own summary + significance and a prominent link to the canonical MITRE
// page. Mirrors the glossary term page's design language for consistency.
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import { termBySlug } from '../../data/securityTerms';
import { ATTACK_TECHNIQUES } from '../../data/references';

export async function getStaticPaths() {
  return ATTACK_TECHNIQUES.map((tech) => ({ params: { id: tech.id }, props: { tech } }));
}

const { tech } = Astro.props;

const idx = ATTACK_TECHNIQUES.findIndex((t) => t.id === tech.id);
const prev = idx > 0 ? ATTACK_TECHNIQUES[idx - 1] : null;
const next = idx >= 0 && idx < ATTACK_TECHNIQUES.length - 1 ? ATTACK_TECHNIQUES[idx + 1] : null;
const gloss = tech.glossarySlug ? termBySlug(tech.glossarySlug) : null;
const parentId = tech.id.includes('.') ? tech.id.split('.')[0] : null;
const parent = parentId ? ATTACK_TECHNIQUES.find((t) => t.id === parentId) : null;

const sectionH2 = css({ display: 'flex', alignItems: 'center', gap: '0.5rem', fontSize: '1.2rem', fontWeight: 700, mt: '2.5rem', mb: '0.75rem' });
const para = css({ color: 'text', lineHeight: 1.8, fontSize: '1.02rem' });
const extBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.5rem',
  mt: '1.5rem',
  px: '1.1rem',
  py: '0.65rem',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  color: 'text',
  fontWeight: 600,
  fontSize: '0.95rem',
  transition: 'border-color 200ms ease, color 200ms ease, transform 200ms ease',
  _hover: { borderColor: 'primary', color: 'primary', transform: 'translateY(-1px)' },
});
const glossCard = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.3rem',
  p: '1rem 1.15rem',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  transition: 'border-color 200ms ease, transform 200ms ease',
  _hover: { borderColor: 'primary', transform: 'translateY(-2px)' },
});
const navLink = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.25rem',
  p: '0.85rem 1.1rem',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  bg: 'bgCard',
  transition: 'border-color 200ms ease, transform 200ms ease',
  _hover: { borderColor: 'primary', transform: 'translateY(-2px)' },
});
const navMeta = css({ fontSize: '0.72rem', fontFamily: 'sans', color: 'textMuted' });
const navTitle = css({ fontWeight: 600, fontSize: '0.95rem', lineHeight: 1.3 });
---

<BaseLayout title={`${tech.id} ${tech.name} — MITRE ATT&CK`} description={tech.summary}>
  <Breadcrumbs
    items={[{ label: 'Home', href: '/' }, { label: 'ATT&CK map', href: '/attack-map/' }, { label: tech.id }]}
  />

  <header class={css({ mb: '1.5rem' })}>
    <p class={css({ fontFamily: 'sans', fontSize: '0.8rem', textTransform: 'uppercase', letterSpacing: '0.1em', color: 'primary', mb: '0.5rem', display: 'inline-flex', alignItems: 'center', gap: '0.4rem' })}>
      <Icon name="crosshair" size={15} />
      {tech.tactic} · MITRE ATT&CK
    </p>
    <h1 class={css({ fontSize: { base: '2.1rem', md: '2.75rem' }, fontWeight: 700, letterSpacing: '-0.02em', lineHeight: 1.1 })}>
      {tech.name}
    </h1>
    <p class={css({ fontFamily: 'mono', fontSize: '0.85rem', color: 'textMuted', mt: '0.6rem' })}>
      {tech.id}
      {parent && (
        <>
          {' · sub-technique of '}
          <a href={`/attack-map/${parent.id}/`} class={css({ color: 'primary', _hover: { textDecoration: 'underline' } })}>{parent.id} {parent.name}</a>
        </>
      )}
    </p>
    {tech.summary && (
      <p class={css({ fontSize: '1.2rem', color: 'textMuted', mt: '1rem', lineHeight: 1.6, maxW: '640px' })}>{tech.summary}</p>
    )}
    <a href={tech.url} target="_blank" rel="noopener" class={extBtn}>
      View this technique on MITRE ATT&CK
      <Icon name="external-link" size={15} />
    </a>
  </header>

  {tech.significance && (
    <>
      <h2 class={sectionH2}><Icon name="shield" size={18} class={css({ color: 'primary' })} /> Why it matters</h2>
      <p class={para}>{tech.significance}</p>
    </>
  )}

  {gloss && (
    <>
      <h2 class={sectionH2}><Icon name="book-open" size={18} class={css({ color: 'primary' })} /> In the glossary</h2>
      <a href={`/glossary/${gloss.slug}/`} class={glossCard}>
        <span class={css({ fontWeight: 700, color: 'text', display: 'inline-flex', alignItems: 'center', gap: '0.4rem' })}>
          {gloss.term} <Icon name="arrow-right" size={14} class={css({ color: 'primary' })} />
        </span>
        <span class={css({ fontSize: '0.9rem', color: 'textMuted', lineHeight: 1.5 })}>{gloss.short}</span>
      </a>
    </>
  )}

  <nav
    aria-label="More techniques"
    class={css({ display: 'grid', gridTemplateColumns: { base: '1fr', sm: '1fr 1fr' }, gap: '1rem', mt: '3rem', pt: '1.5rem', borderTop: '1px solid token(colors.border)' })}
  >
    {prev ? (
      <a href={`/attack-map/${prev.id}/`} class={navLink}>
        <span class={navMeta}>← Previous</span>
        <span class={navTitle}>{prev.id} {prev.name}</span>
      </a>
    ) : (
      <span />
    )}
    {next ? (
      <a href={`/attack-map/${next.id}/`} class={`${navLink} ${css({ textAlign: 'right', alignItems: 'flex-end' })}`}>
        <span class={navMeta}>Next →</span>
        <span class={navTitle}>{next.id} {next.name}</span>
      </a>
    ) : (
      <span />
    )}
  </nav>
</BaseLayout>
