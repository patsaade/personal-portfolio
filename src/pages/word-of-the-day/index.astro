---
// Compatibility redirect for the original /word-of-the-day/ URL (the glossary has
// since moved to /glossary/). A meta-refresh is used (rather than config redirects)
// because it composes cleanly with trailingSlash: 'always'.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
const dest = '/glossary/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${dest}`} />
    <link rel="canonical" href={dest} />
    <meta name="robots" content="noindex" />
    <title>Moved — Glossary</title>
  </head>
  <body>
    <p>This page has moved to the <a href={dest}>Glossary</a>.</p>
  </body>
</html>
