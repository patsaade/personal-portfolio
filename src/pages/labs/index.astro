---
// Labs listing — gallery of lab/CTF writeups, filterable by source platform.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Badge from '../../components/Badge.astro';
import Icon from '../../components/Icon.astro';
import PixelStar from '../../components/PixelStar.astro';
import TagCombobox from '../../components/TagCombobox.astro';
import { getFormattedDate } from '../../utils/date';
import { getSortedLabs, tagSlug } from '../../utils/posts';

const labs = await getSortedLabs();
const sources = [...new Set(labs.map((l) => l.data.source))];

// Tag facet for the search combobox (a lab can carry several tags → AND filter).
const labTagCounts: Record<string, { label: string; n: number }> = {};
for (const l of labs) for (const t of l.data.tags) {
  const s = tagSlug(t);
  (labTagCounts[s] ??= { label: t, n: 0 }).n++;
}
const labTagOptions = Object.entries(labTagCounts)
  .map(([value, v]) => ({ value, label: v.label, count: v.n }))
  .sort((a, b) => b.count - a.count);

const chip = css({
  fontFamily: 'sans',
  fontSize: '0.82rem',
  px: '0.8rem',
  py: '0.4rem',
  borderRadius: 'md',
  border: '1px solid token(colors.border)',
  bg: 'transparent',
  color: 'textMuted',
  cursor: 'pointer',
  transition: 'all 150ms ease',
  _hover: { borderColor: 'primary', color: 'text' },
  '&[data-active]': { bg: 'primary', color: 'onPrimary', borderColor: 'primary' },
});
---

<BaseLayout title="Labs" description="Completed DFIR lab & CTF writeups — CyberDefenders, 13Cubed, Magnet, BTLO, and home-lab projects.">
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Labs' }]}
    eyebrow="Labs & Writeups"
    title="Hands-on challenges, solved"
    description="Full walkthroughs of forensics challenges — approach, key findings, extracted IOCs, and lessons learned."
  />

  {
    labs.length > 0 && (
      <div class={css({ display: 'flex', flexDirection: 'column', gap: '0.9rem', mb: '2rem' })}>
        <TagCombobox id="lab-cb" options={labTagOptions} placeholder={`Search ${labs.length} writeups, or type a tag…`} label="Search labs or filter by tag" />
        <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.5rem' })}>
          <button class={chip} data-filter="all" data-active type="button">All sources</button>
          {sources.map((s) => (
            <button class={chip} data-filter={s} type="button">{s}</button>
          ))}
        </div>
        <p class={css({ color: 'textMuted', fontSize: '0.85rem', m: 0 })}>
          <span id="lab-count">{labs.length}</span> <span id="lab-count-word">{labs.length === 1 ? 'writeup' : 'writeups'}</span>
        </p>
      </div>
    )
  }

  {
    labs.length > 0 ? (
      <div
        id="lab-grid"
        class={css({
          display: 'grid',
          gridTemplateColumns: { base: '1fr', md: 'repeat(2, 1fr)' },
          gap: '1.25rem',
        })}
      >
        {labs.map((lab) => (
          <a
            href={`/labs/${lab.id}/`}
            class={`lab-item ${css({
              display: 'flex',
              flexDirection: 'column',
              gap: '0.75rem',
              p: '1.5rem',
              bg: 'bgCard',
              border: '1px solid token(colors.border)',
              borderRadius: 'lg',
              boxShadow: 'card',
              transition: 'transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease',
              _hover: { transform: 'translateY(-3px)', borderColor: 'primary', boxShadow: 'cardHover' },
            })}`}
            data-source={lab.data.source}
            data-tags={`|${lab.data.tags.map(tagSlug).join('|')}|`}
            data-search={`${lab.data.title} ${lab.data.excerpt} ${lab.data.tags.join(' ')} ${lab.data.tools.join(' ')} ${lab.data.source}`.toLowerCase()}
          >
            <div class={css({ display: 'flex', gap: '0.5rem', flexWrap: 'wrap' })}>
              <Badge variant="primary">{lab.data.source}</Badge>
              <Badge variant="difficulty">{lab.data.difficulty}</Badge>
            </div>
            <h3 class={css({ fontSize: '1.15rem', fontWeight: 700, lineHeight: 1.3 })}>
              {lab.data.title}
            </h3>
            <p class={css({ color: 'textMuted', fontSize: '0.92rem', flex: 1 })}>{lab.data.excerpt}</p>
            <div
              class={css({
                display: 'flex',
                flexWrap: 'wrap',
                gap: '0.5rem 1.25rem',
                fontSize: '0.78rem',
                fontFamily: 'sans',
                color: 'textMuted',
                pt: '0.5rem',
                borderTop: '1px solid token(colors.border)',
              })}
            >
              <span>{getFormattedDate(lab.data.date)}</span>
              {lab.data.timeSpent && <span>⏱ {lab.data.timeSpent}</span>}
              {typeof lab.data.iocCount === 'number' && <span>{lab.data.iocCount} IOCs</span>}
              {lab.data.tools.length > 0 && <span>{lab.data.tools.length} tools</span>}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div
        class={css({
          display: 'flex',
          flexDirection: 'column',
          alignItems: 'center',
          textAlign: 'center',
          gap: '1rem',
          p: { base: '2.5rem 1.5rem', md: '4rem 2rem' },
          bg: 'bgCard',
          border: '1px dashed token(colors.border)',
          borderRadius: 'xl',
        })}
      >
        <PixelStar size={64} />
        <h2 class={css({ fontSize: '1.4rem', fontWeight: 700 })}>Writeups in the works</h2>
        <p class={css({ color: 'textMuted', maxW: '480px', lineHeight: 1.7 })}>
          Full walkthroughs of public lab &amp; CTF challenges — CyberDefenders, 13Cubed,
          MemLabs, Magnet, and home-lab projects — are on the way, with a focus on host and
          memory forensics.
        </p>
        <a
          href="/blog/"
          class={css({
            display: 'inline-flex',
            alignItems: 'center',
            gap: '0.5rem',
            mt: '0.25rem',
            bg: 'primary',
            color: 'onPrimary',
            fontWeight: 600,
            px: '1.25rem',
            py: '0.7rem',
            borderRadius: 'md',
            transition: 'background 200ms ease',
            _hover: { bg: 'primaryHover' },
          })}
        >
          Read the blog meanwhile <Icon name="arrow-right" size={16} />
        </a>
      </div>
    )
  }
</BaseLayout>

<p id="lab-empty" hidden class={css({ color: 'textMuted', textAlign: 'center', py: '2rem' })}>
  No writeups match your filters.
</p>

<script is:inline>
  (function () {
    var combobox = document.getElementById('lab-cb');
    var chips = Array.prototype.slice.call(document.querySelectorAll('[data-filter]'));
    var items = Array.prototype.slice.call(document.querySelectorAll('.lab-item'));
    var countEl = document.getElementById('lab-count');
    var wordEl = document.getElementById('lab-count-word');
    var empty = document.getElementById('lab-empty');
    var source = 'all';
    var query = '';
    var tags = [];
    function apply() {
      var q = query.toLowerCase();
      var shown = 0;
      items.forEach(function (item) {
        var matchSource = source === 'all' || item.getAttribute('data-source') === source;
        var matchText = !q || (item.getAttribute('data-search') || '').indexOf(q) !== -1;
        var dt = item.getAttribute('data-tags') || '';
        var matchTags = tags.every(function (s) { return dt.indexOf('|' + s + '|') !== -1; }); // AND
        var show = matchSource && matchText && matchTags;
        item.style.display = show ? '' : 'none';
        if (show) shown++;
      });
      if (countEl) countEl.textContent = String(shown);
      if (wordEl) wordEl.textContent = shown === 1 ? 'writeup' : 'writeups';
      if (empty) empty.hidden = shown !== 0;
      chips.forEach(function (c) {
        if (c.getAttribute('data-filter') === source) c.setAttribute('data-active', '');
        else c.removeAttribute('data-active');
      });
    }
    if (combobox) combobox.addEventListener('comboboxchange', function (e) { tags = e.detail.selected; query = e.detail.query; apply(); });
    chips.forEach(function (c) {
      c.addEventListener('click', function () { source = c.getAttribute('data-filter'); apply(); });
    });
    apply();
  })();
</script>
