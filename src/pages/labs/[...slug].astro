---
// Single lab writeup — renders an MDX lab entry via PostLayout.
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { estimateReadTime, getSortedLabs } from '../../utils/posts';

// Prerender to static HTML (required: getStaticPaths is ignored under output: 'server').
export const prerender = true;

export async function getStaticPaths() {
  // getSortedLabs() excludes drafts in production, so drafts never get a page.
  const labs = await getSortedLabs();
  return labs.map((lab) => ({
    params: { slug: lab.id },
    props: { lab },
  }));
}

const { lab } = Astro.props;
const { Content, headings } = await render(lab);
const readTime = estimateReadTime(lab.body);

const tags = [...new Set([lab.data.source, ...lab.data.tags])];

// Series: sibling labs sharing this lab's `series`, ordered by `seriesOrder`.
const allLabs = await getSortedLabs();
const series = lab.data.series
  ? {
      name: lab.data.series,
      parts: allLabs
        .filter((p) => p.data.series === lab.data.series)
        .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
        .map((p, i) => ({ title: p.data.title, href: `/labs/${p.id}/`, n: i + 1, current: p.id === lab.id })),
    }
  : undefined;
---

<PostLayout
  title={lab.data.title}
  excerpt={lab.data.excerpt}
  category={lab.data.source}
  date={lab.data.date}
  readTime={readTime}
  difficulty={lab.data.difficulty}
  tags={tags}
  tools={lab.data.tools}
  headings={headings}
  path={`/labs/${lab.id}/`}
  series={series}
>
  <Content />
</PostLayout>
