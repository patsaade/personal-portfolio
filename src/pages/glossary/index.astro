---
// Glossary index — the full, searchable bank, with today's "Term of the Day"
// featured up top (client-updated to the visitor's day).
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Badge from '../../components/Badge.astro';
import Icon from '../../components/Icon.astro';
import {
  CATEGORIES,
  CATEGORY_META,
  SECURITY_TERMS,
  termForDate,
} from '../../data/securityTerms';
import { ATTACK_TECHNIQUES } from '../../data/references';
import CollapseAll from '../../components/CollapseAll.astro';
import TagCombobox from '../../components/TagCombobox.astro';
import { tagSlug } from '../../utils/posts';
import { assignTermSymbols } from '../../data/termSymbols';
import { tag } from 'styled-system/recipes';

const today = termForDate(new Date());
const todayDate = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
const total = SECURITY_TERMS.length;

// Category facet for the search combobox (only categories that have terms).
const catOptions = CATEGORIES.map((cat) => ({ cat, n: SECURITY_TERMS.filter((t) => t.category === cat).length }))
  .filter((c) => c.n > 0)
  .map((c) => ({ value: tagSlug(c.cat), label: c.cat, count: c.n }));

// A unique decorative glyph per term (faint corner watermark on each card).
const termSymbols = assignTermSymbols(SECURITY_TERMS.map((t) => t.slug));

// Map each glossary slug to its ATT&CK technique (for the on-card chip).
const techBySlug: Record<string, (typeof ATTACK_TECHNIQUES)[number]> = {};
for (const tech of ATTACK_TECHNIQUES) if (tech.glossarySlug) techBySlug[tech.glossarySlug] = tech;

// Compact, uniform term cards: a stretched term link, a faint dictionary-style
// initial filling the top-right corner, and an optional ATT&CK chip pinned
// bottom-right (mirroring how term pages link to ATT&CK).
const cardClass = css({
  position: 'relative',
  display: 'flex',
  flexDirection: 'column',
  gap: '0.2rem',
  p: '0.6rem 0.7rem',
  minH: '4rem',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  overflow: 'hidden',
  transition: 'border-color 200ms ease, transform 200ms ease',
  _hover: {
    borderColor: 'primary',
    transform: 'translateY(-2px)',
    '& .gloss-go': { transform: 'translateX(2px)', color: 'primary' },
  },
});
const cardLink = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.15rem',
  minW: 0,
  _after: { content: '""', position: 'absolute', inset: '0', borderRadius: 'md' },
});
// Header row: term + a navigation arrow (mirrors the Tools cards); arrow nudges on hover.
const cardHead = css({ display: 'flex', alignItems: 'flex-start', justifyContent: 'space-between', gap: '0.4rem' });
const cardTerm = css({ fontFamily: 'sans', fontWeight: 700, fontSize: '0.86rem', color: 'text', lineHeight: 1.3, minW: 0 });
const goArrow = css({ color: 'textMuted', flexShrink: 0, mt: '0.1rem', transition: 'transform 200ms ease, color 200ms ease' });
const cardShort = css({ fontSize: '0.79rem', color: 'textMuted', lineHeight: 1.4 });
// Footer pinned to the bottom: the term's unique symbol (left) + ATT&CK chip (right).
const cardFooter = css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '0.5rem', mt: 'auto', pt: '0.2rem' });
// A unique monochrome symbol per term (see data/termSymbols.ts), bottom-left.
// Decorative, so aria-hidden; symbol-friendly font stack for glyph coverage.
const monogram = css({
  fontFamily: "'Segoe UI Symbol', 'Apple Symbols', 'Noto Sans Symbols2', system-ui, sans-serif",
  fontSize: '1.3rem',
  lineHeight: 1,
  color: 'color-mix(in srgb, token(colors.primary) 50%, transparent)',
  userSelect: 'none',
  pointerEvents: 'none',
  flexShrink: 0,
});
const attackTag = `${tag({ tone: 'primary', mono: true })} ${css({
  position: 'relative',
  zIndex: 1,
  flexShrink: 0,
  transition: 'background 150ms ease',
  _hover: { bg: 'color-mix(in srgb, token(colors.primary) 24%, transparent)' },
})}`;

// Each category is a collapsible <details>, matching the Tools / Certifications pages.
const groupDetails = css({ borderTop: '1px solid token(colors.border)', py: '1.25rem' });
const groupSummary = css({
  cursor: 'pointer',
  listStyle: 'none',
  userSelect: 'none',
  '&::-webkit-details-marker': { display: 'none' },
  '&::marker': { display: 'none' },
  _hover: { '& .totd-grp-title': { color: 'primary' } },
});
const groupHead = css({ display: 'flex', alignItems: 'center', gap: '0.6rem', flexWrap: 'wrap', m: 0, fontSize: '1.15rem', fontWeight: 700 });
const chevCls = css({ color: 'textMuted', flexShrink: 0, transition: 'transform 200ms ease', 'details[open] &': { transform: 'rotate(90deg)' } });
const grpCount = css({ fontFamily: 'sans', fontSize: '0.68rem', fontWeight: 600, color: 'textMuted', bg: 'bgSubtle', border: '1px solid token(colors.border)', borderRadius: 'full', px: '0.5rem', py: '0.1rem' });
---

<BaseLayout
  title="Glossary"
  description="A cybersecurity & DFIR glossary — concepts, techniques, and artifacts, with why each one matters in an investigation."
>
  <PageHeader breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Glossary' }]} eyebrow="Reference" title="Cybersecurity glossary" />

  {/* ── Today's featured term (client-updated to the visitor's local day) ── */}
  <section
    class={css({
      border: '1px solid token(colors.border)',
      borderTopWidth: '3px',
      borderTopColor: 'primary',
      borderRadius: 'lg',
      bg: 'bgCard',
      p: { base: '1.5rem', md: '2rem' },
      mb: '2.5rem',
      boxShadow: 'card',
    })}
  >
    <div class={css({ display: 'flex', justifyContent: 'space-between', alignItems: 'center', gap: '1rem', mb: '1rem', flexWrap: 'wrap' })}>
      <span class={css({ display: 'inline-flex', alignItems: 'center', gap: '0.45rem', fontFamily: 'sans', fontSize: '0.75rem', textTransform: 'uppercase', letterSpacing: '0.12em', color: 'primary', fontWeight: 700 })}>
        <Icon name="radio" size={15} /> Today’s term
      </span>
      <span id="totd-feat-date" class={css({ fontFamily: 'sans', fontSize: '0.8rem', color: 'textMuted' })}>{todayDate}</span>
    </div>

    <div class={css({ mb: '0.75rem' })}>
      <Badge variant="primary" icon="book-open"><span id="totd-feat-cat">{today.category}</span></Badge>
    </div>

    <h2 id="totd-feat-term" class={css({ fontSize: { base: '1.9rem', md: '2.4rem' }, fontWeight: 700, letterSpacing: '-0.02em', lineHeight: 1.1 })}>
      {today.term}
    </h2>
    <p id="totd-feat-short" class={css({ fontSize: '1.15rem', color: 'textMuted', mt: '0.6rem', maxW: '640px' })}>
      {today.short}
    </p>

    <a
      id="totd-feat-link"
      href={`/glossary/${today.slug}/`}
      class={css({
        display: 'inline-flex',
        alignItems: 'center',
        gap: '0.4rem',
        mt: '1.25rem',
        fontWeight: 600,
        color: 'primary',
        _hover: { '& svg': { transform: 'translateX(3px)' } },
      })}
    >
      Read the full entry
      <Icon name="arrow-right" size={16} class={css({ transition: 'transform 200ms ease' })} />
    </a>
  </section>

  {/* ── Search + category filter (typeahead combobox) ── */}
  <div class={css({ mb: '0.6rem' })}>
    <TagCombobox
      id="glossary-cb"
      options={catOptions}
      placeholder={`Search ${total} terms, or type a category…`}
      label="Search the glossary or filter by category"
    />
  </div>
  <div class={css({ display: 'flex', alignItems: 'center', gap: '1rem', flexWrap: 'wrap', mb: '2rem' })}>
    <p role="status" aria-live="polite" class={css({ color: 'textMuted', fontSize: '0.9rem', m: 0 })}>
      <span id="totd-result-count">{total}</span> terms — every one a concept, technique, or artifact you’ll meet in a real investigation.
    </p>
    <CollapseAll target="[data-totd-group]" />
  </div>

  {/* ── Full glossary (collapsible by category) ── */}
  <div class={css({ display: 'flex', flexDirection: 'column' })}>
    {
      CATEGORIES.map((cat) => {
        const terms = SECURITY_TERMS.filter((t) => t.category === cat);
        if (terms.length === 0) return null;
        return (
          <details open data-totd-group class={groupDetails}>
            <summary class={groupSummary}>
              <h3 class={groupHead}>
                <Icon name="chevron-right" size={17} class={chevCls} />
                <Icon name={CATEGORY_META[cat].icon as any} size={19} class={css({ color: 'primary', flexShrink: 0 })} />
                <span class="totd-grp-title">{cat}</span>
                <span class={grpCount}>{terms.length}</span>
              </h3>
            </summary>
            <div class={css({ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(min(100%, 215px), 1fr))', gap: '0.6rem', mt: '1rem' })}>
              {terms.map((t) => {
                const tech = techBySlug[t.slug];
                return (
                  <div
                    class={cardClass}
                    data-cat={tagSlug(t.category)}
                    data-totd-card={`${t.term} ${t.short} ${(t.aka ?? []).join(' ')} ${t.category} ${tech ? tech.id : ''}`.toLowerCase()}
                  >
                    <a href={`/glossary/${t.slug}/`} class={cardLink}>
                      <span class={cardHead}>
                        <span class={cardTerm}>{t.term}</span>
                        <Icon name="arrow-right" size={14} class={`gloss-go ${goArrow}`} />
                      </span>
                      <span class={`${cardShort} totd-clamp2`}>{t.short}</span>
                    </a>
                    <div class={cardFooter}>
                      <span class={monogram} aria-hidden="true">{termSymbols[t.slug]}</span>
                      {tech && (
                        <a href={`/attack-map/${tech.id}/`} class={attackTag} title={`MITRE ATT&CK ${tech.id} — ${tech.name}`}>
                          {tech.id}
                        </a>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </details>
        );
      })
    }
  </div>

  <p id="totd-empty" hidden role="status" aria-live="polite" class={css({ color: 'textMuted', textAlign: 'center', py: '3rem' })}>
    No terms match your search.
  </p>

  <script is:inline>
    (function () {
      // Featured card → today's term for the visitor's local day (via cached bank.json).
      fetch('/glossary/bank.json')
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (bank) {
          if (!Array.isArray(bank) || !bank.length) return;
          var d = new Date();
          var serial = Math.floor(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()) / 86400000);
          var e = bank[((serial % bank.length) + bank.length) % bank.length]; // [slug, term, short, cat]
          var set = function (id, val) { var el = document.getElementById(id); if (el) el.textContent = val; };
          set('totd-feat-term', e[1]);
          set('totd-feat-short', e[2]);
          set('totd-feat-cat', e[3]);
          var dateEl = document.getElementById('totd-feat-date');
          if (dateEl) { try { dateEl.textContent = d.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' }); } catch (err) {} }
          var link = document.getElementById('totd-feat-link');
          if (link) link.setAttribute('href', '/glossary/' + e[0] + '/');
        })
        .catch(function () {});

      // Client-side glossary search + category facet (typeahead combobox).
      var combobox = document.getElementById('glossary-cb');
      if (!combobox) return;
      var cards = Array.prototype.slice.call(document.querySelectorAll('[data-totd-card]'));
      var groups = Array.prototype.slice.call(document.querySelectorAll('[data-totd-group]'));
      var empty = document.getElementById('totd-empty');
      var countEl = document.getElementById('totd-result-count');
      var query = '';
      var cats = [];
      function apply() {
        var q = query.toLowerCase();
        var shown = 0;
        for (var i = 0; i < cards.length; i++) {
          var c = cards[i];
          var matchText = !q || c.getAttribute('data-totd-card').indexOf(q) !== -1;
          var matchCat = cats.length === 0 || cats.indexOf(c.getAttribute('data-cat')) !== -1; // OR within categories
          var show = matchText && matchCat;
          c.style.display = show ? '' : 'none';
          if (show) shown++;
        }
        var filtering = !!q || cats.length > 0;
        for (var g = 0; g < groups.length; g++) {
          var anyVisible = groups[g].querySelector('[data-totd-card]:not([style*="display: none"])');
          groups[g].style.display = anyVisible ? '' : 'none';
          if (filtering && anyVisible) groups[g].open = true; // surface matches inside collapsed categories
        }
        if (empty) empty.hidden = shown !== 0;
        if (countEl) countEl.textContent = String(shown);
      }
      combobox.addEventListener('comboboxchange', function (e) {
        cats = e.detail.selected;
        query = e.detail.query;
        apply();
      });
    })();
  </script>
</BaseLayout>
