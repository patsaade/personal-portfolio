---
// MITRE ATT&CK coverage map — the FULL Enterprise matrix (generated from MITRE's
// official STIX), laid out by tactic in kill-chain order. Each technique links to
// its MITRE page, its own detail page, and (where one exists) the glossary entry;
// posts/labs that tag an `attack` ID mark it "covered". Searchable, with a
// covered-only filter, a coverage summary, and a legend. Linked from the footer's
// "More". Static page — prerendered to HTML served from the CDN.
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import CollapseAll from '../components/CollapseAll.astro';
import TagCombobox from '../components/TagCombobox.astro';
import FilterToggle from '../components/FilterToggle.astro';
import { tag } from 'styled-system/recipes';
import { getSortedPosts, getSortedLabs, tagSlug } from '../utils/posts';
import { termBySlug } from '../data/securityTerms';
import { ATTACK_TECHNIQUES, ATTACK_TACTIC_ORDER, ATTACK_VERSION } from '../data/references';

// Techniques explicitly covered by a post/lab (via its `attack` frontmatter).
const [posts, labs] = await Promise.all([getSortedPosts(), getSortedLabs()]);
const covered = new Set([...posts, ...labs].flatMap((p) => p.data.attack ?? []));

// Group techniques by tactic; render tactics in kill-chain order, populated only.
// A technique can sit under several tactics — list it under each, like the matrix.
const byTactic: Record<string, typeof ATTACK_TECHNIQUES> = {};
for (const t of ATTACK_TECHNIQUES) for (const tac of t.tactics) (byTactic[tac] ??= []).push(t);
const tactics = ATTACK_TACTIC_ORDER.filter((name) => byTactic[name]?.length);
// Anchor each technique's id to its first render only (no duplicate DOM ids).
const anchored = new Set<string>();

const total = ATTACK_TECHNIQUES.length;
const linkedCount = ATTACK_TECHNIQUES.filter((t) => t.glossarySlug).length;
const coveredCount = ATTACK_TECHNIQUES.filter((t) => covered.has(t.id)).length;

// Platform facet for the search combobox — cross-cuts the tactic grouping, so you
// can narrow to e.g. Windows or Linux techniques. A technique runs on several.
const platCounts: Record<string, number> = {};
for (const t of ATTACK_TECHNIQUES) for (const p of t.platforms ?? []) platCounts[p] = (platCounts[p] ?? 0) + 1;
const platformOptions = Object.entries(platCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([p, n]) => ({ value: tagSlug(p), label: p, count: n }));

// Each tactic is a collapsible <details>, matching the glossary / Tools / Certifications pages.
const groupDetails = css({ borderTop: '1px solid token(colors.border)', py: '1.25rem' });
const groupSummary = css({
  cursor: 'pointer',
  listStyle: 'none',
  userSelect: 'none',
  '&::-webkit-details-marker': { display: 'none' },
  '&::marker': { display: 'none' },
  _hover: { '& .tactic-title': { color: 'primary' } },
});
const chevCls = css({ color: 'textMuted', flexShrink: 0, transition: 'transform 200ms ease', 'details[open] &': { transform: 'rotate(90deg)' } });
const tacticHead = css({ display: 'flex', alignItems: 'center', gap: '0.5rem', m: 0, fontSize: '1.05rem', fontWeight: 700 });
const tacCount = css({ fontFamily: 'sans', fontSize: '0.68rem', fontWeight: 600, color: 'textMuted', bg: 'bgSubtle', border: '1px solid token(colors.border)', borderRadius: 'full', px: '0.5rem', py: '0.1rem' });
const tacCoveredCount = css({ fontFamily: 'sans', fontSize: '0.72rem', fontWeight: 600, color: 'accent' });
const grid = css({ mt: '1rem' }); // columns/gap come from the shared .card-grid class
const chip = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.35rem',
  p: '0.7rem 0.85rem',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  transition: 'border-color 200ms ease, transform 200ms ease',
  scrollMarginTop: '90px', // clear the sticky header when linked to via #<id>
  _hover: { borderColor: 'primary', transform: 'translateY(-2px)' },
  '&[data-covered]': { borderLeftWidth: '3px', borderLeftColor: 'accent' },
  '&:target': { borderColor: 'primary', boxShadow: 'cardHover' },
});
const chipTop = css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '0.5rem' });
const chipId = css({ fontFamily: 'mono', fontSize: '0.72rem', fontWeight: 600, color: 'primary' });
const coveredBadge = tag({ tone: 'accent' });
const chipName = css({ display: 'inline-flex', alignItems: 'center', gap: '0.3rem', fontWeight: 600, fontSize: '0.9rem', color: 'text', lineHeight: 1.3, _hover: { color: 'primary' } });
const chipGloss = css({ display: 'inline-flex', alignItems: 'center', gap: '0.25rem', fontSize: '0.78rem', fontWeight: 600, color: 'textMuted', mt: 'auto', _hover: { color: 'primary' } });

// Search + controls.
const statLink = css({ color: 'primary', display: 'inline-flex', alignItems: 'center', gap: '0.3rem', _hover: { textDecoration: 'underline' } });
const legendRow = css({ display: 'flex', flexWrap: 'wrap', gap: '0.4rem 1.25rem', mb: '1.75rem', fontSize: '0.78rem', color: 'textMuted' });
const legendItem = css({ display: 'inline-flex', alignItems: 'center', gap: '0.4rem' });
const legendSwatch = css({ display: 'inline-block', w: '14px', h: '14px', bg: 'bgCard', border: '1px solid token(colors.border)', borderLeftWidth: '3px', borderLeftColor: 'accent', borderRadius: '2px', flexShrink: 0 });
---

<BaseLayout
  title="ATT&CK coverage map"
  description="The full MITRE ATT&CK Enterprise matrix, by tactic — each technique linked to its official MITRE page, a detail page, and the matching glossary entry, with the techniques covered in writeups marked."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'MITRE ATT&CK Map' }]}
    eyebrow="Coverage"
    title="MITRE ATT&CK coverage map"
    description="The full Enterprise matrix, laid out by tactic. Each technique links to its official MITRE page and detail entry; many link straight to the glossary, and the ones I've written about are marked."
  />

  <aside
    class={css({
      bg: 'bgSubtle',
      border: '1px solid token(colors.border)',
      borderLeftWidth: '3px',
      borderLeftColor: 'primary',
      borderRadius: 'md',
      p: '1rem 1.25rem',
      mb: '1.5rem',
    })}
  >
    <p class={css({ color: 'text', lineHeight: 1.7, fontSize: '0.95rem', m: 0 })}>
      <strong class={css({ color: 'text' })}>MITRE ATT&CK</strong> — short for <em>Adversarial Tactics,
      Techniques, and Common Knowledge</em> — is a free, openly maintained knowledge base of how real
      attackers operate. <em>Tactics</em> are the adversary's goals (the <em>why</em>, e.g. Persistence);
      <em>techniques</em> are the specific methods used to reach them (the <em>how</em>, e.g. Process
      Injection). Mapping detections and writeups to it gives defenders a shared vocabulary for
      describing intrusions.
    </p>
  </aside>

  {/* Search + platform filter (typeahead combobox) */}
  <div class={css({ mb: '0.6rem' })}>
    <TagCombobox
      id="attack-cb"
      options={platformOptions}
      placeholder={`Search ${total} techniques by name or ID, or type a platform…`}
      label="Search ATT&CK techniques or filter by platform"
    />
  </div>

  {/* Stats + controls */}
  <div class={css({ display: 'flex', alignItems: 'center', gap: '0.6rem 1rem', flexWrap: 'wrap', mb: '0.85rem' })}>
    <p role="status" aria-live="polite" class={css({ display: 'flex', flexWrap: 'wrap', alignItems: 'center', gap: '0.3rem 0.9rem', color: 'textMuted', fontSize: '0.9rem', m: 0 })}>
      <span><span id="attack-count">{total}</span> techniques</span>
      <span aria-hidden="true">·</span>
      <span class={css({ color: 'accent', fontWeight: 600 })}>{coveredCount} covered in writeups</span>
      <span aria-hidden="true">·</span>
      <span>{linkedCount} in the glossary</span>
      <span aria-hidden="true">·</span>
      <a href="https://attack.mitre.org/" target="_blank" rel="noopener" class={statLink}>ATT&CK v{ATTACK_VERSION} <Icon name="external-link" size={12} /></a>
    </p>
    <div class={css({ display: 'flex', alignItems: 'center', gap: '0.5rem', ml: 'auto' })}>
      <FilterToggle id="attack-covered-toggle" icon="check" label="Covered only" tone="accent" />
      <FilterToggle id="attack-gloss-toggle" icon="book-open" label="In glossary" tone="primary" />
      <CollapseAll target="[data-tactic-group]" />
    </div>
  </div>

  {/* Legend */}
  <div class={legendRow}>
    <span class={legendItem}><span class={legendSwatch} aria-hidden="true"></span> covered in a writeup</span>
    <span class={legendItem}><Icon name="book-open" size={13} class={css({ color: 'textMuted' })} /> links to the glossary entry</span>
    <span class={legendItem}><Icon name="arrow-right" size={13} class={css({ color: 'textMuted' })} /> opens the technique detail page</span>
  </div>

  <div class={css({ display: 'flex', flexDirection: 'column' })}>
    {
      tactics.map((tactic) => {
        const tacCovered = byTactic[tactic].filter((t) => covered.has(t.id)).length;
        return (
          <details data-tactic-group open class={groupDetails}>
            <summary class={groupSummary}>
              <h2 class={tacticHead}>
                <Icon name="chevron-right" size={17} class={chevCls} />
                <Icon name="crosshair" size={18} class={css({ color: 'primary', flexShrink: 0 })} />
                <span class="tactic-title">{tactic}</span>
                <span class={tacCount}>{byTactic[tactic].length}</span>
                {tacCovered > 0 && <span class={tacCoveredCount}>{tacCovered} covered</span>}
              </h2>
            </summary>
            <div class={`card-grid ${grid}`}>
              {byTactic[tactic].map((t) => {
                const gloss = t.glossarySlug ? termBySlug(t.glossarySlug) : undefined;
                const firstHere = !anchored.has(t.id);
                if (firstHere) anchored.add(t.id);
                const isCovered = covered.has(t.id);
                return (
                  <div
                    id={firstHere ? t.id : undefined}
                    class={chip}
                    data-attack-id={t.id}
                    data-platforms={`|${(t.platforms ?? []).map(tagSlug).join('|')}|`}
                    data-attack-card={`${t.id} ${t.name} ${tactic} ${gloss ? gloss.term : ''}`.toLowerCase()}
                    {...(isCovered ? { 'data-covered': true } : {})}
                    {...(gloss ? { 'data-has-gloss': true } : {})}
                  >
                    <div class={chipTop}>
                      <span class={chipId}>{t.id}</span>
                      {isCovered && <span class={coveredBadge}>covered</span>}
                    </div>
                    <a href={`/attack-map/${t.id}/`} class={chipName}>
                      {t.name}
                      <Icon name="arrow-right" size={12} class={css({ color: 'textMuted', flexShrink: 0 })} />
                    </a>
                    {gloss && (
                      <a href={`/glossary/${gloss.slug}/`} class={chipGloss}>
                        <Icon name="book-open" size={12} /> {gloss.term}
                      </a>
                    )}
                  </div>
                );
              })}
            </div>
          </details>
        );
      })
    }
  </div>

  <p id="attack-empty" hidden role="status" aria-live="polite" class={css({ color: 'textMuted', textAlign: 'center', py: '3rem' })}>
    No techniques match.
  </p>

  <p class={css({ fontSize: '0.78rem', color: 'textMuted', mt: '2.5rem', pt: '1.5rem', borderTop: '1px solid token(colors.border)', lineHeight: 1.6 })}>
    ATT&CK® and MITRE ATT&CK® are registered trademarks of The MITRE Corporation. Technique names and
    IDs are drawn from the public ATT&CK knowledge base (v{ATTACK_VERSION}); this map links back to the canonical pages.
  </p>

  <script is:inline>
    (function () {
      var combobox = document.getElementById('attack-cb');
      var toggle = document.getElementById('attack-covered-toggle');
      var glossToggle = document.getElementById('attack-gloss-toggle');
      var countEl = document.getElementById('attack-count');
      var empty = document.getElementById('attack-empty');
      var groups = Array.prototype.slice.call(document.querySelectorAll('[data-tactic-group]'));
      var chips = Array.prototype.slice.call(document.querySelectorAll('[data-attack-card]'));
      var coveredOnly = false;
      var glossOnly = false;
      var query = '';
      var plats = [];

      function apply() {
        var q = query.toLowerCase();
        var seen = {};
        var shown = 0;
        for (var i = 0; i < chips.length; i++) {
          var c = chips[i];
          var okQ = !q || c.getAttribute('data-attack-card').indexOf(q) !== -1;
          var okCov = !coveredOnly || c.hasAttribute('data-covered');
          var okGloss = !glossOnly || c.hasAttribute('data-has-gloss');
          var dp = c.getAttribute('data-platforms') || '';
          var okPlat = plats.length === 0 || plats.some(function (p) { return dp.indexOf('|' + p + '|') !== -1; }); // OR
          var vis = okQ && okCov && okGloss && okPlat;
          c.style.display = vis ? '' : 'none';
          if (vis) {
            var id = c.getAttribute('data-attack-id');
            if (!seen[id]) { seen[id] = 1; shown++; } // count techniques once across tactics
          }
        }
        var filtering = !!q || coveredOnly || glossOnly || plats.length > 0;
        for (var g = 0; g < groups.length; g++) {
          var any = groups[g].querySelector('[data-attack-card]:not([style*="display: none"])');
          groups[g].style.display = any ? '' : 'none';
          groups[g].open = filtering ? !!any : true; // expand matches while filtering, restore otherwise
        }
        if (countEl) countEl.textContent = String(shown);
        if (empty) empty.hidden = shown !== 0;
      }

      if (combobox) combobox.addEventListener('comboboxchange', function (e) {
        plats = e.detail.selected;
        query = e.detail.query;
        apply();
      });
      if (toggle) toggle.addEventListener('click', function () {
        coveredOnly = !coveredOnly;
        toggle.setAttribute('aria-pressed', coveredOnly ? 'true' : 'false');
        apply();
      });
      if (glossToggle) glossToggle.addEventListener('click', function () {
        glossOnly = !glossOnly;
        glossToggle.setAttribute('aria-pressed', glossOnly ? 'true' : 'false');
        apply();
      });
    })();
  </script>
</BaseLayout>
