---
// MITRE ATT&CK coverage map — the techniques referenced across the glossary and
// writeups, laid out by tactic in kill-chain order. Each links to its official
// MITRE page and, where one exists, the matching glossary entry; posts that tag
// an `attack` technique ID mark it "covered". Hidden from the header, linked from
// the footer's "More". Static page — prerender to HTML served from the CDN.
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import { getSortedPosts, getSortedLabs } from '../utils/posts';
import { termBySlug } from '../data/securityTerms';
import { ATTACK_TECHNIQUES, ATTACK_TACTIC_ORDER } from '../data/references';

// Techniques explicitly covered by a post/lab (via its `attack` frontmatter).
const [posts, labs] = await Promise.all([getSortedPosts(), getSortedLabs()]);
const covered = new Set([...posts, ...labs].flatMap((p) => p.data.attack ?? []));

// Group techniques by tactic; render tactics in kill-chain order, populated only.
const byTactic: Record<string, typeof ATTACK_TECHNIQUES> = {};
for (const t of ATTACK_TECHNIQUES) (byTactic[t.tactic] ??= []).push(t);
const tactics = ATTACK_TACTIC_ORDER.filter((name) => byTactic[name]?.length);

const linkedCount = ATTACK_TECHNIQUES.filter((t) => t.glossarySlug).length;

const tacticHead = css({ display: 'flex', alignItems: 'center', gap: '0.5rem', fontSize: '1.05rem', fontWeight: 700, mb: '0.85rem' });
const grid = css({ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(min(100%, 240px), 1fr))', gap: '0.65rem' });
const chip = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.35rem',
  p: '0.7rem 0.85rem',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  transition: 'border-color 200ms ease, transform 200ms ease',
  _hover: { borderColor: 'primary', transform: 'translateY(-2px)' },
  '&[data-covered]': { borderLeftWidth: '3px', borderLeftColor: 'accent' },
});
const chipTop = css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '0.5rem' });
const chipId = css({ fontFamily: 'mono', fontSize: '0.72rem', fontWeight: 600, color: 'primary' });
const coveredBadge = css({ fontFamily: 'sans', fontSize: '0.6rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.05em', color: 'accent', bg: 'color-mix(in srgb, token(colors.accent) 13%, transparent)', border: '1px solid color-mix(in srgb, token(colors.accent) 35%, transparent)', borderRadius: 'sm', px: '0.35rem', py: '0.05rem' });
const chipName = css({ display: 'inline-flex', alignItems: 'center', gap: '0.3rem', fontWeight: 600, fontSize: '0.9rem', color: 'text', lineHeight: 1.3, _hover: { color: 'primary' } });
const chipGloss = css({ display: 'inline-flex', alignItems: 'center', gap: '0.25rem', fontSize: '0.78rem', fontWeight: 600, color: 'textMuted', mt: 'auto', _hover: { color: 'primary' } });
---

<BaseLayout
  title="ATT&CK coverage map"
  description="The MITRE ATT&CK techniques referenced across this site's glossary and writeups, by tactic — each linked to its official MITRE page and the matching glossary entry."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'ATT&CK map' }]}
    eyebrow="Coverage"
    title="MITRE ATT&CK coverage map"
    description="The adversary techniques I reference across the glossary and writeups, laid out by tactic. Each links to its official MITRE page; many link straight to the glossary entry that explains it."
  />

  <p class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.4rem 1.25rem', color: 'textMuted', fontSize: '0.9rem', mb: '2rem' })}>
    <span>{ATTACK_TECHNIQUES.length} techniques across {tactics.length} tactics</span>
    <span>·</span>
    <span>{linkedCount} linked to a glossary entry</span>
    <span>·</span>
    <a href="https://attack.mitre.org/" target="_blank" rel="noopener" class={css({ color: 'primary', display: 'inline-flex', alignItems: 'center', gap: '0.3rem', _hover: { textDecoration: 'underline' } })}>
      MITRE ATT&CK <Icon name="external-link" size={12} />
    </a>
  </p>

  <div class={css({ display: 'flex', flexDirection: 'column', gap: '2.25rem' })}>
    {
      tactics.map((tactic) => (
        <section>
          <h2 class={tacticHead}>
            <Icon name="crosshair" size={18} class={css({ color: 'primary' })} />
            {tactic}
            <span class={css({ fontFamily: 'sans', fontSize: '0.78rem', fontWeight: 400, color: 'textMuted' })}>{byTactic[tactic].length}</span>
          </h2>
          <div class={grid}>
            {byTactic[tactic].map((t) => {
              const gloss = t.glossarySlug ? termBySlug(t.glossarySlug) : undefined;
              return (
                <div class={chip} {...(covered.has(t.id) ? { 'data-covered': true } : {})}>
                  <div class={chipTop}>
                    <span class={chipId}>{t.id}</span>
                    {covered.has(t.id) && <span class={coveredBadge}>covered</span>}
                  </div>
                  <a href={t.url} target="_blank" rel="noopener" class={chipName}>
                    {t.name}
                    <Icon name="external-link" size={12} class={css({ color: 'textMuted', flexShrink: 0 })} />
                  </a>
                  {gloss && (
                    <a href={`/glossary/${gloss.slug}/`} class={chipGloss}>
                      <Icon name="book-open" size={12} /> {gloss.term}
                    </a>
                  )}
                </div>
              );
            })}
          </div>
        </section>
      ))
    }
  </div>

  <p class={css({ fontSize: '0.78rem', color: 'textMuted', mt: '2.5rem', pt: '1.5rem', borderTop: '1px solid token(colors.border)', lineHeight: 1.6 })}>
    ATT&CK® and MITRE ATT&CK® are registered trademarks of The MITRE Corporation. Technique names and
    IDs are drawn from the public ATT&CK knowledge base; this map links back to the canonical pages.
  </p>
</BaseLayout>
