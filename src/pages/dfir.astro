---
// DFIR landing page — the single "browse everything" destination for the 6
// DFIR_GROUPS categories (17 links total: reference material, the two MITRE
// framework maps, and 11 interactive tools split by workflow shape). Nav's
// "DFIR" dropdown, the footer's compact DFIR column, and ToolSidebar's rail
// all point subsets of this same data at their own surfaces; this page is
// the one place all of it is shown at once, with a one-line description per
// destination instead of just a label.
// Deliberately NOT collapsible <details> like tools.astro/event-ids.astro —
// those hide 50+ same-shaped filterable instances; this page has 17 items
// across 6 groups, small enough that hiding any of it behind a click would
// defeat the point of a landing/overview page whose whole job is to show
// everything at a glance.
export const prerender = true;
import { css } from 'styled-system/css';
import { card } from 'styled-system/recipes';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import GroupOverview from '../components/GroupOverview.astro';
import Icon from '../components/Icon.astro';
import { DFIR_GROUPS } from '../consts';

// "Browse by category" jump-strip — one tile per DFIR_GROUPS category,
// representative icon = that category's first link (icon uniqueness across
// DFIR_GROUPS is already enforced in consts.ts, so any member icon reads
// cleanly here too).
const groupTiles = DFIR_GROUPS.map((g) => ({
  id: g.id,
  icon: g.links[0].icon,
  title: g.category,
  blurb: g.blurb,
  count: g.links.length,
}));

const sectionWrap = css({ borderTop: '1px solid token(colors.border)', py: '1.25rem', scrollMarginTop: '90px' });
const sectionHead = css({ display: 'flex', alignItems: 'center', gap: '0.6rem', flexWrap: 'wrap', m: 0, fontSize: '1.25rem', fontWeight: 700 });
const sectionCount = css({
  fontFamily: 'sans',
  fontSize: '0.68rem',
  fontWeight: 600,
  color: 'textMuted',
  bg: 'bgSubtle',
  border: '1px solid token(colors.border)',
  borderRadius: 'full',
  px: '0.5rem',
  py: '0.1rem',
});
const sectionBlurb = css({ color: 'textMuted', fontSize: '0.85rem', mt: '0.5rem', mb: 0 });
const cardsGrid = css({ mt: '1rem' }); // columns/gap come from the shared .card-grid class
// card()'s own recipe already sets _hover.borderColor/_hover.transform — this
// appended css() only adds a non-overlapping property, per the CSS-composition
// rule (docs/STYLE_GUIDE.md "Buttons"), matching tools.astro's toolCard.
const linkCard = `${card()} ${css({ _hover: { boxShadow: 'card' } })}`;
const cardHead = css({ display: 'flex', alignItems: 'center', gap: '0.5rem' });
const cardTitle = css({ fontFamily: 'sans', fontWeight: 700, fontSize: '0.9rem', color: 'text', lineHeight: 1.3 });
const cardDesc = css({ color: 'textMuted', fontSize: '0.82rem', lineHeight: 1.45, mt: '0.3rem' });
---

<BaseLayout
  title="DFIR"
  description="Every DFIR reference and tool on this site, organized by what you're trying to do — from browsing the catalog to parsing a raw binary artifact."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'DFIR' }]}
    eyebrow="Reference & Tools"
    title="DFIR"
    description="Everything for digital forensics & incident response work, in one place — reference material, the MITRE framework maps, and the browser-based tools below, organized by what you're trying to do."
  />

  <GroupOverview items={groupTiles} heading="Browse by category" />

  {
    DFIR_GROUPS.map((g) => (
      <section id={g.id} class={sectionWrap}>
        <h2 class={sectionHead}>
          <Icon name={g.links[0].icon} size={20} class={css({ color: 'primary', flexShrink: 0 })} />
          <span>{g.category}</span>
          <span class={sectionCount}>{g.links.length}</span>
        </h2>
        <p class={sectionBlurb}>{g.blurb}</p>
        <div class={`card-grid ${cardsGrid}`}>
          {g.links.map((link) => (
            <a href={link.href} class={linkCard}>
              <span class={cardHead}>
                <Icon name={link.icon} size={16} class={css({ color: 'primary', flexShrink: 0 })} />
                <span class={cardTitle}>{link.label}</span>
              </span>
              <p class={cardDesc}>{link.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>
