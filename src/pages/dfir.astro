---
// DFIR landing page — the single "browse everything" destination for the 6
// DFIR_GROUPS categories (17 links total: reference material, the two MITRE
// framework maps, and 11 interactive tools split by workflow shape). Nav's
// "DFIR" dropdown, the footer's compact DFIR column, and ToolSidebar's rail
// all point subsets of this same data at their own surfaces; this page is
// the one place all of it is shown at once, with a one-line description per
// destination instead of just a label.
// Deliberately NOT collapsible <details> like tools.astro/event-ids.astro —
// those hide 50+ same-shaped filterable instances; this page has 17 items
// across 6 groups, small enough that hiding any of it behind a click would
// defeat the point of a landing/overview page whose whole job is to show
// everything at a glance.
export const prerender = true;
import { css } from 'styled-system/css';
import { card } from 'styled-system/recipes';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import GroupOverview from '../components/GroupOverview.astro';
import Icon from '../components/Icon.astro';
import { DFIR_GROUPS } from '../consts';

// "Browse by category" jump-strip — one tile per DFIR_GROUPS category,
// representative icon = that category's first link (icon uniqueness across
// DFIR_GROUPS is already enforced in consts.ts, so any member icon reads
// cleanly here too).
const groupTiles = DFIR_GROUPS.map((g) => ({
  id: g.id,
  icon: g.links[0].icon,
  title: g.category,
  blurb: g.blurb,
  count: g.links.length,
}));

// Live stats line — same role="status" aria-live="polite" pattern as
// tools.astro/glossary/index.astro/event-ids.astro's result-count lines.
// Nothing here is filtered client-side (this page has no search/facet
// controls), so the numbers are fixed at build time rather than updated by
// ListFilter — but the convention (and the accessibility semantics) still
// apply: it's the page's own summary of what's below it.
const allLinks = DFIR_GROUPS.flatMap((g) => g.links);
const totalLinks = allLinks.length;

// "Start here" spotlight — a small, curated subset of allLinks (not new
// data) covering four distinct first-visit use cases: browse the toolkit,
// look up a term, extract indicators from something in hand, or check
// technique coverage. Mirrors tools.astro's "core kit" spotlight chip row.
const START_HERE_HREFS = ['/tools/', '/glossary/', '/tools/ioc-extractor/', '/attack-map/'] as const;
const startHereLinks = START_HERE_HREFS.map((href) => allLinks.find((l) => l.href === href)).filter(
  (l): l is NonNullable<typeof l> => Boolean(l)
);
const spotlightWrap = css({ mb: '2rem' });
const spotlightLabel = css({
  display: 'block',
  fontFamily: 'sans',
  fontSize: '0.75rem',
  fontWeight: 700,
  textTransform: 'uppercase',
  letterSpacing: '0.1em',
  color: 'textMuted',
  mb: '0.7rem',
});
const spotlightRow = css({ display: 'flex', flexWrap: 'wrap', gap: '0.45rem' });
const spotlightChip = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.3rem',
  px: '0.6rem',
  py: '0.35rem',
  fontFamily: 'sans',
  fontSize: '0.8rem',
  fontWeight: 600,
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'full',
  transition: 'border-color 200ms ease, color 200ms ease',
  _hover: { borderColor: 'accent', color: 'accent', '& svg': { transform: 'translateX(2px)' } },
});

const sectionWrap = css({ borderTop: '1px solid token(colors.border)', py: '1.25rem', scrollMarginTop: '90px' });
const sectionHead = css({ display: 'flex', alignItems: 'center', gap: '0.6rem', flexWrap: 'wrap', m: 0, fontSize: '1.25rem', fontWeight: 700 });
const sectionCount = css({
  fontFamily: 'sans',
  fontSize: '0.68rem',
  fontWeight: 600,
  color: 'textMuted',
  bg: 'bgSubtle',
  border: '1px solid token(colors.border)',
  borderRadius: 'full',
  px: '0.5rem',
  py: '0.1rem',
});
const sectionBlurb = css({ color: 'textMuted', fontSize: '0.85rem', mt: '0.5rem', mb: 0 });
const cardsGrid = css({ mt: '1rem' }); // columns/gap come from the shared .card-grid class
// card()'s own recipe already sets _hover.borderColor/_hover.transform — this
// appended css() only adds a non-overlapping property, per the CSS-composition
// rule (docs/STYLE_GUIDE.md "Buttons"), matching tools.astro's toolCard.
const linkCard = `${card()} ${css({ _hover: { boxShadow: 'card' } })}`;
const cardHead = css({ display: 'flex', alignItems: 'center', gap: '0.5rem' });
const cardTitle = css({ fontFamily: 'sans', fontWeight: 700, fontSize: '0.9rem', color: 'text', lineHeight: 1.3 });
// link.description ranges 32-65 chars. totd-clamp2 caps growth at 2 lines; the fixed `h`
// reserves that same 2-line box for every card so a short description doesn't get
// stretched into a dead gap by a longer .card-grid row-mate — see certifications.astro's
// certFull for the full mechanics.
const cardDesc = css({ color: 'textMuted', fontSize: '0.82rem', lineHeight: 1.45, mt: '0.3rem', h: '2.4rem' });
---

<BaseLayout
  title="DFIR"
  description="A DFIR reference and tools hub — the tool catalog, command cheat sheet, glossary, MITRE ATT&CK/D3FEND maps, and browser-based forensics tools, all in one place."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'DFIR' }]}
    eyebrow="Reference & Tools"
    title="DFIR"
    description="Everything for digital forensics & incident response work, organized by what you're trying to do — reference material if you need to look something up, the MITRE framework maps if you're mapping technique to defense, or the browser-based tools below if you're extracting, converting, or parsing something you already have in hand."
  />

  <p role="status" aria-live="polite" class={css({ display: 'flex', flexWrap: 'wrap', alignItems: 'center', gap: '0.3rem 0.6rem', color: 'textMuted', fontSize: '0.9rem', mt: '-0.5rem', mb: '1.5rem' })}>
    <span>{totalLinks} destinations across {DFIR_GROUPS.length} categories</span>
  </p>

  {/* ── Start here spotlight — a curated first-visit path, one link per broad use case ── */}
  <div class={spotlightWrap}>
    <span class={spotlightLabel}>New here? Start with one of these</span>
    <div class={spotlightRow}>
      {
        startHereLinks.map((link) => (
          <a href={link.href} class={spotlightChip}>
            <Icon name={link.icon} size={13} class={css({ color: 'accent' })} />
            {link.label}
            <Icon name="arrow-right" size={12} class={css({ transition: 'transform 200ms ease' })} />
          </a>
        ))
      }
    </div>
  </div>

  <GroupOverview items={groupTiles} heading="Browse by category" />

  {
    DFIR_GROUPS.map((g) => (
      <section id={g.id} class={sectionWrap}>
        <h2 class={sectionHead}>
          <Icon name={g.links[0].icon} size={20} class={css({ color: 'primary', flexShrink: 0 })} />
          <span>{g.category}</span>
          <span class={sectionCount}>{g.links.length}</span>
        </h2>
        <p class={sectionBlurb}>{g.intro}</p>
        <div class={`card-grid ${cardsGrid}`}>
          {g.links.map((link) => (
            <a href={link.href} class={linkCard}>
              <span class={cardHead}>
                <Icon name={link.icon} size={16} class={css({ color: 'primary', flexShrink: 0 })} />
                <span class={cardTitle}>{link.label}</span>
              </span>
              <p class={`${cardDesc} totd-clamp2`}>{link.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>
