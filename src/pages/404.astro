---
// Custom 404 — branded, on-theme, with routes back into the site.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import PixelStar from '../components/PixelStar.astro';

const primaryBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.5rem',
  bg: 'primary',
  color: 'onPrimary',
  fontWeight: 600,
  px: '1.25rem',
  py: '0.7rem',
  borderRadius: 'md',
  transition: 'background 200ms ease, transform 200ms ease',
  _hover: { bg: 'primaryHover', transform: 'translateY(-1px)' },
});
const ghostBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.5rem',
  border: '1px solid token(colors.border)',
  color: 'text',
  fontWeight: 600,
  px: '1.25rem',
  py: '0.7rem',
  borderRadius: 'md',
  transition: 'border-color 200ms ease',
  _hover: { borderColor: 'primary' },
});
---

<BaseLayout title="404 — Not found" description="That page doesn't exist or has moved." robots="noindex, follow">
  <section
    class={css({
      textAlign: 'center',
      py: { base: '3rem', md: '5rem' },
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center',
      gap: '1rem',
    })}
  >
    <PixelStar size={84} />
    <p
      class={css({
        fontFamily: 'sans',
        fontWeight: 700,
        fontSize: { base: '4rem', md: '6rem' },
        lineHeight: 1,
        color: 'primary',
        letterSpacing: '-0.04em',
      })}
    >
      404
    </p>
    <h1 class={css({ fontSize: { base: '1.6rem', md: '2rem' }, fontWeight: 700 })}>
      No artifacts found at this path.
    </h1>
    <p class={css({ color: 'textMuted', maxW: '460px', lineHeight: 1.7 })}>
      The page you're after doesn't exist or has moved. Let's get you back to something real.
    </p>
    <div class={css({ display: 'flex', flexWrap: 'wrap', justifyContent: 'center', gap: '0.75rem', mt: '0.5rem' })}>
      <a href="/" class={primaryBtn}>Back home <Icon name="arrow-right" size={17} /></a>
      <a href="/blog/" class={ghostBtn}><Icon name="file-text" size={16} /> Read the blog</a>
    </div>
  </section>
</BaseLayout>
