---
// Certifications page — every credential, grouped by issuer (collapsible), with
// the same design language as the Tools page. Hidden from the header; linked from
// the footer's "More". Data is the single source of truth in data/certifications.ts.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import CollapseAll from '../components/CollapseAll.astro';
import TagCombobox from '../components/TagCombobox.astro';
import FilterToggle from '../components/FilterToggle.astro';
import ListFilter from '../components/ListFilter.astro';
import { tagSlug } from '../utils/posts';
import { tag, card } from 'styled-system/recipes';
import { SOCIALS } from '../consts';
import { CERT_ISSUERS, CERTIFICATIONS, EARNED_CERTS, PURSUING_CERTS } from '../data/certifications';

// Focus-area facet for the search combobox (each credential carries one focus tag).
const focusCounts: Record<string, number> = {};
for (const c of CERTIFICATIONS) focusCounts[c.focus] = (focusCounts[c.focus] ?? 0) + 1;
const focusOptions = Object.keys(focusCounts)
  .sort()
  .map((f) => ({ value: tagSlug(f), label: f, count: focusCounts[f] }));

// Each issuer is a collapsible <details>; the credential grid lives inside.
const groupDetails = css({ borderTop: '1px solid token(colors.border)', py: '1.25rem' });
const groupSummary = css({
  cursor: 'pointer',
  listStyle: 'none',
  userSelect: 'none',
  '&::-webkit-details-marker': { display: 'none' },
  '&::marker': { display: 'none' },
  _hover: { '& .cert-grp-title': { color: 'primary' } },
});
const groupHead = css({
  display: 'flex',
  alignItems: 'center',
  gap: '0.6rem',
  flexWrap: 'wrap',
  m: 0,
  fontSize: '1.25rem',
  fontWeight: 700,
});
const chevCls = css({
  color: 'textMuted',
  flexShrink: 0,
  transition: 'transform 200ms ease',
  'details[open] &': { transform: 'rotate(90deg)' },
});
const grpCount = css({
  fontFamily: 'sans',
  fontSize: '0.68rem',
  fontWeight: 600,
  color: 'textMuted',
  bg: 'bgSubtle',
  border: '1px solid token(colors.border)',
  borderRadius: 'full',
  px: '0.5rem',
  py: '0.1rem',
});
const grpBlurb = css({ color: 'textMuted', fontSize: '0.85rem', mt: '0.5rem', mb: 0 });
const certGrid = css({ mt: '1rem' }); // columns/gap come from the shared .card-grid class
// `transition` is a shorthand — a page-local override replaces the recipe's
// value entirely rather than merging, so this must restate the full list.
const certCard = `${card()} ${css({
  transition: 'border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease',
  _hover: { boxShadow: 'card' },
})}`;
const certHead = css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '0.5rem' });
const certName = css({ flex: 1, minW: 0, display: 'inline-flex', alignItems: 'center', gap: '0.4rem', fontWeight: 700, fontSize: '0.9rem', color: 'text', lineHeight: 1.3 });
const earnedIcon = css({ color: 'accent', flexShrink: 0 });
const pursuingIcon = css({ color: 'textMuted', flexShrink: 0 });
const extIcon = css({ color: 'textMuted', flexShrink: 0 });
const certFull = css({ color: 'textMuted', fontSize: '0.82rem', lineHeight: 1.45 });
// maxW/overflow/textOverflow: current `focus` values are all short, but this
// is the same ceiling event-ids.astro and tools.astro needed for their
// variable-length tags — no reason for this one to be the exception the next
// time a longer focus area gets added.
const focusTag = `${tag({ tone: 'muted' })} ${css({ alignSelf: 'flex-start', mt: 'auto', maxW: '100%', overflow: 'hidden', textOverflow: 'ellipsis' })}`;
const pursuingTag = `${tag({ tone: 'accent' })} ${css({ alignSelf: 'flex-start', mt: 'auto' })}`;
const metaLink = css({ display: 'inline-flex', alignItems: 'center', gap: '0.35rem', color: 'primary', fontWeight: 600, _hover: { textDecoration: 'underline' } });
---

<BaseLayout
  title="Certifications"
  description="Patrick Saade's security certifications — CISSP, the CompTIA stack, and the GIAC forensics track in pursuit — grouped by issuer, each verifiable on Credly."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Certifications' }]}
    eyebrow="Credentials"
    title="Certifications"
    description="Every credential I hold, plus the GIAC forensics track I'm working toward — grouped by issuer. Each earned badge links to Credly to verify."
  />

  {/* Search + focus filter (typeahead combobox) */}
  <div class={css({ mb: '0.75rem' })}>
    <TagCombobox
      id="cert-cb"
      options={focusOptions}
      placeholder={`Search ${CERTIFICATIONS.length} certifications, or type a focus area…`}
      label="Search certifications or filter by focus area"
    />
  </div>

  <div class={css({ display: 'flex', alignItems: 'center', gap: '1rem', flexWrap: 'wrap', mb: '0.75rem' })}>
    <p role="status" aria-live="polite" class={css({ color: 'textMuted', fontSize: '0.9rem', m: 0 })}>
      <span id="cert-result-count">{CERTIFICATIONS.length}</span> shown, of {EARNED_CERTS.length} earned
      and {PURSUING_CERTS.length} in pursuit ·{' '}
      <a href={SOCIALS.credly} target="_blank" rel="noopener" class={metaLink}>
        verify on Credly <Icon name="external-link" size={13} />
      </a>
    </p>
    <div class={css({ display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: '0.5rem', ml: { sm: 'auto' } })}>
      <FilterToggle id="cert-earned-toggle" icon="award" label="Earned only" tone="accent" />
      <CollapseAll target="[data-cert-group]" />
    </div>
  </div>

  <div class={css({ display: 'flex', flexDirection: 'column' })}>
    {
      CERT_ISSUERS.map((issuer) => {
        const certs = CERTIFICATIONS.filter((c) => c.issuer === issuer.name);
        if (certs.length === 0) return null;
        return (
          <details data-cert-group open class={groupDetails}>
            <summary class={groupSummary}>
              <h2 class={groupHead}>
                <Icon name="chevron-right" size={18} class={chevCls} />
                <Icon name={issuer.icon} size={20} class={css({ color: 'primary', flexShrink: 0 })} />
                <span class="cert-grp-title">{issuer.name}</span>
                <span class={grpCount}>{certs.length}</span>
              </h2>
            </summary>
            <p class={grpBlurb}>{issuer.blurb}</p>
            <div class={`card-grid ${certGrid}`}>
              {certs.map((c) => (
                <a
                  href={c.url}
                  target="_blank"
                  rel="noopener"
                  class={certCard}
                  data-focus={tagSlug(c.focus)}
                  data-cert-card={`${c.name} ${c.full} ${c.focus} ${c.issuer}`.toLowerCase()}
                  {...(c.earned ? { 'data-earned': true } : {})}
                >
                  <span class={certHead}>
                    <span class={certName}>
                      <Icon
                        name={c.earned ? 'award' : 'clock'}
                        size={14}
                        class={c.earned ? earnedIcon : pursuingIcon}
                        label={c.earned ? 'Earned' : 'In pursuit of'}
                      />
                      {c.name}
                    </span>
                    <Icon name="external-link" size={14} class={extIcon} />
                  </span>
                  <span class={certFull}>{c.full}</span>
                  {c.earned ? <span class={focusTag} title={c.focus}>{c.focus}</span> : <span class={pursuingTag}>In pursuit of</span>}
                </a>
              ))}
            </div>
          </details>
        );
      })
    }
  </div>

  <p id="cert-empty" hidden role="status" aria-live="polite" class={css({ color: 'textMuted', textAlign: 'center', py: '3rem' })}>
    No certifications match.
  </p>

  <ListFilter
    config={{
      comboboxId: 'cert-cb',
      cardSelector: '[data-cert-card]',
      searchAttr: 'data-cert-card',
      groupSelector: '[data-cert-group]',
      countId: 'cert-result-count',
      emptyId: 'cert-empty',
      facetAttr: 'data-focus',
      toggles: [{ id: 'cert-earned-toggle', attr: 'data-earned' }],
    }}
  />
</BaseLayout>
