---
// Blog listing — a faceted, client-side search. The TagCombobox is a typeahead
// multi-select: type to find a tag (e.g. "car" → "career"), click/Enter to add it
// as a removable token. Its text also free-text-filters posts. Tags filter with
// AND (a post must carry every selected tag). Category chips are a second facet.
// State syncs to the URL (?q / ?tag / ?cat) so any view is shareable — this folds
// in the old /tags/ pages. All driven by the shared <ListFilter> controller (same
// one Glossary/Tools/Certifications/both MITRE maps use) via facetMode:'and' +
// chipGroup + urlSync, so this page carries no bespoke filter script of its own.
// Static page — prerendered to the CDN.
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import BlogCard from '../../components/BlogCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import ListFilter from '../../components/ListFilter.astro';
import { getSortedPosts, getTags, tagSlug, estimateReadTime } from '../../utils/posts';
import { categoryIcon } from '../../consts';

const posts = await getSortedPosts();
const categories = [...new Set(posts.map((p) => p.data.category))];
const tagOptions = (await getTags()).map((t) => ({ value: t.slug, label: t.tag, count: t.count }));
const categoryChips = categories.map((c) => ({ value: c, label: c, icon: categoryIcon(c) }));

const countLine = css({ fontSize: '0.85rem', color: 'textMuted', mb: '1.25rem' });
---

<BaseLayout title="Blog" description="DFIR deep dives: memory forensics, host artifacts, EDR analysis, timeline reconstruction. Search by keyword, category, or tag.">
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Blog' }]}
    eyebrow="Blog"
    title="DFIR deep dives"
    description="Memory forensics, host & EDR artifact analysis, timeline reconstruction, and the tooling that ties it together."
  />

  {posts.length > 0 && (
    <FilterBar
      comboboxId="blog-tags"
      comboboxOptions={tagOptions}
      comboboxPlaceholder="Search posts, or type a tag like “car”…"
      comboboxLabel="Filter posts by tag"
      helperNoun="posts"
      chipRowLabel="Category"
      chipAllLabel="All"
      chips={categoryChips}
      clearButtonId="blog-clear"
    />
  )}

  {
    posts.length > 0 ? (
      <>
        <p role="status" aria-live="polite" class={countLine}>
          <span id="post-count">{posts.length}</span> <span id="post-count-word">{posts.length === 1 ? 'post' : 'posts'}</span>
        </p>
        <div
          id="post-grid"
          class={css({ display: 'grid', gridTemplateColumns: { base: '1fr', md: 'repeat(2, 1fr)' }, gap: '1.25rem' })}
        >
          {posts.map((p) => (
            <div
              class="post-item"
              data-category={p.data.category}
              data-tags={`|${p.data.tags.map(tagSlug).join('|')}|`}
              data-search={`${p.data.title} ${p.data.excerpt} ${p.data.tags.join(' ')} ${p.data.tools.join(' ')} ${p.data.category}`.toLowerCase()}
            >
              <BlogCard
                href={`/blog/${p.id}/`}
                title={p.data.title}
                excerpt={p.data.excerpt}
                category={p.data.category}
                date={p.data.date}
                readTime={estimateReadTime(p.body, p.data.readTime)}
                difficulty={p.data.difficulty}
                tags={p.data.tags}
                featured={p.data.featured}
              />
            </div>
          ))}
        </div>
      </>
    ) : (
      <p class={css({ color: 'textMuted' })}>No posts yet — check back soon.</p>
    )
  }

  <p id="no-results" hidden role="status" aria-live="polite" class={css({ color: 'textMuted', textAlign: 'center', py: '2rem' })}>
    No posts match your filters.
  </p>

  <ListFilter
    config={{
      comboboxId: 'blog-tags',
      cardSelector: '.post-item',
      searchAttr: 'data-search',
      countId: 'post-count',
      countWordId: 'post-count-word',
      countWordSingular: 'post',
      countWordPlural: 'posts',
      emptyId: 'no-results',
      facetAttr: 'data-tags',
      facetMode: 'and',
      chipGroup: { selector: '[data-filter]', attr: 'data-category' },
      clearButtonId: 'blog-clear',
      urlSync: { queryParam: 'q', facetParam: 'tag', chipParam: 'cat' },
    }}
  />
</BaseLayout>
