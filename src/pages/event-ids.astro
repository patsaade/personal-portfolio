---
// Windows Event ID / Sysmon Reference — a comprehensive, fully-cited lookup
// for the Windows Security auditing log + Sysinternals Sysmon operational
// log event IDs that actually matter for DFIR (src/data/eventIds.ts). Same
// "grouped, searchable list" shape as the Tool Catalog: two collapsible
// groups (Windows Security Log, Sysmon), search across id/name/category,
// and a quick toggle for entries with a documented MITRE ATT&CK mapping.
// Each card links to its own detail page (/event-ids/[slug]/).
// Static page — prerender to HTML served from the CDN.
export const prerender = true;
import { css } from 'styled-system/css';
import { tag, card } from 'styled-system/recipes';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import CollapseAll from '../components/CollapseAll.astro';
import TagCombobox from '../components/TagCombobox.astro';
import FilterToggle from '../components/FilterToggle.astro';
import ListFilter from '../components/ListFilter.astro';
import GroupOverview from '../components/GroupOverview.astro';
import { getSortedPosts, getSortedLabs } from '../utils/posts';
import { EVENT_IDS, type EventIdEntry } from '../data/eventIds';

const GROUPS = [
  { id: 'security', title: 'Windows Security Log', icon: 'shield' as const, blurb: 'Auditing events written to the Security event log — logons, account/group management, process and object access, privilege use, and policy changes.' },
  { id: 'sysmon', title: 'Sysmon', icon: 'activity' as const, blurb: 'Sysinternals Sysmon’s own operational log — deeper, opt-in telemetry (process creation with full command lines, network connections, image/driver loads, process injection, and more) once installed and configured.' },
];
const bySource = (id: string) => EVENT_IDS.filter((e) => e.source === id).sort((a, b) => Number(a.id) - Number(b.id));
const totalCount = EVENT_IDS.length;
const attackMappedCount = EVENT_IDS.filter((e) => e.attackTechniques.length > 0).length;

// TODO(human): "Critical events" spotlight, mirroring Tools' "In my day-to-day
// kit" chip row (spotlightRow) and Glossary's "Today's term" callout — a slim,
// curated shortlist of the ~10-15 highest-signal event IDs out of ~190, out of
// scope here because it's an editorial judgment call (which entries are the
// DFIR "greatest hits"), not a mechanical derive from existing data the way
// the sub-grouping below is. A well-grounded starting candidate list, verified
// to actually exist in src/data/eventIds.ts as of this writing (each backed by
// its own `what`/`why` already in the dataset — a human should still sanity-check
// the final cut, not rubber-stamp it):
//   Security: 4624 (successful logon), 4625 (failed logon), 4688 (process
//     creation), 4698 (scheduled task created), 1102 (audit log cleared)
//   Sysmon:   1 (process creation), 3 (network connection), 11 (file create),
//     22 (DNS query)
// These lean toward "an attacker did something" pivot points analysts search
// for first — but the actual selection, and whether it warrants its own
// spotlight section vs. e.g. a "critical" data flag feeding a FilterToggle,
// is a call for a human to make.

// Events referenced by a writeup via frontmatter `eventIds: ['security-4624', …]`
// (for the "In a writeup" filter). Populated once a human confirms which
// writeups actually discuss which specific event IDs — see content.config.ts.
const [ePosts, eLabs] = await Promise.all([getSortedPosts(), getSortedLabs()]);
const featuredEventIds = new Set(
  [...ePosts, ...eLabs].flatMap((p) => (p.data.eventIds ?? []).map((s) => s.toLowerCase())),
);

// "Browse by log" overview tiles, mirroring the Tools/Glossary jump-to strip.
const groupTiles = GROUPS.map((g) => ({ id: `evt-${g.id}`, icon: g.icon, title: g.title, blurb: g.blurb, count: bySource(g.id).length }));

// Category facet for the search combobox — pooled across both logs.
const catCounts: Record<string, number> = {};
for (const e of EVENT_IDS) catCounts[e.category] = (catCounts[e.category] ?? 0) + 1;
const catSlug = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
const catOptions = Object.keys(catCounts).sort().map((c) => ({ value: catSlug(c), label: c, count: catCounts[c] }));

// Sub-group a source's entries by their own `category` field (already used for
// the search facet above) — a mechanical rendering change, same taxonomy, just
// surfaced as nested collapsible groups instead of one flat grid per log.
const byCategory = (items: EventIdEntry[]): [string, EventIdEntry[]][] => {
  const map = new Map<string, EventIdEntry[]>();
  for (const e of items) {
    if (!map.has(e.category)) map.set(e.category, []);
    map.get(e.category)!.push(e);
  }
  return [...map.entries()].sort((a, b) => a[0].localeCompare(b[0]));
};

const groupDetails = css({ borderTop: '1px solid token(colors.border)', py: '1.25rem', scrollMarginTop: '90px' });
const groupSummary = css({
  cursor: 'pointer',
  listStyle: 'none',
  userSelect: 'none',
  '&::-webkit-details-marker': { display: 'none' },
  '&::marker': { display: 'none' },
  _hover: { '& .evt-grp-title': { color: 'primary' } },
});
const groupHead = css({ display: 'flex', alignItems: 'center', gap: '0.6rem', flexWrap: 'wrap', m: 0, fontSize: '1.25rem', fontWeight: 700 });
const chevCls = css({
  color: 'textMuted',
  flexShrink: 0,
  transition: 'transform 200ms ease',
  // Scoped to *this* chevron's own <details>/<summary> pair (a child
  // combinator between details and summary, then a descendant match for the
  // chevron) rather than "any details ancestor is open" — required once the
  // category sub-groups below nest a second <details> inside each
  // always-open source-level one: a plain 'details[open] &' descendant
  // selector would also fire off the outer group and permanently rotate the
  // inner chevron regardless of its own open/closed state.
  'details[open] > summary &': { transform: 'rotate(90deg)' },
});
const grpCount = css({
  fontFamily: 'sans',
  fontSize: '0.68rem',
  fontWeight: 600,
  color: 'textMuted',
  bg: 'bgSubtle',
  border: '1px solid token(colors.border)',
  borderRadius: 'full',
  px: '0.5rem',
  py: '0.1rem',
});
const grpBlurb = css({ color: 'textMuted', fontSize: '0.85rem', mt: '0.5rem', mb: 0 });
// Category sub-groups nested inside each source-level group — same collapsible
// pattern, one size down (smaller heading, no top border/py on the first one,
// a hairline divider between siblings instead) so the hierarchy reads as
// "this log, broken into its categories" rather than two visually equal tiers.
const subGroupWrap = css({ mt: '1rem', display: 'flex', flexDirection: 'column' });
const subGroupDetails = css({ '& + &': { borderTop: '1px solid token(colors.border)', mt: '1rem', pt: '1rem' } });
const subGroupSummary = css({
  cursor: 'pointer',
  listStyle: 'none',
  userSelect: 'none',
  '&::-webkit-details-marker': { display: 'none' },
  '&::marker': { display: 'none' },
  _hover: { '& .evt-subgrp-title': { color: 'primary' } },
});
const subGroupHead = css({ display: 'flex', alignItems: 'center', gap: '0.5rem', flexWrap: 'wrap', m: 0, fontSize: '0.95rem', fontWeight: 700, color: 'textMuted' });
const evtGrid = css({ mt: '1rem' });
const evtCard = `${card()} ${css({
  transition: 'border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease',
  _hover: { boxShadow: 'card', '& .evt-go': { transform: 'translateX(2px)', color: 'primary' } },
})}`;
const evtHead = css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '0.5rem' });
const evtIdBadge = css({ fontFamily: 'mono', fontWeight: 700, fontSize: '0.95rem', color: 'primary', flexShrink: 0 });
const evtName = css({ flex: 1, minW: 0, fontFamily: 'sans', fontWeight: 700, fontSize: '0.88rem', color: 'text', lineHeight: 1.3 });
const goCls = css({ color: 'textMuted', flexShrink: 0, transition: 'transform 200ms ease, color 200ms ease' });
// flexWrap MUST stay 'nowrap' here (do not change back to 'wrap'): this row
// can hold two chips — categoryTag (variable-length) and the ATT&CK badge
// (fixed-width) — and with wrap enabled, the wrap algorithm decides line
// breaks using each item's un-shrunk hypothetical width, so a long category
// pushed the ATT&CK badge onto a second line *before* categoryTag's own
// truncation got a chance to make room for it. That grew the card taller
// than its card-grid neighbors — the truncation fix alone wasn't enough;
// this is what actually re-broke it. With nowrap, categoryTag (flexShrink:1)
// absorbs 100% of the shrinking and the ATT&CK badge (flexShrink:0) never
// moves, so the row always fits on one line, full stop.
const tagRow = css({ display: 'flex', flexWrap: 'nowrap', gap: '0.3rem', mt: 'auto', pt: '0.15rem', minW: 0 });
// The category is often a longer descriptive grouping (not a short taxonomy
// label like other tag() usages), so it's truncated with an ellipsis on one
// line — not wrapped — so it can never grow this card taller than its
// neighbors in the same .card-grid row (see STYLE_GUIDE.md's card-size rule:
// a CSS grid row stretches every cell to match its tallest one, so a card
// that grows from wrapped content drags the whole row's white space with
// it). The full value is still available via the native tooltip and on the
// entry's own detail page, so nothing is actually lost, just not previewed
// in full on the card.
const categoryTag = `${tag({ tone: 'muted' })} ${css({ minW: 0, flexShrink: 1, maxW: '100%', overflow: 'hidden', textOverflow: 'ellipsis' })}`;
// Fixed-width sibling in the same nowrap row — flexShrink: 0 so categoryTag
// (not this) absorbs all the squeezing; see tagRow's comment.
const attackBadge = `${tag({ tone: 'accent' })} ${css({ flexShrink: 0 })}`;

const filterRow = css({ display: 'flex', alignItems: 'center', gap: '1rem', flexWrap: 'wrap', mb: '0.75rem' });
---

<BaseLayout
  title="Windows Event ID / Sysmon Reference"
  description="A comprehensive, fully-cited reference for Windows Security auditing log and Sysmon event IDs that matter for DFIR — what each records, why it matters, common triggers, and MITRE ATT&CK cross-links."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Event ID Reference' }]}
    eyebrow="Reference"
    title="Windows Event ID / Sysmon Reference"
    description={`${totalCount} Windows Security auditing + Sysmon event IDs, each with what it records, why it matters for DFIR, common triggers, and MITRE ATT&CK cross-links where a mapping is well-established.`}
  />

  {/* ── Browse by log (jump-to overview strip) ── */}
  <GroupOverview items={groupTiles} heading="Browse by log" />

  <div class={css({ mb: '0.6rem' })}>
    <TagCombobox
      id="evt-cb"
      options={catOptions}
      placeholder={`Search ${totalCount} event IDs, or type a category…`}
      label="Search event IDs or filter by category"
    />
  </div>

  <div class={filterRow}>
    <p role="status" aria-live="polite" class={css({ display: 'flex', flexWrap: 'wrap', alignItems: 'center', gap: '0.3rem 0.6rem', color: 'textMuted', fontSize: '0.9rem', m: 0 })}>
      <span><span id="evt-result-count">{totalCount}</span> event IDs across {GROUPS.length} logs</span>
      <span aria-hidden="true">·</span>
      <span>{attackMappedCount} mapped to ATT&amp;CK</span>
      <span aria-hidden="true">·</span>
      <span>{featuredEventIds.size} in a writeup</span>
    </p>
    <div class={css({ display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: '0.5rem', ml: { sm: 'auto' } })}>
      <FilterToggle id="evt-attack-toggle" icon="target" label="Maps to ATT&CK" tone="primary" />
      <FilterToggle id="evt-writeup-toggle" icon="file-text" label="In a writeup" tone="accent" />
      <CollapseAll target="[data-evt-group]" />
    </div>
  </div>

  <div class={css({ display: 'flex', flexDirection: 'column' })}>
    {
      GROUPS.map((g) => {
        const items = bySource(g.id);
        const catGroups = byCategory(items);
        return (
          <details id={`evt-${g.id}`} data-evt-group open class={groupDetails}>
            <summary class={groupSummary}>
              <h2 class={groupHead}>
                <Icon name="chevron-right" size={18} class={chevCls} />
                <Icon name={g.icon} size={20} class={css({ color: 'primary', flexShrink: 0 })} />
                <span class="evt-grp-title">{g.title}</span>
                <span class={grpCount}>{items.length}</span>
              </h2>
            </summary>
            <p class={grpBlurb}>{g.blurb}</p>
            <div class={subGroupWrap}>
              {catGroups.map(([cat, entries]) => (
                <details id={`evt-${g.id}-${catSlug(cat)}`} data-evt-group open class={subGroupDetails}>
                  <summary class={subGroupSummary}>
                    <h3 class={subGroupHead}>
                      <Icon name="chevron-right" size={15} class={chevCls} />
                      <span class="evt-subgrp-title">{cat}</span>
                      <span class={grpCount}>{entries.length}</span>
                    </h3>
                  </summary>
                  <div class={`card-grid ${evtGrid}`}>
                    {entries.map((e) => (
                      <a
                        href={`/event-ids/${e.slug}/`}
                        class={evtCard}
                        data-evt-card={`${e.id} ${e.name} ${e.category} ${e.channel}`.toLowerCase()}
                        data-cat={catSlug(e.category)}
                        {...(e.attackTechniques.length > 0 ? { 'data-attack-mapped': true } : {})}
                        {...(featuredEventIds.has(e.slug) ? { 'data-in-writeup': true } : {})}
                      >
                        <span class={evtHead}>
                          <span class={evtIdBadge}>{e.id}</span>
                          <Icon name="arrow-right" size={14} class={`evt-go ${goCls}`} />
                        </span>
                        <span class={evtName}>{e.name}</span>
                        <span class={tagRow}>
                          <span class={categoryTag} title={e.category}>{e.category}</span>
                          {e.attackTechniques.length > 0 && <span class={attackBadge}>ATT&amp;CK</span>}
                        </span>
                      </a>
                    ))}
                  </div>
                </details>
              ))}
            </div>
          </details>
        );
      })
    }
  </div>

  <p id="evt-empty" hidden role="status" aria-live="polite" class={css({ color: 'textMuted', textAlign: 'center', py: '3rem' })}>
    No event IDs match your search.
  </p>

  <ListFilter
    config={{
      comboboxId: 'evt-cb',
      cardSelector: '[data-evt-card]',
      searchAttr: 'data-evt-card',
      groupSelector: '[data-evt-group]',
      countId: 'evt-result-count',
      emptyId: 'evt-empty',
      facetAttr: 'data-cat',
      toggles: [
        { id: 'evt-attack-toggle', attr: 'data-attack-mapped' },
        { id: 'evt-writeup-toggle', attr: 'data-in-writeup' },
      ],
      urlSync: { queryParam: 'q', facetParam: 'category' },
    }}
  />
</BaseLayout>
