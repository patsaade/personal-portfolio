---
// Per-tag page — lists every blog post carrying a given tag.
import { css } from 'styled-system/css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import BlogCard from '../../components/BlogCard.astro';
import Icon from '../../components/Icon.astro';
import { getSortedPosts, estimateReadTime, tagSlug } from '../../utils/posts';

// Prerender to static HTML (required: getStaticPaths is ignored under output: 'server').
export const prerender = true;

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  const byTag = new Map<string, { tag: string; posts: typeof posts }>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      const slug = tagSlug(tag);
      if (!byTag.has(slug)) byTag.set(slug, { tag, posts: [] });
      byTag.get(slug)!.posts.push(post);
    }
  }
  return [...byTag.entries()].map(([slug, { tag, posts: tagged }]) => ({
    params: { tag: slug },
    props: { tag, posts: tagged },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Posts tagged ${tag}.`}>
  <p class={css({ mb: '1rem' })}>
    <a
      href="/tags/"
      class={css({ display: 'inline-flex', alignItems: 'center', gap: '0.3rem', fontSize: '0.85rem', color: 'textMuted', _hover: { color: 'primary' } })}
    >
      <Icon name="arrow-left" size={14} /> All topics
    </a>
  </p>

  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Tags', href: '/tags/' }, { label: `#${tag}` }]}
    eyebrow="Tag"
    title={tag}
    description={`${posts.length} ${posts.length === 1 ? 'post' : 'posts'} tagged “${tag}”.`}
  />

  <div
    class={css({
      display: 'grid',
      gridTemplateColumns: { base: '1fr', md: 'repeat(2, 1fr)' },
      gap: '1.25rem',
    })}
  >
    {
      posts.map((p) => (
        <BlogCard
          href={`/blog/${p.id}/`}
          title={p.data.title}
          excerpt={p.data.excerpt}
          category={p.data.category}
          date={p.data.date}
          readTime={estimateReadTime(p.body, p.data.readTime)}
          difficulty={p.data.difficulty}
          tags={p.data.tags}
          featured={p.data.featured}
        />
      ))
    }
  </div>
</BaseLayout>
