---
// Tags index — browse all blog topics, each linking to its tag page.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Icon from '../../components/Icon.astro';
import { getTags } from '../../utils/posts';

const tags = await getTags();

const chip = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.4rem',
  fontFamily: 'sans',
  fontSize: '0.85rem',
  px: '0.85rem',
  py: '0.5rem',
  borderRadius: 'md',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  color: 'text',
  transition: 'all 200ms ease',
  _hover: { borderColor: 'primary', color: 'primary', transform: 'translateY(-2px)' },
});
---

<BaseLayout title="Tags" description="Browse posts by topic — memory forensics, host artifacts, EDR, tooling, and more.">
  <PageHeader breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Tags' }]} eyebrow="Browse" title="Topics" description="Every tag across the blog. Pick one to see related posts." />

  {
    tags.length > 0 ? (
      <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.6rem' })}>
        {tags.map((t) => (
          <a href={`/tags/${t.slug}/`} class={chip}>
            <Icon name="tag" size={14} />
            {t.tag}
            <span class={css({ color: 'textMuted' })}>{t.count}</span>
          </a>
        ))}
      </div>
    ) : (
      <p class={css({ color: 'textMuted' })}>No tags yet — check back as posts publish.</p>
    )
  }
</BaseLayout>
