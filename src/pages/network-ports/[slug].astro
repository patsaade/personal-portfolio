---
// Network Port Reference detail — one prerendered page per port
// (src/data/networkPorts.ts), same shape as the Windows Event ID / Sysmon
// detail page: what it's used for, why it matters for DFIR, common
// triggers, indicators to check, related ports (cross-linked within this
// same dataset), MITRE ATT&CK cross-links (on-site where the technique
// exists locally, else straight to attack.mitre.org), and the authoritative
// references each entry was fact-checked against.
export const prerender = true;
import { css } from 'styled-system/css';
import { tag } from 'styled-system/recipes';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import EntryNav from '../../components/EntryNav.astro';
import { NETWORK_PORTS, networkPortBySlug } from '../../data/networkPorts';
import type { NetworkPortEntry, PortConfidence } from '../../data/networkPorts';
import { resolveAttackLink } from '../../data/references';
import { SITE } from '../../consts';

export async function getStaticPaths() {
  const entryPaths = NETWORK_PORTS.map((e) => ({
    params: { slug: e.slug },
    props: { kind: 'entry' as const, entry: e, matches: null },
  }));

  // Bare-numeric direct-query redirects — /network-ports/443/ resolves
  // straight to /network-ports/tcp-443/ — mirrors event-ids/[slug].astro's
  // own bare-event-ID redirect, since a port pasted from a log or ticket
  // usually carries no protocol context either. Real slugs are always
  // `{protocol}-{port}` or, for a genuinely dual-protocol service,
  // `port-{port}`, so a bare numeric id can never collide with one. If a
  // future addition ever gave the same port number two DIFFERENT entries
  // (e.g. an unrelated TCP-only and UDP-only service sharing a number),
  // this renders a disambiguation list instead of silently guessing.
  const byPort = new Map<number, NetworkPortEntry[]>();
  for (const e of NETWORK_PORTS) {
    const list = byPort.get(e.port) ?? [];
    list.push(e);
    byPort.set(e.port, list);
  }
  const redirectPaths = [...byPort.entries()].map(([port, matches]) => ({
    params: { slug: String(port) },
    props: { kind: 'redirect' as const, entry: null, matches },
  }));

  return [...entryPaths, ...redirectPaths];
}

const props = Astro.props;
const entry = props.kind === 'entry' ? props.entry : null;
const matches = props.kind === 'redirect' ? props.matches : null;
const dest = matches && matches.length === 1 ? `/network-ports/${matches[0].slug}/` : null;

const idx = entry ? NETWORK_PORTS.findIndex((e) => e.slug === entry.slug) : -1;
const prev = idx > 0 ? NETWORK_PORTS[idx - 1] : null;
const next = entry && idx >= 0 && idx < NETWORK_PORTS.length - 1 ? NETWORK_PORTS[idx + 1] : null;

// Related ports are full slugs (unlike event-ids' bare-number-scoped-to-
// source scheme) — ports don't have the same source-collision ambiguity, so
// resolving directly against this dataset is simpler and just as safe; one
// that doesn't resolve renders as plain, unlinked text.
const related = entry ? entry.relatedPorts.map((slug) => ({ slug, entry: networkPortBySlug(slug) })) : [];

// MITRE ATT&CK cross-links — on-site where the technique is in our own
// dataset, otherwise straight to the authoritative MITRE page (same
// resolve-or-fall-back-external pattern as event-ids/[slug].astro).
const attackLinks = entry ? entry.attackTechniques.map(resolveAttackLink) : [];

const CONFIDENCE_LABEL: Record<PortConfidence, string> = {
  'iana-registered': 'IANA-registered',
  'de-facto-standard': 'De facto standard',
  'historical-documented': 'Historical / documented',
};
const CONFIDENCE_TONE: Record<PortConfidence, 'primary' | 'accent' | 'muted'> = {
  'iana-registered': 'primary',
  'de-facto-standard': 'accent',
  'historical-documented': 'muted',
};
const CONFIDENCE_EXPLAINER: Record<PortConfidence, string> = {
  'iana-registered': "IANA's own Service Name and Transport Protocol Port Number Registry assigns this port to this exact service.",
  'de-facto-standard': "Overwhelmingly used this way in practice, but IANA's registry actually assigns this port to an unrelated service, or nothing at all — see \"What it is\" above for the specific gap.",
  'historical-documented': 'No registration authority applies here — this mapping rests entirely on historical, vendor, or threat-intel documentation, not a protocol spec. Treat it as a pivot point worth investigating, never a confirmed finding on its own.',
};

const RANGE_LABEL: Record<string, string> = {
  'well-known': 'Well-Known (0–1023)',
  registered: 'Registered (1024–49151)',
  dynamic: 'Dynamic / Ephemeral (49152–65535)',
};

// Same DefinedTerm shape as the Event ID / Glossary detail pages.
const jsonLd = entry
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'DefinedTerm',
      name: `Port ${entry.port}/${entry.protocol} — ${entry.name}`,
      termCode: String(entry.port),
      description: entry.what,
      inDefinedTermSet: `${SITE.url}/network-ports/`,
      url: `${SITE.url}/network-ports/${entry.slug}/`,
      ...(entry.references.length ? { sameAs: entry.references.map((r) => r.url) } : {}),
    }).replace(/</g, '\\u003c') // escape `<` so it can't break out of the <script> tag
  : null;

const sectionH2 = css({ display: 'flex', alignItems: 'center', gap: '0.5rem', fontSize: '1.2rem', fontWeight: 700, mt: '2.5rem', mb: '0.75rem' });
const para = css({ color: 'text', lineHeight: 1.8, fontSize: '1.02rem' });
const refLink = css({
  display: 'inline-flex', alignItems: 'center', gap: '0.5rem', fontSize: '0.92rem', color: 'text',
  transition: 'color 150ms ease', _hover: { color: 'primary' },
});
const metaBlock = css({
  display: 'inline-flex', alignItems: 'center', gap: '0.5rem', p: '0.6rem 0.9rem', fontFamily: 'mono', fontSize: '0.88rem',
  color: 'text', bg: 'bgSubtle', border: '1px solid token(colors.border)', borderRadius: 'md', wordBreak: 'break-all',
});
const attackChip = css({
  display: 'inline-flex', alignItems: 'center', gap: '0.35rem', px: '0.6rem', py: '0.3rem', fontSize: '0.8rem', fontWeight: 600,
  color: 'text', bg: 'color-mix(in srgb, token(colors.primary) 10%, transparent)',
  border: '1px solid color-mix(in srgb, token(colors.primary) 30%, transparent)', borderRadius: 'full',
  transition: 'all 150ms ease', _hover: { borderColor: 'primary', color: 'primary' },
});
const chipLink = css({
  display: 'inline-flex', alignItems: 'center', gap: '0.4rem', px: '0.8rem', py: '0.45rem', fontSize: '0.9rem', fontWeight: 600,
  bg: 'bgCard', border: '1px solid token(colors.border)', borderRadius: 'md',
  transition: 'border-color 200ms ease, color 200ms ease', _hover: { borderColor: 'primary', color: 'primary' },
});
const fieldCard = css({ p: '0.75rem 0.9rem', bg: 'bgCard', border: '1px solid token(colors.border)', borderRadius: 'md' });
const fieldName = css({ display: 'block', fontFamily: 'mono', fontSize: '0.88rem', fontWeight: 700, color: 'primary' });
const fieldDesc = css({ display: 'block', color: 'textMuted', fontSize: '0.88rem', lineHeight: 1.55, mt: '0.25rem' });
const exampleBox = css({
  p: '0.9rem 1.05rem', bg: 'bgCard', border: '1px solid token(colors.border)', borderLeft: '3px solid token(colors.primary)',
  borderRadius: 'md', color: 'text', fontSize: '0.95rem', lineHeight: 1.75,
});
---

{matches ? (
  <BaseLayout
    title={dest ? `Moved — Port ${matches[0].port}` : `Port ${matches[0].port} — Multiple Matches`}
    description={dest ? `This page has moved to the canonical port ${matches[0].port} reference page.` : `Port ${matches[0].port} has more than one entry on this site — pick the one you mean.`}
    robots="noindex"
  >
    {dest && <script is:inline define:vars={{ dest }}>window.location.replace(dest);</script>}
    {dest ? (
      <p>This page has moved to <a href={dest}>Port {matches[0].port} — {matches[0].name}</a>.</p>
    ) : (
      <>
        <p>Port {matches[0].port} has more than one entry — pick the one you mean:</p>
        <ul>
          {matches.map((m) => (
            <li>
              <a href={`/network-ports/${m.slug}/`}>{m.protocol.toUpperCase()} — {m.name}</a>
            </li>
          ))}
        </ul>
      </>
    )}
  </BaseLayout>
) : (
  entry && (
    <BaseLayout title={`Port ${entry.port} — ${entry.name}`} description={`${entry.name} (port ${entry.port}/${entry.protocol}) — what it's used for, why it matters for DFIR, and common triggers.`}>
      <Breadcrumbs
        items={[{ label: 'Home', href: '/' }, { label: 'Network Port Reference', href: '/network-ports/' }, { label: String(entry.port) }]}
      />

  <header class={css({ mb: '1.5rem' })}>
    <p class={css({ fontFamily: 'sans', fontSize: '0.8rem', textTransform: 'uppercase', letterSpacing: '0.1em', color: 'primary', mb: '0.5rem', display: 'inline-flex', alignItems: 'center', gap: '0.4rem' })}>
      <Icon name="server" size={15} />
      {entry.category}
    </p>
    <h1 class={css({ fontSize: { base: '2.1rem', md: '2.75rem' }, fontWeight: 700, letterSpacing: '-0.02em', lineHeight: 1.1 })}>
      <span class={css({ fontFamily: 'mono', color: 'primary' })}>{entry.port}</span> — {entry.name}
    </h1>
    <p class={css({ fontSize: '1.05rem', color: 'textMuted', mt: '1rem', lineHeight: 1.6, maxW: '640px' })}>
      {entry.protocol === 'tcp/udp' ? 'TCP and UDP' : entry.protocol.toUpperCase()} · {RANGE_LABEL[entry.rangeType]}
    </p>
    <p class={css({ mt: '0.75rem', display: 'flex', flexWrap: 'wrap', gap: '0.5rem' })}>
      <span class={metaBlock}>Port {entry.port}/{entry.protocol === 'tcp/udp' ? 'tcp,udp' : entry.protocol}</span>
      <span class={tag({ tone: CONFIDENCE_TONE[entry.confidence] })}>{CONFIDENCE_LABEL[entry.confidence]}</span>
    </p>
    {
      attackLinks.length > 0 && (
        <p class={css({ mt: '1.1rem', display: 'flex', flexWrap: 'wrap', gap: '0.5rem', alignItems: 'center' })}>
          <span class={css({ fontSize: '0.75rem', fontFamily: 'sans', textTransform: 'uppercase', letterSpacing: '0.08em', color: 'textMuted' })}>
            MITRE ATT&amp;CK
          </span>
          {attackLinks.map((t) => (
            <a href={t.href} target={t.onSite ? undefined : '_blank'} rel={t.onSite ? undefined : 'noopener'} class={attackChip} title={`${t.id} ${t.name}${t.onSite ? ' — technique detail' : ' — on attack.mitre.org'}`}>
              <Icon name="crosshair" size={13} />
              <span class={css({ fontFamily: 'mono', fontWeight: 700 })}>{t.id}</span>
              {t.name}
            </a>
          ))}
        </p>
      )
    }
  </header>

  <h2 class={sectionH2}><Icon name="book-open" size={18} class={css({ color: 'primary' })} /> What it is</h2>
  <p class={para}>{entry.what}</p>

  <h2 class={sectionH2}><Icon name="shield" size={18} class={css({ color: 'primary' })} /> Why it matters</h2>
  <p class={para}>{entry.why}</p>

  <h2 class={sectionH2}><Icon name="activity" size={18} class={css({ color: 'primary' })} /> Common triggers</h2>
  <p class={para}>{entry.commonTriggers}</p>

  {
    entry.example && (
      <>
        <h2 class={sectionH2}><Icon name="file-text" size={18} class={css({ color: 'primary' })} /> Example</h2>
        <p class={exampleBox}>{entry.example}</p>
      </>
    )
  }

  {
    entry.indicators.length > 0 && (
      <>
        <h2 class={sectionH2}><Icon name="crosshair" size={18} class={css({ color: 'primary' })} /> What to check</h2>
        <p class={css({ color: 'textMuted', fontSize: '0.92rem', mb: '0.85rem', lineHeight: 1.7 })}>
          Specific things a DFIR analyst should pivot on when this port shows up:
        </p>
        <div class={css({ display: 'flex', flexDirection: 'column', gap: '0.5rem' })}>
          {entry.indicators.map((f) => (
            <div class={fieldCard}>
              <span class={fieldName}>{f.name}</span>
              <span class={fieldDesc}>{f.desc}</span>
            </div>
          ))}
        </div>
      </>
    )
  }

  <h2 class={sectionH2}><Icon name="check" size={18} class={css({ color: 'primary' })} /> Confidence</h2>
  <p class={para}>{CONFIDENCE_EXPLAINER[entry.confidence]}</p>

  {
    related.length > 0 && (
      <>
        <h2 class={sectionH2}><Icon name="link" size={18} class={css({ color: 'primary' })} /> Related ports</h2>
        <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.6rem' })}>
          {related.map((r) =>
            r.entry ? (
              <a href={`/network-ports/${r.entry.slug}/`} class={chipLink}>
                <span class={css({ fontFamily: 'mono', fontWeight: 700, color: 'primary' })}>{r.entry.port}</span>
                {r.entry.name}
                <Icon name="arrow-right" size={13} />
              </a>
            ) : (
              <span class={`${tag({ tone: 'muted' })}`}>{r.slug}</span>
            ),
          )}
        </div>
      </>
    )
  }

  <h2 class={sectionH2}>
    <Icon name="external-link" size={18} class={css({ color: 'primary' })} /> References &amp; sources
  </h2>
  <ul class={css({ listStyle: 'none', m: 0, p: 0, display: 'flex', flexDirection: 'column', gap: '0.55rem' })}>
    {entry.references.map((r) => (
      <li>
        <a href={r.url} target="_blank" rel="noopener" class={refLink}>
          <Icon name="external-link" size={14} class={css({ color: 'primary', flexShrink: 0 })} />
          <span>{r.name}</span>
        </a>
      </li>
    ))}
  </ul>
  <p class={css({ fontSize: '0.78rem', color: 'textMuted', mt: '0.85rem', lineHeight: 1.6 })}>
    Every entry on this page was researched, then independently adversarially fact-checked (a second pass
    specifically trying to refute each claim) before being included — see the confidence level above for how
    solid the port-to-service mapping itself is.
  </p>

      <EntryNav
        ariaLabel="More ports"
        prev={prev ? { href: `/network-ports/${prev.slug}/`, label: `${prev.port} — ${prev.name}` } : null}
        next={next ? { href: `/network-ports/${next.slug}/`, label: `${next.port} — ${next.name}` } : null}
      />

      <script type="application/ld+json" is:inline set:html={jsonLd} />
    </BaseLayout>
  )
)}
