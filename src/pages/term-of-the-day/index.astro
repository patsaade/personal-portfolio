---
// Compatibility redirect. The glossary page briefly lived at /term-of-the-day/
// before being renamed to /glossary/ ("Term of the Day" now names only the ticker).
// A meta-refresh is used so it composes cleanly with trailingSlash: 'always'.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
const dest = '/glossary/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${dest}`} />
    <link rel="canonical" href={dest} />
    <meta name="robots" content="noindex" />
    <title>Moved — Glossary</title>
  </head>
  <body>
    <p>This page has moved to the <a href={dest}>Glossary</a>.</p>
  </body>
</html>
