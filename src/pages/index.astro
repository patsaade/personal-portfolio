---
// Home page — hero, headline stats, featured/latest posts, and CTA.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import Icon from '../components/Icon.astro';
import { getSortedPosts, estimateReadTime } from '../utils/posts';
import { STATS, SOCIALS } from '../consts';

const posts = await getSortedPosts();
const featured = posts.filter((p) => p.data.featured).slice(0, 3);
const latest = (featured.length ? featured : posts).slice(0, 3);
---

<BaseLayout>
  {/* Hero */}
  <section
    class={css({
      py: { base: '2rem', md: '3rem' },
      borderBottom: '1px solid token(colors.border)',
      mb: '3rem',
    })}
  >
    <h1
      class={css({
        fontSize: { base: '2.4rem', md: '3.5rem' },
        fontWeight: 700,
        lineHeight: 1.1,
        letterSpacing: '-0.03em',
        mb: '1.25rem',
      })}
    >
      DFIR-focused.<br />
      <span class={css({ color: 'primary' })}>SOC & Incident Response @ First American.</span><br />
      Pursuing GCFA, GCFE & GCIH.
    </h1>
    <p
      class={css({
        fontSize: '1.15rem',
        color: 'textMuted',
        maxW: '640px',
        lineHeight: 1.7,
        mb: '2rem',
      })}
    >
      I'm Patrick Saade — a Senior Information Security Analyst at
      <strong class={css({ color: 'text' })}>First American</strong>, working the Security
      Operations Center: detection-and-response, incident response, and detection tuning across
      SIEM, cloud, endpoint, and email. Before this I ran live response and containment as a
      Threat Response Engineer at <strong class={css({ color: 'text' })}>Red Canary</strong>
      (now part of <strong class={css({ color: 'text' })}>Zscaler</strong>). This is where I go
      deeper on the forensics craft: memory analysis walkthroughs, host & EDR artifact deep
      dives, timeline reconstruction, and full lab writeups.
    </p>
    <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.75rem' })}>
      <a
        href="/blog"
        class={css({
          display: 'inline-flex',
          alignItems: 'center',
          gap: '0.5rem',
          bg: 'primary',
          color: 'onPrimary',
          fontWeight: 600,
          px: '1.25rem',
          py: '0.7rem',
          borderRadius: 'md',
          transition: 'background 200ms ease, transform 200ms ease',
          _hover: { bg: 'primaryHover', transform: 'translateY(-1px)' },
        })}
      >
        Read the latest posts <Icon name="arrow-right" size={17} />
      </a>
      <a
        href="/labs"
        class={css({
          display: 'inline-flex',
          alignItems: 'center',
          gap: '0.5rem',
          border: '1px solid token(colors.border)',
          color: 'text',
          fontWeight: 600,
          px: '1.25rem',
          py: '0.7rem',
          borderRadius: 'md',
          transition: 'border-color 200ms ease',
          _hover: { borderColor: 'primary' },
        })}
      >
        <Icon name="flask" size={17} /> Browse lab writeups
      </a>
    </div>
  </section>

  {/* Highlights */}
  <section
    class={css({
      display: 'grid',
      gridTemplateColumns: { base: '1fr', sm: 'repeat(2, 1fr)', md: 'repeat(4, 1fr)' },
      gap: '1rem',
      mb: '3.5rem',
    })}
  >
    {
      STATS.map((s) => (
        <div
          class={css({
            display: 'flex',
            alignItems: 'flex-start',
            gap: '0.85rem',
            p: '1.1rem 1.25rem',
            bg: 'bgCard',
            border: '1px solid token(colors.border)',
            borderRadius: 'lg',
            transition: 'border-color 200ms ease, transform 200ms ease',
            _hover: { borderColor: 'primary', transform: 'translateY(-2px)' },
          })}
        >
          <span
            class={css({
              display: 'inline-flex',
              alignItems: 'center',
              justifyContent: 'center',
              flexShrink: 0,
              w: '2.25rem',
              h: '2.25rem',
              borderRadius: 'md',
              bg: 'color-mix(in srgb, token(colors.primary) 13%, transparent)',
              color: 'primary',
            })}
            aria-hidden="true"
          >
            <Icon name={s.icon} size={18} />
          </span>
          <div class={css({ minW: 0 })}>
            <div class={css({ fontWeight: 700, fontSize: '0.98rem', color: 'text', lineHeight: 1.3 })}>
              {s.title}
            </div>
            <div class={css({ fontSize: '0.82rem', color: 'textMuted', mt: '0.15rem', lineHeight: 1.4 })}>
              {s.desc}
            </div>
          </div>
        </div>
      ))
    }
  </section>

  {/* Featured / latest posts */}
  <section>
    <div
      class={css({
        display: 'flex',
        justifyContent: 'space-between',
        alignItems: 'baseline',
        mb: '1.5rem',
      })}
    >
      <h2 class={css({ fontSize: '1.5rem', fontWeight: 700 })}>
        {featured.length ? 'Featured writeups' : 'Latest posts'}
      </h2>
      <a href="/blog" class={css({ fontSize: '0.9rem', color: 'primary', _hover: { textDecoration: 'underline' } })}>
        View all →
      </a>
    </div>

    {
      latest.length > 0 ? (
        <div
          class={css({
            display: 'grid',
            gridTemplateColumns: { base: '1fr', md: 'repeat(3, 1fr)' },
            gap: '1.25rem',
          })}
        >
          {latest.map((p) => (
            <BlogCard
              href={`/blog/${p.id}`}
              title={p.data.title}
              excerpt={p.data.excerpt}
              category={p.data.category}
              date={p.data.date}
              readTime={estimateReadTime(p.body, p.data.readTime)}
              difficulty={p.data.difficulty}
              tags={p.data.tags}
            />
          ))}
        </div>
      ) : (
        <p class={css({ color: 'textMuted' })}>First posts publishing soon.</p>
      )
    }
  </section>

  {/* CTA strip */}
  <section
    class={css({
      mt: '3.5rem',
      p: '2rem',
      bg: 'bgSubtle',
      border: '1px solid token(colors.border)',
      borderRadius: 'xl',
      textAlign: 'center',
    })}
  >
    <h2 class={css({ fontSize: '1.3rem', fontWeight: 700, mb: '0.5rem' })}>
      Pursuing GCFA / GCFE / GCIH too?
    </h2>
    <p class={css({ color: 'textMuted', mb: '1.25rem', maxW: '520px', mx: 'auto' })}>
      Follow along for exam-prep notes, tool comparisons, and home-lab builds — or connect
      with me directly.
    </p>
    <div class={css({ display: 'flex', justifyContent: 'center', gap: '0.75rem', flexWrap: 'wrap' })}>
      <a href={SOCIALS.linkedin} target="_blank" rel="noopener" class={css({ color: 'primary', fontWeight: 600, _hover: { textDecoration: 'underline' } })}>LinkedIn</a>
      <span class={css({ color: 'border' })}>·</span>
      <a href={SOCIALS.github} target="_blank" rel="noopener" class={css({ color: 'primary', fontWeight: 600, _hover: { textDecoration: 'underline' } })}>GitHub (home lab)</a>
    </div>
  </section>
</BaseLayout>
