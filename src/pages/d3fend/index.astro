---
// MITRE D3FEND coverage map — the defensive counterpart to the ATT&CK Map. The full
// D3FEND matrix (generated from MITRE's official ontology), grouped by defensive
// tactic in matrix order. Each technique links to its MITRE D3FEND page, its own
// detail page, and — where D3FEND maps it — the ATT&CK techniques it counters.
// Searchable, with a tactic facet and a "maps to ATT&CK" filter. Same shape as the
// ATT&CK Map (shared TagCombobox / CollapseAll / FilterToggle / .card-grid). Static.
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Icon from '../../components/Icon.astro';
import CollapseAll from '../../components/CollapseAll.astro';
import TagCombobox from '../../components/TagCombobox.astro';
import FilterToggle from '../../components/FilterToggle.astro';
import ListFilter from '../../components/ListFilter.astro';
import { tag, card } from 'styled-system/recipes';
import { tagSlug } from '../../utils/posts';
import { D3FEND_TECHNIQUES, D3FEND_TACTIC_ORDER, D3FEND_VERSION, d3fendById } from '../../data/d3fend';

// Group techniques by tactic, in D3FEND matrix order, populated only.
const byTactic: Record<string, typeof D3FEND_TECHNIQUES> = {};
for (const t of D3FEND_TECHNIQUES) (byTactic[t.tactic] ??= []).push(t);
const tactics = D3FEND_TACTIC_ORDER.filter((name) => byTactic[name]?.length);

const total = D3FEND_TECHNIQUES.length;
const mappedCount = D3FEND_TECHNIQUES.filter((t) => t.counters.length).length;

// Tactic facet for the search combobox.
const tacticOptions = tactics.map((name) => ({ value: tagSlug(name), label: name, count: byTactic[name].length }));

// Each tactic is a collapsible <details>, matching the ATT&CK Map / Glossary pages.
const groupDetails = css({ borderTop: '1px solid token(colors.border)', py: '1.25rem' });
const groupSummary = css({
  cursor: 'pointer',
  listStyle: 'none',
  userSelect: 'none',
  '&::-webkit-details-marker': { display: 'none' },
  '&::marker': { display: 'none' },
  _hover: { '& .tactic-title': { color: 'primary' } },
});
const chevCls = css({ color: 'textMuted', flexShrink: 0, transition: 'transform 200ms ease', 'details[open] &': { transform: 'rotate(90deg)' } });
const tacticHead = css({ display: 'flex', alignItems: 'center', gap: '0.5rem', m: 0, fontSize: '1.05rem', fontWeight: 700 });
const tacCount = css({ fontFamily: 'sans', fontSize: '0.68rem', fontWeight: 600, color: 'textMuted', bg: 'bgSubtle', border: '1px solid token(colors.border)', borderRadius: 'full', px: '0.5rem', py: '0.1rem' });
const tacMappedCount = css({ fontFamily: 'sans', fontSize: '0.72rem', fontWeight: 600, color: 'accent' });
const chip = `${card()} ${css({
  scrollMarginTop: '90px', // clear the sticky header when linked to via #<id>
  '&[data-mapped]': { borderLeftWidth: '3px', borderLeftColor: 'accent' },
  '&:target': { borderColor: 'primary', boxShadow: 'cardHover' },
})}`;
const chipTop = css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '0.5rem' });
const chipId = css({ fontFamily: 'mono', fontSize: '0.72rem', fontWeight: 600, color: 'primary' });
const mappedBadge = tag({ tone: 'accent' });
const chipName = css({ display: 'inline-flex', alignItems: 'center', gap: '0.3rem', fontWeight: 600, fontSize: '0.9rem', color: 'text', lineHeight: 1.3, _hover: { color: 'primary' } });
const chipParent = css({ display: 'inline-flex', alignItems: 'center', gap: '0.25rem', fontSize: '0.78rem', fontWeight: 600, color: 'textMuted', mt: 'auto' });

const statLink = css({ color: 'primary', display: 'inline-flex', alignItems: 'center', gap: '0.3rem', _hover: { textDecoration: 'underline' } });
const legendRow = css({ display: 'flex', flexWrap: 'wrap', gap: '0.4rem 1.25rem', mb: '1.75rem', fontSize: '0.78rem', color: 'textMuted' });
const legendItem = css({ display: 'inline-flex', alignItems: 'center', gap: '0.4rem' });
const legendSwatch = css({ display: 'inline-block', w: '14px', h: '14px', bg: 'bgCard', border: '1px solid token(colors.border)', borderLeftWidth: '3px', borderLeftColor: 'accent', borderRadius: '2px', flexShrink: 0 });

// Anchor each technique's id to its first render only.
const anchored = new Set<string>();
---

<BaseLayout
  title="MITRE D3FEND Map"
  description="The full MITRE D3FEND matrix of defensive techniques, by tactic — each linked to its official D3FEND page, a detail page, and the ATT&CK techniques it counters."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'MITRE D3FEND Map' }]}
    eyebrow="Countermeasures"
    title="MITRE D3FEND Map"
    description="The defensive counterpart to ATT&CK — defensive techniques grouped by tactic. Each links to its official D3FEND page and detail entry, and many map to the ATT&CK techniques they counter."
  />

  <aside
    class={css({ bg: 'bgSubtle', border: '1px solid token(colors.border)', borderLeftWidth: '3px', borderLeftColor: 'primary', borderRadius: 'md', p: '1rem 1.25rem', mb: '1.5rem' })}
  >
    <p class={css({ color: 'text', lineHeight: 1.7, fontSize: '0.95rem', m: 0 })}>
      <strong class={css({ color: 'text' })}>MITRE D3FEND</strong> — a knowledge graph of <em>defensive</em>
      techniques, the counterpart to ATT&CK's offensive one. <em>Tactics</em> are defensive goals
      (Model, Harden, Detect, Isolate, Deceive, Evict, Restore); <em>techniques</em> are the specific
      countermeasures. D3FEND ties each technique to the ATT&CK techniques it <em>counters</em>, so a
      defender can move from "what the attacker did" to "what stops it."
    </p>
  </aside>

  {/* Cross-link to the offensive counterpart */}
  <a
    href="/attack-map/"
    class={css({
      display: 'flex',
      alignItems: 'center',
      gap: '0.6rem',
      mb: '1.5rem',
      p: '0.7rem 1rem',
      borderRadius: 'md',
      border: '1px solid token(colors.border)',
      bg: 'bgCard',
      fontSize: '0.9rem',
      color: 'text',
      transition: 'border-color 200ms ease, color 200ms ease',
      _hover: { borderColor: 'primary', color: 'primary', '& .x-arrow': { transform: 'translateX(3px)' } },
    })}
  >
    <Icon name="crosshair" size={16} class={css({ color: 'primary', flexShrink: 0 })} />
    <span>See the offensive techniques — <strong class={css({ fontWeight: 700 })}>MITRE ATT&CK Coverage Map</strong></span>
    <Icon name="arrow-right" size={15} class={`x-arrow ${css({ ml: 'auto', color: 'primary', flexShrink: 0, transition: 'transform 200ms ease' })}`} />
  </a>

  {/* Search + tactic filter */}
  <div class={css({ mb: '0.6rem' })}>
    <TagCombobox
      id="d3fend-cb"
      options={tacticOptions}
      placeholder={`Search ${total} techniques by name or ID, or type a tactic…`}
      label="Search D3FEND techniques or filter by tactic"
    />
  </div>

  {/* Stats + controls */}
  <div class={css({ display: 'flex', alignItems: 'center', gap: '0.6rem 1rem', flexWrap: 'wrap', mb: '0.85rem' })}>
    <p role="status" aria-live="polite" class={css({ display: 'flex', flexWrap: 'wrap', alignItems: 'center', gap: '0.3rem 0.9rem', color: 'textMuted', fontSize: '0.9rem', m: 0 })}>
      <span><span id="d3fend-count">{total}</span> techniques</span>
      <span aria-hidden="true">·</span>
      <span class={css({ color: 'accent', fontWeight: 600 })}>{mappedCount} map to ATT&CK</span>
      <span aria-hidden="true">·</span>
      <a href="https://d3fend.mitre.org/" target="_blank" rel="noopener" class={statLink}>D3FEND v{D3FEND_VERSION} <Icon name="external-link" size={12} /></a>
    </p>
    <div class={css({ display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: '0.5rem', ml: { sm: 'auto' } })}>
      <FilterToggle id="d3fend-mapped-toggle" icon="crosshair" label="Maps to ATT&CK" tone="accent" />
      <CollapseAll target="[data-tactic-group]" />
    </div>
  </div>

  {/* Legend */}
  <div class={legendRow}>
    <span class={legendItem}><span class={legendSwatch} aria-hidden="true"></span> maps to an ATT&CK technique</span>
    <span class={legendItem}><Icon name="arrow-right" size={13} class={css({ color: 'textMuted' })} /> opens the technique detail page</span>
  </div>

  <div class={css({ display: 'flex', flexDirection: 'column' })}>
    {
      tactics.map((tactic) => {
        const tacMapped = byTactic[tactic].filter((t) => t.counters.length).length;
        return (
          <details data-tactic-group open class={groupDetails}>
            <summary class={groupSummary}>
              <h2 class={tacticHead}>
                <Icon name="chevron-right" size={17} class={chevCls} />
                <Icon name="shield" size={18} class={css({ color: 'primary', flexShrink: 0 })} />
                <span class="tactic-title">{tactic}</span>
                <span class={tacCount}>{byTactic[tactic].length}</span>
                {tacMapped > 0 && <span class={tacMappedCount}>{tacMapped} mapped</span>}
              </h2>
            </summary>
            <div class={`card-grid ${css({ mt: '1rem' })}`}>
              {byTactic[tactic].map((t) => {
                const firstHere = !anchored.has(t.id);
                if (firstHere) anchored.add(t.id);
                const parent = t.parentId ? d3fendById(t.parentId) : undefined;
                const mapped = t.counters.length > 0;
                return (
                  <div
                    id={firstHere ? t.id : undefined}
                    class={chip}
                    data-d3fend-id={t.id}
                    data-tactic={tagSlug(tactic)}
                    data-d3fend-card={`${t.id} ${t.name} ${parent ? parent.name : ''}`.toLowerCase()}
                    {...(mapped ? { 'data-mapped': true } : {})}
                  >
                    <div class={chipTop}>
                      <span class={chipId}>{t.id}</span>
                      {mapped && <span class={mappedBadge}>{t.counters.length} ATT&CK</span>}
                    </div>
                    <a href={`/d3fend/${t.id}/`} class={chipName}>
                      {t.name}
                      <Icon name="arrow-right" size={12} class={css({ color: 'textMuted', flexShrink: 0 })} />
                    </a>
                    {parent && (
                      <span class={chipParent}>
                        <Icon name="layers" size={12} /> {parent.name}
                      </span>
                    )}
                  </div>
                );
              })}
            </div>
          </details>
        );
      })
    }
  </div>

  <p id="d3fend-empty" hidden role="status" aria-live="polite" class={css({ color: 'textMuted', textAlign: 'center', py: '3rem' })}>
    No techniques match.
  </p>

  <p class={css({ fontSize: '0.78rem', color: 'textMuted', mt: '2.5rem', pt: '1.5rem', borderTop: '1px solid token(colors.border)', lineHeight: 1.6 })}>
    D3FEND™ is a trademark of The MITRE Corporation. Technique names, IDs, and ATT&CK mappings are drawn
    from the public D3FEND knowledge base (v{D3FEND_VERSION}); this map links back to the canonical pages.
  </p>

  <ListFilter
    config={{
      comboboxId: 'd3fend-cb',
      cardSelector: '[data-d3fend-card]',
      searchAttr: 'data-d3fend-card',
      groupSelector: '[data-tactic-group]',
      countId: 'd3fend-count',
      emptyId: 'd3fend-empty',
      dedupeAttr: 'data-d3fend-id',
      facetAttr: 'data-tactic',
      toggles: [{ id: 'd3fend-mapped-toggle', attr: 'data-mapped' }],
    }}
  />
</BaseLayout>
