---
// Tool detail page — one prerendered page per tool, in the glossary / ATT&CK
// detail format (what it is, why it matters, in practice, reference) while staying
// its own thing: a platform · function eyebrow, the function + cost tags, an
// "in my kit" note, and a reference out to the tool's official site.
export const prerender = true;
import { css } from 'styled-system/css';
import { tag } from 'styled-system/recipes';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import { TOOLS, costTone } from '../../data/tools';
import { CATEGORY_META, SECURITY_TERMS, type SecurityCategory } from '../../data/securityTerms';
import { getSortedPosts, getSortedLabs, tagSlug } from '../../utils/posts';

// A tool's function tag maps loosely to the glossary category covering the same
// ground — a derived cross-link (no new authoring), so e.g. a Memory tool points
// at the Memory Forensics category. Left out where no category fits well (broad
// "Platform"/"Utility" tools).
const FN_TO_CATEGORY: Partial<Record<string, SecurityCategory>> = {
  Detection: 'Detection, Hunting & IR',
  Host: 'Host & Disk Forensics',
  Imaging: 'Host & Disk Forensics',
  Intel: 'Threat Intelligence & Frameworks',
  Logs: 'Logging & Telemetry',
  Malware: 'Malware Analysis & RE',
  Memory: 'Memory Forensics',
  Network: 'Network Forensics & C2',
  OSINT: 'Threat Intelligence & Frameworks',
  Registry: 'Host & Disk Forensics',
  Timeline: 'Host & Disk Forensics',
  Triage: 'Host & Disk Forensics',
};

export async function getStaticPaths() {
  // Reverse-link writeups whose `tools` frontmatter lists this tool (by name).
  const [posts, labs] = await Promise.all([getSortedPosts(), getSortedLabs()]);
  return TOOLS.map((tool) => {
    const name = tool.name.toLowerCase();
    const writeups = [
      ...posts.filter((p) => (p.data.tools ?? []).some((n) => n.toLowerCase() === name)).map((p) => ({ title: p.data.title, href: `/blog/${p.id}/`, kind: 'Post' })),
      ...labs.filter((l) => (l.data.tools ?? []).some((n) => n.toLowerCase() === name)).map((l) => ({ title: l.data.title, href: `/labs/${l.id}/`, kind: 'Lab' })),
    ];
    return { params: { slug: tool.slug }, props: { tool, writeups } };
  });
}

const { tool, writeups } = Astro.props;

const idx = TOOLS.findIndex((t) => t.slug === tool.slug);
const prev = idx > 0 ? TOOLS[idx - 1] : null;
const next = idx >= 0 && idx < TOOLS.length - 1 ? TOOLS[idx + 1] : null;
// Other tools sharing this tool's function tag (exact, from the data).
const similar = TOOLS.filter((t) => t.fn === tool.fn && t.slug !== tool.slug);
// The glossary category covering the same ground as this tool's function, if any.
const relatedCategory = FN_TO_CATEGORY[tool.fn];
const relatedCategoryCount = relatedCategory ? SECURITY_TERMS.filter((t) => t.category === relatedCategory).length : 0;

const sectionH2 = css({ display: 'flex', alignItems: 'center', gap: '0.5rem', fontSize: '1.2rem', fontWeight: 700, mt: '2.5rem', mb: '0.75rem' });
const para = css({ color: 'text', lineHeight: 1.8, fontSize: '1.02rem' });
const exampleP = css({ borderLeft: '3px solid token(colors.primary)', pl: '1rem', color: 'textMuted', fontStyle: 'italic' });
const refLink = css({ display: 'inline-flex', alignItems: 'center', gap: '0.5rem', fontSize: '0.92rem', color: 'text', transition: 'color 150ms ease', _hover: { color: 'primary' } });
const navLink = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.25rem',
  p: '0.85rem 1.1rem',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  bg: 'bgCard',
  transition: 'border-color 200ms ease, transform 200ms ease',
  _hover: { borderColor: 'primary', transform: 'translateY(-2px)' },
});
const navMeta = css({ fontSize: '0.72rem', fontFamily: 'sans', color: 'textMuted' });
const navTitle = css({ fontWeight: 600, fontSize: '0.95rem', lineHeight: 1.3 });
const codeBlock = css({
  p: '0.6rem 0.9rem',
  fontFamily: 'mono',
  fontSize: '0.85rem',
  color: 'text',
  bg: 'bgSubtle',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  overflowX: 'auto',
  whiteSpace: 'pre',
});
---

<BaseLayout title={`${tool.name} — DFIR tool`} description={tool.what ?? tool.use}>
  <Breadcrumbs
    items={[{ label: 'Home', href: '/' }, { label: 'Tools', href: '/tools/' }, { label: tool.name }]}
  />

  <header class={css({ mb: '1.5rem' })}>
    <p class={css({ fontFamily: 'sans', fontSize: '0.8rem', textTransform: 'uppercase', letterSpacing: '0.1em', color: 'primary', mb: '0.5rem', display: 'inline-flex', alignItems: 'center', gap: '0.4rem' })}>
      <Icon name="wrench" size={15} />
      {tool.platform} · {tool.fn}
    </p>
    <h1 class={css({ fontSize: { base: '2.1rem', md: '2.75rem' }, fontWeight: 700, letterSpacing: '-0.02em', lineHeight: 1.1, display: 'flex', alignItems: 'center', gap: '0.5rem', flexWrap: 'wrap' })}>
      {tool.core && <Icon name="star" size={20} strokeWidth={0} class={css({ color: 'accent', fill: 'token(colors.accent)' })} label="In my kit" />}
      {tool.name}
    </h1>
    <p class={css({ fontSize: '1.15rem', color: 'textMuted', mt: '0.6rem' })}>{tool.use}</p>
    <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.4rem', mt: '1rem' })}>
      <span class={tag({ tone: costTone(tool.cost) })}>{tool.cost}</span>
      <span class={tag({ tone: 'muted' })}>{tool.fn}</span>
      <span class={tag({ tone: 'muted' })}>{tool.platform}</span>
      {tool.core && <span class={tag({ tone: 'accent' })}>In my kit</span>}
    </div>
    {tool.tags.length > 0 && (
      <div class={css({ display: 'flex', flexWrap: 'wrap', alignItems: 'center', gap: '0.4rem', mt: '0.85rem' })}>
        <Icon name="tag" size={13} class={css({ color: 'textMuted', flexShrink: 0 })} label="Tags" />
        {tool.tags.map((t) => (
          <a href={`/tools/?q=${encodeURIComponent(t)}`} class={`${tag({ tone: 'muted', mono: true })} ${css({ transition: 'color 150ms ease, border-color 150ms ease', _hover: { color: 'primary', borderColor: 'primary' } })}`}>
            {t}
          </a>
        ))}
      </div>
    )}
  </header>

  {tool.what && (
    <>
      <h2 class={sectionH2}><Icon name="book-open" size={18} class={css({ color: 'primary' })} /> What it is</h2>
      <p class={para}>{tool.what}</p>
    </>
  )}

  {tool.install && (
    <>
      <h2 class={sectionH2}><Icon name="download" size={18} class={css({ color: 'primary' })} /> Install</h2>
      <p class={css({ color: 'text', lineHeight: 1.7, fontSize: '0.95rem' })}>{tool.install}</p>
    </>
  )}

  {tool.syntax && (
    <>
      <h2 class={sectionH2}><Icon name="terminal" size={18} class={css({ color: 'primary' })} /> Usage</h2>
      <p class={codeBlock}>{tool.syntax}</p>
    </>
  )}

  {tool.why && (
    <>
      <h2 class={sectionH2}><Icon name="shield" size={18} class={css({ color: 'primary' })} /> Why it matters</h2>
      <p class={para}>{tool.why}</p>
    </>
  )}

  {tool.example && (
    <>
      <h2 class={sectionH2}><Icon name="terminal" size={18} class={css({ color: 'primary' })} /> In practice</h2>
      <p class={`${para} ${exampleP}`}>{tool.example}</p>
    </>
  )}

  {writeups.length > 0 && (
    <>
      <h2 class={sectionH2}><Icon name="file-text" size={18} class={css({ color: 'primary' })} /> Featured in my writeups</h2>
      <ul class={css({ listStyle: 'none', m: 0, p: 0, display: 'flex', flexDirection: 'column', gap: '0.5rem' })}>
        {writeups.map((w) => (
          <li>
            <a href={w.href} class={`${refLink} ${css({ gap: '0.5rem' })}`}>
              <Icon name="arrow-right" size={14} class={css({ color: 'primary', flexShrink: 0 })} />
              <span>{w.title}</span>
              <span class={css({ fontFamily: 'sans', fontSize: '0.66rem', textTransform: 'uppercase', letterSpacing: '0.05em', color: 'textMuted' })}>{w.kind}</span>
            </a>
          </li>
        ))}
      </ul>
    </>
  )}

  {similar.length > 0 && (
    <>
      <h2 class={sectionH2}><Icon name="layers" size={18} class={css({ color: 'primary' })} /> Similar tools</h2>
      <p class={css({ color: 'textMuted', fontSize: '0.92rem', mb: '0.85rem', lineHeight: 1.7 })}>
        Other {tool.fn} tools in the toolkit:
      </p>
      <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.6rem' })}>
        {similar.map((s) => (
          <a
            href={`/tools/${s.slug}/`}
            class={css({
              display: 'inline-flex',
              alignItems: 'center',
              gap: '0.4rem',
              px: '0.8rem',
              py: '0.45rem',
              fontSize: '0.9rem',
              fontWeight: 600,
              bg: 'bgCard',
              border: '1px solid token(colors.border)',
              borderRadius: 'md',
              transition: 'border-color 200ms ease, color 200ms ease',
              _hover: { borderColor: 'primary', color: 'primary' },
            })}
          >
            {s.core && <Icon name="star" size={12} strokeWidth={0} class={css({ color: 'accent', fill: 'token(colors.accent)' })} label="In my kit" />}
            {s.name}
            <Icon name="arrow-right" size={13} />
          </a>
        ))}
      </div>
    </>
  )}

  {relatedCategory && (
    <>
      <h2 class={sectionH2}><Icon name="book-open" size={18} class={css({ color: 'primary' })} /> Related glossary terms</h2>
      <a
        href={`/glossary/#${tagSlug(relatedCategory)}`}
        class={css({
          display: 'flex',
          alignItems: 'center',
          gap: '0.6rem',
          p: '0.7rem 1rem',
          borderRadius: 'md',
          border: '1px solid token(colors.border)',
          bg: 'bgCard',
          fontSize: '0.9rem',
          color: 'text',
          transition: 'border-color 200ms ease, color 200ms ease',
          _hover: { borderColor: 'primary', color: 'primary', '& .x-arrow': { transform: 'translateX(3px)' } },
        })}
      >
        <Icon name={CATEGORY_META[relatedCategory].icon as any} size={16} class={css({ color: 'primary', flexShrink: 0 })} />
        <span>
          Browse <strong class={css({ fontWeight: 700 })}>{relatedCategory}</strong> in the glossary — {relatedCategoryCount} terms covering the same ground.
        </span>
        <Icon name="arrow-right" size={15} class={`x-arrow ${css({ ml: 'auto', color: 'primary', flexShrink: 0, transition: 'transform 200ms ease' })}`} />
      </a>
    </>
  )}

  <h2 class={sectionH2}><Icon name="external-link" size={18} class={css({ color: 'primary' })} /> References &amp; sources</h2>
  <ul class={css({ listStyle: 'none', m: 0, p: 0, display: 'flex', flexDirection: 'column', gap: '0.55rem' })}>
    <li>
      <a href={tool.url} target="_blank" rel="noopener" class={refLink}>
        <Icon name="external-link" size={14} class={css({ color: 'primary', flexShrink: 0 })} />
        <span>{tool.name} — official site</span>
      </a>
    </li>
    {tool.references?.map((r) => (
      <li>
        <a href={r.url} target="_blank" rel="noopener" class={refLink}>
          <Icon name="external-link" size={14} class={css({ color: 'textMuted', flexShrink: 0 })} />
          <span>{r.name}</span>
        </a>
      </li>
    ))}
  </ul>
  <p class={css({ fontSize: '0.78rem', color: 'textMuted', mt: '0.85rem', lineHeight: 1.6 })}>
    Names and trademarks belong to their respective projects and vendors; links go to each tool's
    canonical site. Cost reflects the free/open-source tier — some tools offer paid upgrades.
  </p>

  <nav
    aria-label="More tools"
    class={css({ display: 'grid', gridTemplateColumns: { base: '1fr', sm: '1fr 1fr' }, gap: '1rem', mt: '3rem', pt: '1.5rem', borderTop: '1px solid token(colors.border)' })}
  >
    {prev ? (
      <a href={`/tools/${prev.slug}/`} class={navLink}>
        <span class={navMeta}>← Previous</span>
        <span class={navTitle}>{prev.name}</span>
      </a>
    ) : (
      <span />
    )}
    {next ? (
      <a href={`/tools/${next.slug}/`} class={`${navLink} ${css({ textAlign: 'right', alignItems: 'flex-end' })}`}>
        <span class={navMeta}>Next →</span>
        <span class={navTitle}>{next.name}</span>
      </a>
    ) : (
      <span />
    )}
  </nav>
</BaseLayout>
