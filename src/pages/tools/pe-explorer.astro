---
// PE Header Explorer — parse a local EXE/DLL's Windows PE headers entirely
// client-side (DOS header, COFF File Header, Optional Header, Section Table,
// Import/Export Directory Tables, and a computed imphash). Same page shape
// as the Hash Calculator / IOC Extractor (intro aside -> interactive tool ->
// reference notes). Static page — prerender to HTML served from the CDN.
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Icon from '../../components/Icon.astro';
import PeExplorer from '../../components/PeExplorer.astro';
import Term from '../../components/Term.astro';
import { toolChip } from '../../components/RelatedTools.astro';

const sectionH2 = css({
  display: 'flex',
  alignItems: 'center',
  gap: '0.6rem',
  fontSize: '1.3rem',
  fontWeight: 700,
  mt: '2.5rem',
  mb: '1rem',
  pt: '1.5rem',
  borderTop: '1px solid token(colors.border)',
  scrollMarginTop: '90px',
});
const refTable = css({ width: '100%', borderCollapse: 'collapse', fontSize: '0.85rem' });
const refTh = css({ textAlign: 'left', color: 'textMuted', fontFamily: 'sans', fontWeight: 600, fontSize: '0.72rem', textTransform: 'uppercase', letterSpacing: '0.06em', p: '0.5rem 0.7rem', borderBottom: '1px solid token(colors.border)' });
const refTd = css({ p: '0.5rem 0.7rem', borderBottom: '1px solid token(colors.border)', color: 'text', verticalAlign: 'top' });
const refTdMuted = css({ p: '0.5rem 0.7rem', borderBottom: '1px solid token(colors.border)', color: 'textMuted', fontSize: '0.8rem', verticalAlign: 'top' });
const relatedList = css({ display: 'flex', flexDirection: 'column', gap: '0.85rem' });
const relatedReason = css({ color: 'textMuted', fontSize: '0.85rem', mt: '0.35rem', lineHeight: 1.6 });

const STRUCTURES: { name: string; note: string }[] = [
  { name: 'DOS header', note: "The legacy MS-DOS stub every PE still carries — its only fields that matter to a modern loader are the 'MZ' magic and e_lfanew, the file offset of the real PE header." },
  { name: 'COFF File Header', note: 'Machine type, section count, link timestamp, and Characteristics flags (executable vs. DLL, 32-bit-only, etc.) — the first place to check target architecture and build time.' },
  { name: 'Optional Header', note: "Despite the name, mandatory for a working image — Magic distinguishes 32-bit PE32 from 64-bit PE32+, plus the entry point RVA, preferred image base, and the 16-entry data directory that locates every other table." },
  { name: 'Section Table', note: 'One entry per section (.text, .data, .rsrc, …) mapping its virtual layout to its on-disk bytes, plus Characteristics flags — a section marked both writable and executable is a classic red flag.' },
  { name: 'Import Directory Table', note: "Every DLL a binary depends on and the functions it pulls from each — by name or, less commonly, by raw ordinal. What a file imports is often the fastest way to guess what it does." },
  { name: 'Export Table', note: "Present on DLLs (and some EXEs) — the functions a module makes available to others, by name and/or ordinal. Absent on most plain executables." },
  { name: 'Imphash', note: "An MD5 hash of a file's import table, order-sensitive and format-normalized — two samples sharing an imphash very likely share source code, even if their file hashes differ completely (a common signal for clustering malware families)." },
];
---

<BaseLayout
  title="PE Header Explorer"
  description="Parse a local EXE/DLL's DOS header, COFF File Header, Optional Header, Section Table, Import/Export tables, and imphash — entirely in your browser, nothing uploaded."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Tool Catalog', href: '/tools/' }, { label: 'PE Header Explorer' }]}
    eyebrow="Malware & Static Analysis"
    title="PE Header Explorer"
    description="Load a local EXE or DLL and walk its Windows PE headers — DOS/COFF/Optional headers, sections, imports, exports, and a computed imphash."
  />

  <aside
    class={css({
      bg: 'bgSubtle',
      border: '1px solid token(colors.border)',
      borderLeftWidth: '3px',
      borderLeftColor: 'primary',
      borderRadius: 'md',
      p: '1rem 1.25rem',
      mb: '1.5rem',
    })}
  >
    <p class={css({ color: 'text', lineHeight: 1.7, fontSize: '0.95rem', m: 0 })}>
      Everything here runs entirely in your browser — <strong class={css({ color: 'text' })}>no external APIs, no
      upload, the file you choose never leaves your machine</strong>. Parsing reads the raw bytes locally via the
      File API and walks the Windows PE format by hand — DOS header, COFF File Header, Optional Header, Section
      Table, and the Import/Export Directory Tables — computing an imphash along the way. Disassembly, resource
      (.rsrc) rendering, .NET/CLR metadata, and digital-signature verification are out of scope; a file that has
      any of those surfaces a plain note rather than pretending they don't exist.
    </p>
  </aside>

  <p class={css({ color: 'text', lineHeight: 1.8, fontSize: '1rem', mb: '1.5rem' })}>
    Static PE analysis is usually the first thing worth reaching for on an unknown or suspicious binary — before
    it's safe, or necessary, to detonate it in a sandbox. The COFF header's machine type and link timestamp tell
    you what you're looking at and roughly when it was built (though a build timestamp is trivially forged and
    shouldn't be trusted on its own — it's a linker-set field, not a signed one); the Section Table's
    Characteristics flags surface anything unusual, like a section marked both writable and executable; and the
    Import Directory Table is often the fastest way to form a hypothesis about what a binary does, since it lists
    every external function the file calls. The imphash computed alongside the parse exists for the same reason{' '}
    <Term slug="malware-family">malware family</Term> clustering tools use it: two samples built from the same
    source tree tend to share an import order — and therefore an imphash — even when their raw file hashes, or
    even their observable behavior, differ completely.
  </p>

  <h2 id="explorer" class={css({ display: 'flex', alignItems: 'center', gap: '0.6rem', fontSize: '1.3rem', fontWeight: 700, mb: '1rem', scrollMarginTop: '90px' })}>
    <Icon name="layers" size={20} class={css({ color: 'primary' })} /> Explorer
  </h2>
  <PeExplorer />

  <h2 id="reference" class={sectionH2}>
    <Icon name="list" size={20} class={css({ color: 'primary' })} /> Structure reference
  </h2>
  <div class={css({ overflowX: 'auto' })}>
    <table class={refTable}>
      <thead>
        <tr>
          <th class={refTh}>Structure</th>
          <th class={refTh}>What it tells you</th>
        </tr>
      </thead>
      <tbody>
        {
          STRUCTURES.map((s) => (
            <tr>
              <td class={refTd}>
                <strong class={css({ color: 'text' })}>{s.name}</strong>
              </td>
              <td class={refTdMuted}>{s.note}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <p class={css({ color: 'textMuted', fontSize: '0.88rem', mt: '1.5rem', lineHeight: 1.7 })}>
    A file with by-ordinal imports (no function name recorded in the import table, just a numeric ordinal into the
    exporting DLL) renders those entries as <strong class={css({ color: 'text' })}>"ordinal N"</strong> rather than
    guessing a name — resolving an ordinal to a name needs the exporting DLL's own export table, which this tool
    doesn't fetch or assume.
  </p>

  <h2 id="related" class={sectionH2}>
    <Icon name="wrench" size={20} class={css({ color: 'primary' })} /> Related tools
  </h2>
  <div class={relatedList}>
    <div>
      <a href="/tools/hash-calculator/" class={toolChip}>
        <Icon name="lock" size={13} /> Hash Calculator <Icon name="arrow-right" size={13} />
      </a>
      <p class={relatedReason}>
        Compute an MD5/SHA-256 of the same file alongside the header parse — the bytes you just inspected, ready
        for a threat-intel or known-bad lookup.
      </p>
    </div>
    <div>
      <a href="/tools/ioc-extractor/" class={toolChip}>
        <Icon name="search" size={13} /> IOC Extractor <Icon name="arrow-right" size={13} />
      </a>
      <p class={relatedReason}>
        Pull structured indicators — IPs, domains, hashes — out of any strings, notes, or command line you're
        pasting alongside a PE analysis.
      </p>
    </div>
  </div>
</BaseLayout>
