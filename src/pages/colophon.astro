---
// Colophon — how the site is built (stack, design, principles, build note).
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const para = css({ color: 'textMuted', lineHeight: 1.8, mb: '1rem' });
const h2 = css({ fontSize: '1.3rem', fontWeight: 700, mt: '2.25rem', mb: '0.75rem' });
const list = css({ color: 'textMuted', lineHeight: 1.9, pl: '1.25rem', mb: '1rem' });
const link = css({ color: 'primary', textDecoration: 'underline', _hover: { color: 'primaryHover' } });
const term = css({ color: 'text', fontWeight: 600 });
---

<BaseLayout
  title="Colophon"
  description="How patricksaade.com is built — the stack, design choices, and principles behind the site."
>
  <PageHeader eyebrow="Colophon" title="How this site is built" description="The stack, the choices, and the principles behind it." />

  <h2 class={h2}>Stack</h2>
  <ul class={list}>
    <li><span class={term}>Astro</span> — content-driven framework; pages are prerendered to HTML, with minimal client JS.</li>
    <li><span class={term}>Panda CSS</span> — type-safe, zero-runtime styling generated at build time.</li>
    <li><span class={term}>MDX</span> — posts authored in Markdown via Astro content collections.</li>
    <li><span class={term}>Shiki</span> — build-time syntax highlighting with light/dark themes.</li>
    <li><span class={term}>Vercel</span> — hosting via the <code class={css({ fontFamily: 'mono', fontSize: '0.9em' })}>@astrojs/vercel</code> adapter, global CDN, plus cookieless Web Analytics &amp; Speed Insights.</li>
  </ul>

  <h2 class={h2}>Design</h2>
  <ul class={list}>
    <li>Ten color themes (five dark, five light), chosen independently per mode.</li>
    <li>System UI font stack (Inter where available) for text; a monospace stack for code and metadata.</li>
    <li>Icons are inline SVGs (lucide-style), drawn with <code class={css({ fontFamily: 'mono', fontSize: '0.9em' })}>currentColor</code> so they follow the theme.</li>
    <li>A subtle ambient "node field" background, themed to the active palette.</li>
    <li>A daily <span class={term}>Term of the Day</span> — a 500+ entry, vendor-agnostic security glossary, surfaced as a scrolling ticker and a searchable index.</li>
  </ul>

  <h2 class={h2}>Principles</h2>
  <ul class={list}>
    <li><span class={term}>Fast & light</span> — no client frameworks; interactivity is small inline scripts, plus Vercel Web Analytics & Speed Insights.</li>
    <li><span class={term}>Privacy-first</span> — cookieless Web Analytics & Speed Insights, no marketing trackers. See the <a class={link} href="/privacy">privacy policy</a>.</li>
    <li><span class={term}>Accessible</span> — semantic markup, keyboard-friendly controls, and reduced-motion support (the background animation disables itself when you prefer reduced motion).</li>
  </ul>

  <h2 class={h2}>Build</h2>
  <p class={para}>
    The site's design and front-end were built with AI assistance
    (<a class={link} href="https://claude.com/claude-code" target="_blank" rel="noopener">Claude Code</a>),
    then reviewed and refined. The source is on
    <a class={link} href="https://github.com/patsaade/personal-portfolio" target="_blank" rel="noopener">GitHub</a>,
    and the footer links the exact build version and commit.
  </p>
</BaseLayout>
