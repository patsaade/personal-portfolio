---
// OSINT Toolkit — a recipe-framed search-operator ("dork") builder across
// Google/Bing/DuckDuckGo: pick a Focus (the "cuisine style" — what you're
// trying to find), which highlights relevant Ingredients and offers a few
// named Presets; picking a Preset fills those ingredients, producing the
// live Recipe (the final query) in the builder's own sticky stage. All of
// it lives inside <DorkBuilder> — there's no separate recipe-browsing
// section on this page. Framed for authorized/defensive use (assessing your
// own or a client's exposure, or an authorized investigation), matching this
// site's dual-use-tool guidance. Static page.
export const prerender = true;
import { css } from 'styled-system/css';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import DorkBuilder from '../components/DorkBuilder.astro';
import { SEARCH_ENGINES, DORK_OPERATORS, DORK_FOCUSES } from '../data/osint';
import { TOOLS } from '../data/tools';

const osintTools = TOOLS.filter((t) => t.fn === 'OSINT');

const sectionH2 = css({
  display: 'flex',
  alignItems: 'center',
  gap: '0.6rem',
  fontSize: '1.3rem',
  fontWeight: 700,
  mt: '2.5rem',
  mb: '1rem',
  pt: '1.5rem',
  borderTop: '1px solid token(colors.border)',
  scrollMarginTop: '90px', // clear the sticky header when linked to via #<id>
});
const opTable = css({ width: '100%', borderCollapse: 'collapse', fontSize: '0.85rem' });
const opTh = css({ textAlign: 'left', color: 'textMuted', fontFamily: 'sans', fontWeight: 600, fontSize: '0.72rem', textTransform: 'uppercase', letterSpacing: '0.06em', p: '0.5rem 0.7rem', borderBottom: '1px solid token(colors.border)' });
// Kept as a plain object (not a pre-atomized css() call) so the two variant
// cells below can css(opTdBase, variant) — a deep object merge that
// deterministically overrides opTdBase's own color, unlike concatenating two
// independently-atomized class strings (see STYLE_GUIDE.md "Buttons" for the
// exact failure mode this avoids — these two cells were previously composed
// as `${opTd} ${...}`, which left the winning color up to Panda's atomic-
// class ordering: the Syntax column was rendering full-contrast `text`
// instead of the intended `primary` mono styling, purely by chance of
// ordering, and the notes column likewise wasn't reliably muted).
const opTdBase = { p: '0.5rem 0.7rem', borderBottom: '1px solid token(colors.border)', color: 'text' } as const;
const opTd = css(opTdBase);
const opTdCode = css(opTdBase, { fontFamily: 'mono', color: 'primary' });
const opTdNote = css(opTdBase, { color: 'textMuted', fontSize: '0.78rem' });
// Matches DorkBuilder.astro's exactTag exactly — same always-visible, zero-
// interaction "Exact" chip glued onto the phrase operator's syntax fragment,
// here and in the builder's own ingredient badge, so the two stay visually
// consistent (see that file's comment for why the bare quote glyphs alone
// weren't self-evident).
const exactTag = css({
  display: 'inline-block',
  fontFamily: 'sans',
  fontSize: '0.58rem',
  fontWeight: 800,
  textTransform: 'uppercase',
  letterSpacing: '0.04em',
  color: 'accent',
  bg: 'color-mix(in srgb, token(colors.accent) 16%, transparent)',
  borderRadius: 'sm',
  px: '0.3rem',
  py: '0.05rem',
  ml: '0.35rem',
  verticalAlign: 'middle',
});
const toolChipRow = css({ display: 'flex', flexWrap: 'wrap', gap: '0.5rem', mt: '0.75rem' });
const toolChip = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.35rem',
  fontFamily: 'sans',
  fontSize: '0.85rem',
  fontWeight: 600,
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  px: '0.7rem',
  py: '0.4rem',
  transition: 'all 150ms ease',
  _hover: { borderColor: 'primary', color: 'primary' },
});
---

<BaseLayout
  title="OSINT Toolkit"
  description="An interactive search-operator (dork) recipe builder across Google, Bing, and DuckDuckGo — pick a focus, load a preset, and get a ready-to-run query."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'OSINT Toolkit' }]}
    eyebrow="Recon & Discovery"
    title="OSINT Toolkit"
    description="Open-source intelligence, built like a recipe: pick a Focus, fill in the Ingredients, get your Recipe — a ready-to-run search-engine query."
  />

  <aside
    class={css({
      bg: 'bgSubtle',
      border: '1px solid token(colors.border)',
      borderLeftWidth: '3px',
      borderLeftColor: 'primary',
      borderRadius: 'md',
      p: '1rem 1.25rem',
      mb: '1.5rem',
    })}
  >
    <p class={css({ color: 'text', lineHeight: 1.7, fontSize: '0.95rem', m: 0 })}>
      <strong class={css({ color: 'text' })}>OSINT</strong> — <em>open-source intelligence</em> — is
      information gathered from publicly available sources: search engines, DNS, certificate logs,
      code repositories, social platforms. For a defender, the same techniques an attacker uses to
      scope a target double as a fast way to check your own (or an authorized client's) exposure, or
      to verify a claimed identity during an authorized investigation. Everything below is meant for
      infrastructure you own or are authorized to test, and people/organizations you have a
      legitimate reason to research.
    </p>
  </aside>

  <h2 id="builder" class={css({ display: 'flex', alignItems: 'center', gap: '0.6rem', fontSize: '1.3rem', fontWeight: 700, mb: '1rem', scrollMarginTop: '90px' })}>
    <Icon name="search" size={20} class={css({ color: 'primary' })} /> Recipe builder
  </h2>
  <DorkBuilder engines={SEARCH_ENGINES} operators={DORK_OPERATORS} focuses={DORK_FOCUSES} />

  <h2 id="operators" class={sectionH2}>
    <Icon name="list" size={20} class={css({ color: 'primary' })} /> Operator reference
  </h2>
  <div class={css({ overflowX: 'auto' })}>
    <table class={opTable}>
      <thead>
        <tr>
          <th class={opTh}>Operator</th>
          <th class={opTh}>Syntax</th>
          <th class={opTh}>Works on</th>
          <th class={opTh}>What it does</th>
          <th class={opTh}>Cross-engine notes</th>
        </tr>
      </thead>
      <tbody>
        {
          DORK_OPERATORS.map((op) => (
            <tr>
              <td class={opTd}>{op.label}</td>
              <td class={opTdCode}>
                {op.kind === 'phrase' ? '"…"' : op.kind === 'exclude' ? '-term' : op.prefix}
                {op.kind === 'phrase' && <span class={exactTag}>Exact</span>}
              </td>
              <td class={opTd}>
                {op.engines
                  .map((e) => SEARCH_ENGINES.find((s) => s.id === e)?.label ?? e)
                  .join(', ')}
              </td>
              <td class={opTd}>{op.description}</td>
              <td class={opTdNote}>{op.note}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
  <p class={css({ color: 'textMuted', fontSize: '0.78rem', mt: '0.6rem' })}>
    Several long-standing operators (intitle:, inurl:, intext:, OR) are no longer formally documented
    by Google, though still widely reported as functional — the builder and notes above flag this
    distinction rather than presenting undocumented and officially-guaranteed syntax as equivalent.
    Google has fully deprecated several other once-common "dork" operators over the years
    (cache:, related:, info:, the + prefix, the ~ synonym match) — they're intentionally left out.
  </p>

  <h2 id="tools-in-kit" class={sectionH2}>
    <Icon name="wrench" size={20} class={css({ color: 'primary' })} /> OSINT tools in the kit
  </h2>
  <p class={css({ color: 'textMuted', fontSize: '0.9rem' })}>
    Certificate transparency, IP reputation, internet-wide scan data, and more — the toolkit already
    covers several free/open OSINT lookups.
  </p>
  <div class={toolChipRow}>
    {
      osintTools.map((t) => (
        <a href={`/tools/${t.slug}/`} class={toolChip}>
          {t.name}
          <Icon name="link" size={13} class={css({ color: 'textMuted' })} />
        </a>
      ))
    }
  </div>
  <p class={css({ mt: '0.85rem' })}>
    <a href="/tools/?q=osint" class={css({ color: 'primary', display: 'inline-flex', alignItems: 'center', gap: '0.3rem', fontSize: '0.9rem', _hover: { textDecoration: 'underline' } })}>
      See all OSINT tools in the Tool Catalog <Icon name="link" size={13} />
    </a>
  </p>
</BaseLayout>
