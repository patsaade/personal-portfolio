---
// Tools page — free / open-source DFIR toolkit, grouped by the platform a tool
// runs on (Cross-platform, Windows, macOS & Linux, Web). A star marks the tools
// in my day-to-day kit; each card carries a function tag + a cost tag and links to
// its own detail page (/tools/[slug]/). Data lives in src/data/tools.ts. Searchable.
// Static page — prerender to HTML served from the CDN (output: 'server' is on-demand by default).
export const prerender = true;
import { css } from 'styled-system/css';
import { tag } from 'styled-system/recipes';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import CollapseAll from '../components/CollapseAll.astro';
import { TOOL_PLATFORMS, TOTAL_TOOLS, costTone } from '../data/tools';

const platforms = TOOL_PLATFORMS;
const totalTools = TOTAL_TOOLS;

// Each platform is a collapsible <details>. The summary holds the heading; the
// blurb + tool grid live inside, so they fold away (and a search auto-expands them).
const groupDetails = css({ borderTop: '1px solid token(colors.border)', py: '1.25rem' });
const groupSummary = css({
  cursor: 'pointer',
  listStyle: 'none',
  userSelect: 'none',
  '&::-webkit-details-marker': { display: 'none' },
  '&::marker': { display: 'none' },
  _hover: { '& .tools-grp-title': { color: 'primary' } },
});
const groupHead = css({
  display: 'flex',
  alignItems: 'center',
  gap: '0.6rem',
  flexWrap: 'wrap',
  m: 0,
  fontSize: '1.25rem',
  fontWeight: 700,
});
// Chevron points right when closed, rotates down when the parent <details> is open.
const chevCls = css({
  color: 'textMuted',
  flexShrink: 0,
  transition: 'transform 200ms ease',
  'details[open] &': { transform: 'rotate(90deg)' },
});
const grpCount = css({
  fontFamily: 'sans',
  fontSize: '0.78rem',
  fontWeight: 600,
  color: 'textMuted',
  bg: 'bgSubtle',
  border: '1px solid token(colors.border)',
  borderRadius: 'full',
  px: '0.5rem',
  py: '0.05rem',
});
const grpBlurb = css({ color: 'textMuted', fontSize: '0.85rem', mt: '0.5rem', mb: 0 });
// Fluid grid: as many ~230px columns as fit (1 on mobile, up to ~3 at 960px).
const toolsGrid = css({
  display: 'grid',
  gridTemplateColumns: 'repeat(auto-fill, minmax(min(100%, 230px), 1fr))',
  gap: '0.65rem',
  mt: '1rem',
});
const toolCard = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.35rem',
  p: '0.7rem 0.85rem',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  transition: 'border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease',
  _hover: { borderColor: 'primary', transform: 'translateY(-2px)', boxShadow: 'card', '& .tool-go': { transform: 'translateX(2px)', color: 'primary' } },
});
const toolHead = css({ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '0.5rem' });
const toolName = css({ flex: 1, minW: 0, fontFamily: 'sans', fontWeight: 700, fontSize: '0.9rem', color: 'text', lineHeight: 1.3 });
const starCls = css({ display: 'inline', verticalAlign: '-2px', mr: '0.25rem', color: 'accent', fill: 'token(colors.accent)' });
const goCls = css({ color: 'textMuted', flexShrink: 0, transition: 'transform 200ms ease, color 200ms ease' });
const toolUse = css({ color: 'textMuted', fontSize: '0.82rem', lineHeight: 1.45 });
// Function + cost tags sit in a row at the bottom of the card (shared `tag` recipe).
const tagRow = css({ display: 'flex', flexWrap: 'wrap', gap: '0.3rem', mt: 'auto', pt: '0.15rem' });
---

<BaseLayout
  title="Tools"
  description="Free and open-source DFIR tools grouped by platform — Windows, macOS & Linux, cross-platform, and web — each with a function and cost tag and its own reference page."
>
  <PageHeader
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Tools' }]}
    eyebrow="Tooling"
    title="The DFIR toolkit"
    description="Free and open-source tools, grouped by where they run. A star (★) marks what's in my day-to-day kit; each tool links to a short reference page. Tags mark each tool's function and cost."
  />

  {/* Search */}
  <div class={css({ position: 'relative', mb: '0.6rem' })}>
    <span class={css({ position: 'absolute', left: '0.9rem', top: '50%', transform: 'translateY(-50%)', color: 'textMuted', pointerEvents: 'none', display: 'inline-flex' })}>
      <Icon name="search" size={17} />
    </span>
    <input
      id="tools-search"
      type="search"
      autocomplete="off"
      placeholder={`Search ${totalTools} tools…`}
      aria-label="Search the toolkit"
      class={css({
        w: '100%',
        pl: '2.6rem',
        pr: '1rem',
        py: '0.7rem',
        fontSize: '0.95rem',
        bg: 'bgCard',
        color: 'text',
        border: '1px solid token(colors.border)',
        borderRadius: 'md',
        outline: 'none',
        transition: 'border-color 200ms ease',
        _focusVisible: { borderColor: 'primary' },
        _placeholder: { color: 'textMuted' },
      })}
    />
  </div>
  <div class={css({ display: 'flex', alignItems: 'center', gap: '1rem', flexWrap: 'wrap', mb: '0.75rem' })}>
    <p class={css({ color: 'textMuted', fontSize: '0.9rem', m: 0 })}>
      <span id="tools-result-count">{totalTools}</span> free tools across {platforms.length} groups.
    </p>
    <CollapseAll target="[data-tools-group]" />
  </div>

  <div class={css({ display: 'flex', flexDirection: 'column' })}>
    {
      platforms.map((p) => (
        <details data-tools-group open class={groupDetails}>
          <summary class={groupSummary}>
            <h2 class={groupHead}>
              <Icon name="chevron-right" size={18} class={chevCls} />
              <Icon name={p.icon as any} size={20} class={css({ color: 'primary', flexShrink: 0 })} />
              <span class="tools-grp-title">{p.title}</span>
              <span class={grpCount}>{p.tools.length}</span>
            </h2>
          </summary>
          <p class={grpBlurb}>{p.blurb}</p>
          <div class={toolsGrid}>
            {p.tools.map((t) => (
              <a
                href={`/tools/${t.slug}/`}
                class={toolCard}
                data-tools-card={`${t.name} ${t.use} ${t.fn} ${t.cost} ${p.title}`.toLowerCase()}
              >
                <span class={toolHead}>
                  <span class={toolName}>
                    {t.core && (
                      <Icon name="star" size={13} strokeWidth={0} class={starCls} label="In my kit" />
                    )}
                    {t.name}
                  </span>
                  <Icon name="arrow-right" size={14} class={`tool-go ${goCls}`} />
                </span>
                <span class={toolUse}>{t.use}</span>
                <span class={tagRow}>
                  <span class={tag({ tone: 'muted' })}>{t.fn}</span>
                  <span class={tag({ tone: costTone(t.cost) })}>{t.cost}</span>
                </span>
              </a>
            ))}
          </div>
        </details>
      ))
    }
  </div>

  <p id="tools-empty" hidden class={css({ color: 'textMuted', textAlign: 'center', py: '3rem' })}>
    No tools match your search.
  </p>

  <script is:inline>
    (function () {
      var input = document.getElementById('tools-search');
      if (!input) return;
      var cards = Array.prototype.slice.call(document.querySelectorAll('[data-tools-card]'));
      var groups = Array.prototype.slice.call(document.querySelectorAll('[data-tools-group]'));
      var empty = document.getElementById('tools-empty');
      var countEl = document.getElementById('tools-result-count');
      function apply() {
        var q = input.value.trim().toLowerCase();
        var shown = 0;
        for (var i = 0; i < cards.length; i++) {
          var match = !q || cards[i].getAttribute('data-tools-card').indexOf(q) !== -1;
          cards[i].style.display = match ? '' : 'none';
          if (match) shown++;
        }
        for (var g = 0; g < groups.length; g++) {
          var anyVisible = groups[g].querySelector('[data-tools-card]:not([style*="display: none"])');
          groups[g].style.display = anyVisible ? '' : 'none';
          // While searching, expand groups that have a match; restore all when cleared.
          groups[g].open = q ? !!anyVisible : true;
        }
        if (empty) empty.hidden = shown !== 0;
        if (countEl) countEl.textContent = String(shown);
      }
      input.addEventListener('input', apply);
    })();
  </script>
</BaseLayout>
