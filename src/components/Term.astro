---
// Manual glossary-term hover card. Use in MDX prose to give a word a context
// card sourced from the glossary bank:  <Term slug="order-of-volatility">order of volatility</Term>
// The card engine (HoverCards.astro) resolves the slug against /glossary/bank.json
// and shows the term's definition + a link to the full entry.
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<span class="hovercard" data-card-term={slug} tabindex="0" role="button" aria-expanded="false"><slot /></span>
