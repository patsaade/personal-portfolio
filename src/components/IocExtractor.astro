---
// IOC Extractor & Defanger — paste raw text (a log, an alert, a report, an
// email header) and every indicator category (IPv4/IPv6, URLs, domains,
// emails, MD5/SHA1/SHA256/SHA512 hashes, CVE IDs, MITRE ATT&CK IDs, Bitcoin
// addresses) is extracted, deduped, and listed live as you type
// (src/utils/iocs.ts) — with a 3-way As found/Defang/Refang display switch:
// "As found" mirrors how each indicator genuinely appeared in the pasted
// text (defanged if it was pasted defanged, live otherwise — extractIocs()
// tracks this per match via IocMatch.viaRefang), "Defang" always renders the
// safe-for-sharing form, "Refang" always renders the live/usable form. Each
// extracted value is its own button: click one to copy just that indicator (not the whole category) —
// a shared copy-confirm pop (motion.css's [data-copy-pop]) fires on every
// copy action in this tool (per-item, per-category, and copy-all). A
// category card animates in (motion.css's result-card drop-in) the moment
// it gets its first match, rather than snapping into view. Same "Scratch-
// inspired workspace" visual language as the Timestamp Decoder / OSINT
// Crock Pot (corner brackets, dot-grid texture). Genuinely requires JS
// (extraction has no meaningful static fallback), so the workspace stays
// hidden until the script confirms it's running — same JS-armed, no-JS-safe
// philosophy as the site's other builder tools.
import { css } from 'styled-system/css';
import Icon from './Icon.astro';
import WorkspaceShell from './WorkspaceShell.astro';
import { IOC_CATEGORIES } from '../utils/iocs';

const fieldLabel = css({ fontFamily: 'sans', fontSize: '0.68rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.08em', color: 'textMuted', mb: '0.3rem', display: 'block' });
const textarea = css({
  width: '100%',
  minH: '9rem',
  fontFamily: 'mono',
  fontSize: '0.85rem',
  lineHeight: 1.5,
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  px: '0.75rem',
  py: '0.6rem',
  resize: 'vertical',
  overflowY: 'auto',
  overflowX: 'hidden',
  transition: 'border-color 150ms ease',
  _focus: { outline: 'none', borderColor: 'primary' },
  '&::placeholder': { color: 'textMuted', opacity: 0.7 },
});

const controlsRow = css({ display: 'flex', flexWrap: 'wrap', alignItems: 'center', justifyContent: 'space-between', gap: '0.75rem' });
const fangRow = css({ display: 'inline-flex', position: 'relative', zIndex: 0, gap: '0.15rem', p: '0.2rem', bg: 'bgCard', border: '1px solid token(colors.border)', borderRadius: 'md' });
const fangBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  px: '0.7rem',
  py: '0.35rem',
  fontFamily: 'sans',
  fontSize: '0.78rem',
  fontWeight: 600,
  borderRadius: 'sm',
  border: '1px solid transparent',
  bg: 'transparent',
  color: 'textMuted',
  cursor: 'pointer',
  transition: 'all 150ms ease',
  _hover: { color: 'text' },
  '&[data-active]': { bg: 'bgSubtle', color: 'primary', borderColor: 'border', boxShadow: 'card' },
  // Once armed, this button's own bg/border/shadow is suppressed by a
  // hand-written global rule in motion.css (Panda's css() can't express the
  // compound ancestor+self condition needed — see that rule's comment).
});
const actionRow = css({ display: 'flex', gap: '0.5rem', flexWrap: 'wrap' });
// Kept as plain objects (not pre-atomized css() calls) so the primary variant
// below can css(actionBtnBase, primaryBtnBase) — a deep object merge that
// deterministically overrides actionBtnBase's own _hover.color, unlike
// concatenating two independently-atomized class strings (see STYLE_GUIDE.md
// "Buttons" for why that pattern silently broke a hover state elsewhere).
const actionBtnBase = {
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.4rem',
  fontSize: '0.82rem',
  fontFamily: 'sans',
  fontWeight: 600,
  px: '0.7rem',
  py: '0.4rem',
  borderRadius: 'md',
  border: '1px solid token(colors.border)',
  color: 'text',
  cursor: 'pointer',
  bg: 'bgCard',
  transition: 'all 150ms ease',
  _hover: { borderColor: 'primary', color: 'primary' },
} as const;
const primaryBtnBase = { bg: 'primary', color: 'onPrimary', borderColor: 'primary', _hover: { opacity: 0.9, color: 'onPrimary' } } as const;
const actionBtn = css(actionBtnBase);
const primaryActionBtn = css(actionBtnBase, primaryBtnBase);

const summary = css({ color: 'textMuted', fontSize: '0.85rem', m: 0 });
const categoriesGrid = css({ display: 'grid', gridTemplateColumns: { base: '1fr', md: 'repeat(2, 1fr)' }, gap: '0.85rem' });
const categoryCard = css({
  display: 'none',
  flexDirection: 'column',
  gap: '0.5rem',
  p: '0.75rem 0.85rem',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  '&[data-has-matches]': { display: 'flex' },
});
const categoryHead = css({ display: 'flex', alignItems: 'center', gap: '0.5rem' });
const categoryLabel = css({ fontFamily: 'sans', fontSize: '0.82rem', fontWeight: 700, color: 'text' });
const categoryCount = css({ fontFamily: 'sans', fontSize: '0.68rem', fontWeight: 600, color: 'primary', bg: 'color-mix(in srgb, token(colors.primary) 12%, transparent)', border: '1px solid color-mix(in srgb, token(colors.primary) 30%, transparent)', borderRadius: 'full', px: '0.45rem', py: '0.05rem' });
const categoryCopyBtn = css({
  ml: 'auto',
  display: 'inline-flex',
  alignItems: 'center',
  justifyContent: 'center',
  w: '1.75rem',
  h: '1.75rem',
  borderRadius: 'sm',
  border: '1px solid token(colors.border)',
  bg: 'transparent',
  color: 'textMuted',
  cursor: 'pointer',
  transition: 'all 150ms ease',
  _hover: { borderColor: 'primary', color: 'primary' },
});
const categoryList = css({
  listStyle: 'none',
  m: 0,
  p: 0,
  display: 'flex',
  flexDirection: 'column',
  gap: '0.2rem',
  maxH: '9rem',
  overflowY: 'auto',
  fontFamily: 'mono',
  fontSize: '0.76rem',
  color: 'textMuted',
});
const categoryItem = css({ wordBreak: 'break-all' });
const categoryItemBtn = css({
  display: 'block',
  width: '100%',
  textAlign: 'left',
  fontFamily: 'inherit',
  fontSize: 'inherit',
  color: 'inherit',
  bg: 'transparent',
  border: 'none',
  borderRadius: 'sm',
  p: '0.1rem 0.3rem',
  ml: '-0.3rem',
  cursor: 'pointer',
  transition: 'color 150ms ease, background 150ms ease',
  _hover: { color: 'primary', bg: 'color-mix(in srgb, token(colors.primary) 8%, transparent)' },
  '&[data-copied]': { color: 'primary' },
});
---

<WorkspaceShell hook="data-ioc-extractor" noJsMessage="The interactive IOC extractor needs JavaScript enabled.">
    <div>
      <label class={fieldLabel} for="ioc-input">Paste text — a log, an alert, a report, an email header</label>
      <textarea
        id="ioc-input"
        class={textarea}
        rows={8}
        placeholder="Paste raw text here — indicators are extracted live as you type."
        spellcheck="false"
        data-ioc-input
      ></textarea>
    </div>

    <div class={controlsRow}>
      <div class={fangRow} role="radiogroup" aria-label="Indicator display">
        <button type="button" role="radio" aria-checked="true" data-active data-ioc-fang="normal" data-sound="tick" class={fangBtn}>As found</button>
        <button type="button" role="radio" aria-checked="false" data-ioc-fang="defang" data-sound="tick" class={fangBtn}>Defang</button>
        <button type="button" role="radio" aria-checked="false" data-ioc-fang="refang" data-sound="tick" class={fangBtn}>Refang</button>
      </div>
      <div class={actionRow}>
        <button type="button" class={primaryActionBtn} data-ioc-copy-all data-copy-pop data-sound="copy">
          <Icon name="copy" size={14} /> Copy all as JSON
        </button>
        <button type="button" class={actionBtn} data-ioc-clear data-sound="tick">
          <Icon name="x" size={14} /> Clear
        </button>
      </div>
    </div>

    <p class={summary} data-ioc-summary role="status" aria-live="polite">Paste something above to extract indicators.</p>

    <div class={categoriesGrid}>
      {
        IOC_CATEGORIES.map((cat) => (
          <div class={categoryCard} data-ioc-category={cat.id}>
            <div class={categoryHead}>
              <span class={categoryLabel}>{cat.label}</span>
              <span class={categoryCount} data-ioc-count>0</span>
              <button type="button" class={categoryCopyBtn} data-ioc-copy-cat={cat.id} data-copy-pop data-sound="copy" aria-label={`Copy all ${cat.label}`} title="Copy all">
                <Icon name="copy" size={12} />
              </button>
            </div>
            <ul class={categoryList} data-ioc-list />
          </div>
        ))
      }
    </div>
    {/* Cloned per extracted value — keeps the client script free of Panda class-name strings.
        Each value is its own clickable button: click to copy just that one indicator. */}
    <template data-ioc-item-template>
      <li class={categoryItem}>
        <button type="button" class={categoryItemBtn} data-ioc-item-btn data-copy-pop data-sound="copy" title="Click to copy"></button>
      </li>
    </template>
</WorkspaceShell>

<script>
  // @ts-nocheck — vanilla DOM client script
  import { IOC_CATEGORIES, extractIocs, defangValue, refangValue, containsDefanged } from '../utils/iocs';
  import { pop } from '../scripts/copyPop';

  (function () {
    function init() {
      var roots = document.querySelectorAll('[data-ioc-extractor]:not([data-ready])');
      Array.prototype.forEach.call(roots, function (root) {
        var input = root.querySelector('[data-ioc-input]');
        var summaryEl = root.querySelector('[data-ioc-summary]');
        var fangBtns = Array.prototype.slice.call(root.querySelectorAll('[data-ioc-fang]'));
        var copyAllBtn = root.querySelector('[data-ioc-copy-all]');
        var clearBtn = root.querySelector('[data-ioc-clear]');
        var itemTemplate = root.querySelector('[data-ioc-item-template]');
        if (!input || !summaryEl || !itemTemplate) return;

        var cards = IOC_CATEGORIES.map(function (cat) {
          var card = root.querySelector('[data-ioc-category="' + cat.id + '"]');
          return {
            id: cat.id,
            card: card,
            countEl: card ? card.querySelector('[data-ioc-count]') : null,
            listEl: card ? card.querySelector('[data-ioc-list]') : null,
          };
        });

        var fangMode = 'normal'; // 'normal' (as found) | 'defang' | 'refang'
        var lastResult = {};

        // Renders one match per the active fang mode:
        // - refang: the fully live value — match.value already is (extractIocs
        //   only ever records the live form, see iocs.ts), but routed through
        //   refangValue() explicitly so "Refang" always guarantees a live
        //   value even if that assumption ever changes upstream.
        // - defang: always defangValue applied to the canonical value,
        //   regardless of how it was originally pasted.
        // - normal (as found): defanged only if that's genuinely how it
        //   appeared in the pasted text (match.viaRefang), otherwise the
        //   live value untouched. Deliberate best-effort simplification —
        //   this doesn't try to preserve the user's exact original defang
        //   style (hxxp vs [.] vs (dot) etc.), just renders via the same
        //   canonical defangValue output used everywhere else in the tool.
        function displayValue(match, catId) {
          if (fangMode === 'refang') return refangValue(match.value, catId);
          if (fangMode === 'defang') return defangValue(match.value, catId);
          return match.viaRefang ? defangValue(match.value, catId) : match.value;
        }

        function copyText(btn, text) {
          if (!text) return;
          navigator.clipboard.writeText(text).then(function () { pop(btn); }).catch(function () {});
        }

        function renderList(c, matches) {
          if (!c.listEl) return;
          c.listEl.innerHTML = '';
          matches.forEach(function (match) {
            var li = itemTemplate.content.firstElementChild.cloneNode(true);
            var btn = li.querySelector('[data-ioc-item-btn]');
            var text = displayValue(match, c.id);
            btn.textContent = text;
            btn.addEventListener('click', function () { copyText(btn, text); });
            c.listEl.appendChild(li);
          });
        }

        function run() {
          var text = input.value;
          lastResult = extractIocs(text);
          var total = 0;
          cards.forEach(function (c) {
            var matches = lastResult[c.id] || [];
            total += matches.length;
            if (c.countEl) c.countEl.textContent = String(matches.length);
            if (matches.length) c.card.setAttribute('data-has-matches', '');
            else c.card.removeAttribute('data-has-matches');
            renderList(c, matches);
          });
          var defangedNote = containsDefanged(text) ? ' Defanged indicators detected in your input and recognized.' : '';
          if (!text.trim()) {
            summaryEl.textContent = 'Paste something above to extract indicators.';
          } else if (total === 0) {
            summaryEl.textContent = 'No indicators found in the pasted text.' + defangedNote;
          } else {
            summaryEl.textContent = total + ' indicator' + (total === 1 ? '' : 's') + ' found across ' +
              cards.filter(function (c) { return (lastResult[c.id] || []).length > 0; }).length + ' categories.' + defangedNote;
          }
        }

        input.addEventListener('input', run);

        fangBtns.forEach(function (b) {
          b.addEventListener('click', function () {
            fangBtns.forEach(function (o) {
              var active = o === b;
              if (active) o.setAttribute('data-active', ''); else o.removeAttribute('data-active');
              o.setAttribute('aria-checked', String(active));
            });
            fangMode = b.getAttribute('data-ioc-fang');
            cards.forEach(function (c) { renderList(c, lastResult[c.id] || []); });
          });
        });

        cards.forEach(function (c) {
          if (!c.card) return;
          var btn = c.card.querySelector('[data-ioc-copy-cat]');
          if (!btn) return;
          btn.addEventListener('click', function () {
            var matches = lastResult[c.id] || [];
            if (!matches.length) return;
            var text = matches.map(function (match) { return displayValue(match, c.id); }).join('\n');
            copyText(btn, text);
          });
        });

        if (copyAllBtn) {
          copyAllBtn.addEventListener('click', function () {
            var out = {};
            cards.forEach(function (c) {
              var matches = lastResult[c.id] || [];
              out[c.id] = matches.map(function (match) { return displayValue(match, c.id); });
            });
            copyText(copyAllBtn, JSON.stringify(out, null, 2));
          });
        }

        if (clearBtn) {
          clearBtn.addEventListener('click', function () {
            input.value = '';
            run();
            input.focus();
          });
        }

        run();
        root.setAttribute('data-ready', '');
      });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
