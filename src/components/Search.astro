---
// Site-wide search — a ⌘K command palette. Fetches the prerendered
// /search-index.json (posts, labs, glossary terms, key pages) once and filters
// client-side. Opened by the nav trigger ([data-search-trigger]), ⌘K / Ctrl-K, or
// "/"; closed by Esc or backdrop. Arrow keys move, Enter navigates. No dependency.
// Ranking gets a small context-aware nudge from the current page's section (see
// currentContextKind() below) so results feel relevant to where you are — a tie
// break only, never strong enough to bury a better text match from elsewhere.
import { css } from 'styled-system/css';
import Icon from './Icon.astro';
---

<div
  id="search-modal"
  hidden
  class={css({ position: 'fixed', inset: 0, zIndex: 200, display: 'flex', alignItems: 'flex-start', justifyContent: 'center', p: '1rem', pt: { base: '8vh', md: '12vh' } })}
>
  <div data-search-backdrop class={css({ position: 'absolute', inset: 0, bg: 'color-mix(in srgb, black 55%, transparent)', backdropFilter: 'blur(2px)' })}></div>
  <div
    role="dialog"
    aria-modal="true"
    aria-label="Search the site"
    class={css({ position: 'relative', w: '100%', maxW: '560px', bg: 'bgCard', border: '1px solid token(colors.border)', borderRadius: 'lg', boxShadow: 'cardHover', overflow: 'hidden', maxH: '70vh', display: 'flex', flexDirection: 'column' })}
  >
    <div class={css({ display: 'flex', alignItems: 'center', gap: '0.6rem', px: '1rem', borderBottom: '1px solid token(colors.border)' })}>
      <Icon name="search" size={18} class={css({ color: 'textMuted', flexShrink: 0 })} />
      <input
        id="search-input"
        type="search"
        role="combobox"
        autocomplete="off"
        spellcheck="false"
        placeholder="Search posts, labs, terms…"
        aria-label="Search query"
        aria-controls="search-results"
        aria-expanded="false"
        aria-autocomplete="list"
        aria-haspopup="listbox"
        class={css({ flex: 1, py: '0.9rem', bg: 'transparent', color: 'text', border: 'none', outline: 'none', fontSize: '1rem', _placeholder: { color: 'textMuted' } })}
      />
      <kbd class={css({ fontFamily: 'mono', fontSize: '0.7rem', color: 'textMuted', border: '1px solid token(colors.border)', borderRadius: 'sm', px: '0.35rem', py: '0.1rem' })}>Esc</kbd>
    </div>
    <ul id="search-results" role="listbox" aria-label="Search results" class={css({ listStyle: 'none', m: 0, p: '0.4rem', overflowY: 'auto' })}></ul>
    <p id="search-empty" hidden role="status" class={css({ color: 'textMuted', textAlign: 'center', py: '2rem', fontSize: '0.9rem' })}>No matches.</p>
    <p id="search-hint" class={css({ color: 'textMuted', textAlign: 'center', py: '2rem', fontSize: '0.85rem' })}>Search posts, labs, and the glossary.</p>
  </div>
</div>

<script>
  // @ts-nocheck — vanilla DOM client script
  (function () {
    // Show the platform-correct shortcut hint: ⌘K on macOS/iOS, Ctrl K elsewhere.
    try {
      var isMac = /Mac|iPhone|iPad|iPod/.test((navigator.platform || '') + ' ' + (navigator.userAgent || ''));
      if (!isMac) {
        var hints = document.querySelectorAll('[data-cmdk-hint]');
        for (var h = 0; h < hints.length; h++) hints[h].textContent = 'Ctrl K';
      }
    } catch (e) {}

    var modal = document.getElementById('search-modal');
    if (!modal) return;
    var input = document.getElementById('search-input');
    var list = document.getElementById('search-results');
    var empty = document.getElementById('search-empty');
    var hint = document.getElementById('search-hint');
    var data = null, results = [], sel = -1, lastFocused = null;

    function load() {
      if (data) return Promise.resolve(data);
      return fetch('/search-index.json')
        .then(function (r) { return r.ok ? r.json() : []; })
        .then(function (j) { data = Array.isArray(j) ? j : []; return data; })
        .catch(function () { data = []; return data; });
    }
    function isOpen() { return !modal.hidden; }
    // Make the rest of the page inert (out of tab order + a11y tree) while the dialog is open.
    function setInert(on) {
      var els = document.querySelectorAll('header, main, footer');
      for (var i = 0; i < els.length; i++) { if (on) els[i].setAttribute('inert', ''); else els[i].removeAttribute('inert'); }
    }
    function open() {
      if (isOpen()) return;
      lastFocused = document.activeElement;
      modal.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      setInert(true);
      // Focus + reset synchronously so the first keystrokes always land (never gated on the fetch).
      input.value = '';
      render('');
      input.focus();
      if (window.__sound) window.__sound.play('card');
      load().then(function () { render(input.value); });
    }
    function close() {
      modal.hidden = true;
      document.documentElement.style.overflow = '';
      setInert(false);
      input.setAttribute('aria-expanded', 'false');
      input.removeAttribute('aria-activedescendant');
      sel = -1; results = [];
      // Return focus to whatever opened the palette (trigger button or prior element).
      if (lastFocused && lastFocused.focus) { try { lastFocused.focus(); } catch (e) {} }
      lastFocused = null;
    }
    // Kind relevant to the page the palette was opened from, so a tie between two
    // equally-matched results favors what you're already browsing (e.g. opening ⌘K
    // on /tools/ nudges other Tool results above equally-scored Posts/Terms/etc.).
    // A gentle fractional bonus: it only breaks ties, never outranks a stronger
    // text match, so search always stays a reliable, predictable "find anything" tool.
    var KIND_BY_PATH = [
      ['/blog/', 'Post'],
      ['/labs/', 'Lab'],
      ['/glossary/', 'Term'],
      ['/tools/', 'Tool'],
      ['/attack-map/', 'ATT&CK'],
      ['/d3fend/', 'D3FEND'],
    ];
    function currentContextKind() {
      var path = location.pathname;
      for (var i = 0; i < KIND_BY_PATH.length; i++) {
        if (path.indexOf(KIND_BY_PATH[i][0]) === 0) return KIND_BY_PATH[i][1];
      }
      return null;
    }
    function score(e, q, ctxKind) {
      var t = (e.title || '').toLowerCase();
      var s = 0;
      if (t.indexOf(q) === 0) s = 4;
      else if (t.indexOf(q) !== -1) s = 3;
      else if ((e.keywords || '').indexOf(q) !== -1) s = 2;
      else if ((e.desc || '').toLowerCase().indexOf(q) !== -1) s = 1;
      if (s > 0 && ctxKind && e.kind === ctxKind) s += 0.5;
      return s;
    }
    function render(q) {
      q = q.trim().toLowerCase();
      list.innerHTML = '';
      if (!q) {
        hint.hidden = false; empty.hidden = true; results = [];
        input.setAttribute('aria-expanded', 'false');
        input.removeAttribute('aria-activedescendant');
        return;
      }
      hint.hidden = true;
      var ctxKind = currentContextKind();
      results = (data || [])
        .map(function (e) { return { e: e, s: score(e, q, ctxKind) }; })
        .filter(function (o) { return o.s > 0; })
        .sort(function (a, b) { return b.s - a.s; })
        .slice(0, 24)
        .map(function (o) { return o.e; });
      empty.hidden = results.length !== 0;
      input.setAttribute('aria-expanded', results.length ? 'true' : 'false');
      results.forEach(function (e, i) {
        var li = document.createElement('li');
        var a = document.createElement('a');
        a.href = e.url;
        a.className = 'search-opt';
        a.id = 'search-opt-' + i;
        a.setAttribute('role', 'option');
        a.setAttribute('tabindex', '-1');
        a.setAttribute('aria-selected', 'false');
        a.setAttribute('data-i', String(i));
        var kind = document.createElement('span'); kind.className = 'search-opt-kind'; kind.textContent = e.kind || '';
        var main = document.createElement('span'); main.className = 'search-opt-main';
        var title = document.createElement('span'); title.className = 'search-opt-title'; title.textContent = e.title || '';
        var desc = document.createElement('span'); desc.className = 'search-opt-desc'; desc.textContent = e.desc || '';
        main.appendChild(title); main.appendChild(desc);
        a.appendChild(kind); a.appendChild(main);
        a.addEventListener('mousemove', function () { sel = i; paint(); });
        li.appendChild(a); list.appendChild(li);
      });
      sel = results.length ? 0 : -1;
      paint();
    }
    function paint() {
      var opts = list.querySelectorAll('.search-opt');
      for (var i = 0; i < opts.length; i++) {
        if (i === sel) { opts[i].setAttribute('data-active', ''); opts[i].setAttribute('aria-selected', 'true'); opts[i].scrollIntoView({ block: 'nearest' }); }
        else { opts[i].removeAttribute('data-active'); opts[i].setAttribute('aria-selected', 'false'); }
      }
      // Expose the active option to assistive tech (combobox/listbox pattern).
      if (sel >= 0 && opts[sel]) input.setAttribute('aria-activedescendant', opts[sel].id);
      else input.removeAttribute('aria-activedescendant');
    }
    if (input) input.addEventListener('input', function () { render(input.value); });

    document.addEventListener('keydown', function (e) {
      if ((e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey)) { e.preventDefault(); isOpen() ? close() : open(); return; }
      if (e.key === '/' && !isOpen()) {
        var tag = (e.target && e.target.tagName) || '';
        if (!/^(INPUT|TEXTAREA|SELECT)$/.test(tag) && !(e.target && e.target.isContentEditable)) { e.preventDefault(); open(); }
        return;
      }
      if (!isOpen()) return;
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowDown') { e.preventDefault(); if (results.length) { sel = (sel + 1) % results.length; paint(); } }
      else if (e.key === 'ArrowUp') { e.preventDefault(); if (results.length) { sel = (sel - 1 + results.length) % results.length; paint(); } }
      else if (e.key === 'Enter') { if (sel >= 0 && results[sel]) { if (window.__sound) window.__sound.play('nav'); window.location.href = results[sel].url; } }
      // Focus trap: the input is the only tab stop (options are tabindex=-1, driven by arrows).
      else if (e.key === 'Tab') { e.preventDefault(); input.focus(); }
    });
    modal.addEventListener('click', function (e) { if (e.target.closest('[data-search-backdrop]')) close(); });
    document.addEventListener('click', function (e) { var t = e.target.closest('[data-search-trigger]'); if (t) { e.preventDefault(); open(); } });
  })();
</script>
