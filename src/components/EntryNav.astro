---
// Prev / next browse footer for detail pages (MITRE ATT&CK Map, MITRE D3FEND).
// Pass already-resolved {href, label} for each side (or null at the ends).
import { css } from 'styled-system/css';

interface Item {
  href: string;
  label: string;
}
interface Props {
  prev?: Item | null;
  next?: Item | null;
  ariaLabel?: string;
}
const { prev, next, ariaLabel = 'More' } = Astro.props;

const navLink = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.25rem',
  p: '0.85rem 1.1rem',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  bg: 'bgCard',
  transition: 'border-color 200ms ease, transform 200ms ease',
  _hover: { borderColor: 'primary', transform: 'translateY(-2px)' },
});
const navMeta = css({ fontSize: '0.72rem', fontFamily: 'sans', color: 'textMuted' });
const navTitle = css({ fontWeight: 600, fontSize: '0.95rem', lineHeight: 1.3 });
---

<nav
  aria-label={ariaLabel}
  class={css({ display: 'grid', gridTemplateColumns: { base: '1fr', sm: '1fr 1fr' }, gap: '1rem', mt: '3rem', pt: '1.5rem', borderTop: '1px solid token(colors.border)' })}
>
  {prev ? (
    <a href={prev.href} class={navLink}>
      <span class={navMeta}>← Previous</span>
      <span class={navTitle}>{prev.label}</span>
    </a>
  ) : (
    <span />
  )}
  {next ? (
    <a href={next.href} class={`${navLink} ${css({ textAlign: 'right', alignItems: 'flex-end' })}`}>
      <span class={navMeta}>Next →</span>
      <span class={navTitle}>{next.label}</span>
    </a>
  ) : (
    <span />
  )}
</nav>
