---
// Interactive search-operator ("dork") query builder, framed as a recipe: a
// Focus dropdown (the "cuisine style" — what you're trying to find) both
// highlights which Ingredients matter and offers a few named Presets; picking
// a Preset fills those ingredients, and the live-assembled Recipe (the final
// query) appears in the persistent "stage" alongside copy/search/clear —
// sticky on wide viewports, so the result never scrolls out of view while you
// work through the ingredients. A compact, Scratch-inspired "workspace": the
// ingredients render as a vertical timeline of small blocks (a syntax badge +
// input, connected by a rail whose dot lights up once filled), evoking
// Scratch's block palette + stage split restyled in this site's own tokens.
// Genuinely requires JS (there's no meaningful static form without it), so
// the workspace stays hidden until the script confirms it's running — same
// JS-armed, no-JS-safe philosophy as CollapseAll/ViewToggle.
import { css } from 'styled-system/css';
import Icon from './Icon.astro';
import WorkspaceShell from './WorkspaceShell.astro';
import type { SearchEngine, DorkOperator, DorkFocus } from '../data/osint';

interface Props {
  engines: SearchEngine[];
  operators: DorkOperator[];
  focuses: DorkFocus[];
}
const { engines, operators, focuses } = Astro.props;

// The literal syntax fragment shown on each block's badge — matches the
// "Syntax" column on the Operator Reference table below, for consistency.
const syntaxLabel = (op: DorkOperator) =>
  op.kind === 'phrase' ? '"…"' : op.kind === 'exclude' ? '-term' : op.kind === 'or' ? 'OR' : (op.prefix ?? '');

const topRow = css({ display: 'flex', flexWrap: 'wrap', gap: '0.75rem', alignItems: 'flex-end' });
// position:relative + zIndex:0 is the whole retrofit contract for
// src/scripts/animatedSwitch.ts's site-wide sliding-thumb switch (see
// AnimatedSwitch.astro, mounted once in BaseLayout, and CLAUDE.md invariant
// 12) — it auto-wires every role="radiogroup" on the page, including this
// one, with no other change needed here. flexWrap lets the row wrap onto a
// second line instead of overflowing at narrow widths now that it holds four
// engine buttons instead of three.
const engineRow = css({ display: 'inline-flex', flexWrap: 'wrap', gap: '0.15rem', p: '0.2rem', bg: 'bgCard', border: '1px solid token(colors.border)', borderRadius: 'md', alignSelf: 'flex-start', position: 'relative', zIndex: 0 });
const engineBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.4rem',
  px: '0.75rem',
  py: '0.4rem',
  fontFamily: 'sans',
  fontSize: '0.85rem',
  fontWeight: 600,
  borderRadius: 'sm',
  border: '1px solid transparent',
  bg: 'transparent',
  color: 'textMuted',
  cursor: 'pointer',
  transition: 'all 150ms ease',
  _hover: { color: 'text' },
  '&[data-active]': { bg: 'bgSubtle', color: 'primary', borderColor: 'border', boxShadow: 'card' },
  // Once armed, this button's own bg/border/shadow is suppressed by a
  // hand-written global rule in motion.css (Panda's css() can't express the
  // compound ancestor+self condition needed — see that rule's comment).
});

const selectorField = css({ display: 'flex', flexDirection: 'column', gap: '0.3rem', flex: '1 1 200px', minW: '160px' });
const fieldLabel = css({ fontFamily: 'sans', fontSize: '0.68rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.08em', color: 'textMuted' });
const selectInput = css({
  fontFamily: 'sans',
  fontSize: '0.85rem',
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  px: '0.6rem',
  py: '0.45rem',
  cursor: 'pointer',
  transition: 'border-color 150ms ease',
  _focus: { outline: 'none', borderColor: 'primary' },
  '&:disabled': { opacity: 0.5, cursor: 'not-allowed' },
});
const captionBox = css({ display: 'flex', flexDirection: 'column', gap: '0.15rem' });
const caption = css({ fontSize: '0.8rem', color: 'textMuted', lineHeight: 1.5, m: 0, minH: '1.2em' });
const tipCaption = css({ fontSize: '0.76rem', color: 'accent', lineHeight: 1.5, m: 0 });

const paneLabel = css({ fontFamily: 'sans', fontSize: '0.7rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.1em', color: 'textMuted', mb: '0.6rem' });
const workspaceGrid = css({ display: 'grid', gridTemplateColumns: { base: '1fr', lg: 'minmax(0, 1fr) 260px' }, gap: '1.5rem', alignItems: 'start' });

// Vertical "timeline" of ingredient blocks — a rail with a dot per block that
// lights up (primary) once it has a value, and the block itself gets a subtle
// accent tint when the active Focus says it's relevant.
const blockStack = css({ display: 'flex', flexDirection: 'column', gap: '0.4rem', borderLeft: '2px solid token(colors.border)', ml: '0.4rem', pl: '1.1rem' });
const blockRow = css({
  position: 'relative',
  display: 'flex',
  alignItems: 'center',
  gap: '0.6rem',
  py: '0.15rem',
  px: '0.3rem',
  borderRadius: 'sm',
  transition: 'background 150ms ease',
  '&::before': {
    content: '""',
    position: 'absolute',
    left: '-1.5rem',
    top: '50%',
    transform: 'translateY(-50%)',
    w: '8px',
    h: '8px',
    borderRadius: 'full',
    bg: 'border',
    transition: 'background 150ms ease',
  },
  '&[data-filled]::before': { bg: 'primary' },
  '&[data-highlighted]': { bg: 'color-mix(in srgb, token(colors.accent) 9%, transparent)' },
});
const blockBadge = css({
  flexShrink: 0,
  minW: '4.6rem',
  textAlign: 'right',
  fontFamily: 'mono',
  fontSize: '0.74rem',
  fontWeight: 700,
  color: 'primary',
  whiteSpace: 'nowrap',
});
// A small always-visible "Exact" chip glued onto the phrase operator's badge
// (and the matching Operator Reference table cell in osint.astro) — the bare
// quote glyphs alone read ambiguously at a glance, unlike every other
// operator's badge (-term, OR, site:, ...), which is already self-evident.
// Zero-interaction fix: no title/hover needed, matches this badge's existing
// aria-hidden treatment (the input's own aria-label already carries the
// operator name for screen readers).
const exactTag = css({
  display: 'inline-block',
  fontFamily: 'sans',
  fontSize: '0.58rem',
  fontWeight: 800,
  textTransform: 'uppercase',
  letterSpacing: '0.04em',
  color: 'accent',
  bg: 'color-mix(in srgb, token(colors.accent) 16%, transparent)',
  borderRadius: 'sm',
  px: '0.3rem',
  py: '0.05rem',
  ml: '0.35rem',
  verticalAlign: 'middle',
});
const blockInput = css({
  flex: 1,
  minW: 0,
  fontFamily: 'mono',
  fontSize: '0.84rem',
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  px: '0.6rem',
  py: '0.4rem',
  transition: 'border-color 150ms ease',
  _focus: { outline: 'none', borderColor: 'primary' },
  '&::placeholder': { color: 'textMuted', opacity: 0.7 },
});

const stage = css({
  display: 'flex',
  flexDirection: 'column',
  gap: '0.6rem',
  position: { lg: 'sticky' },
  top: { lg: '90px' },
});
const outputBox = css({
  m: 0,
  p: '0.75rem 0.9rem',
  fontFamily: 'mono',
  fontSize: '0.85rem',
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  overflowX: 'auto',
  whiteSpace: 'pre-wrap',
  wordBreak: 'break-word',
  minH: '4.5rem',
});
const actionCol = css({ display: 'flex', flexDirection: 'column', gap: '0.5rem' });
// Kept as plain objects (not pre-atomized css() calls) so the primary variant
// below can css(actionBtnBase, primaryBtnBase) — a deep object merge that
// deterministically overrides actionBtnBase's own _hover.color, unlike
// concatenating two independently-atomized class strings (see STYLE_GUIDE.md
// "Buttons" for why that pattern silently broke a hover state elsewhere).
const actionBtnBase = {
  display: 'inline-flex',
  alignItems: 'center',
  justifyContent: 'center',
  gap: '0.4rem',
  fontSize: '0.85rem',
  fontFamily: 'sans',
  fontWeight: 600,
  px: '0.8rem',
  py: '0.5rem',
  borderRadius: 'md',
  border: '1px solid token(colors.border)',
  color: 'text',
  cursor: 'pointer',
  bg: 'bgCard',
  transition: 'all 150ms ease',
  _hover: { borderColor: 'primary', color: 'primary' },
} as const;
const primaryBtnBase = {
  bg: 'primary',
  color: 'onPrimary',
  borderColor: 'primary',
  _hover: { opacity: 0.9, color: 'onPrimary' },
} as const;
const actionBtn = css(actionBtnBase);
const primaryActionBtn = css(actionBtnBase, primaryBtnBase);
---

<WorkspaceShell
  hook="data-dork-builder"
  noJsMessage="The interactive recipe builder needs JavaScript enabled."
  attrs={{ 'data-dork-engines': JSON.stringify(engines), 'data-dork-focuses': JSON.stringify(focuses) }}
>
    <div class={topRow}>
      <div class={engineRow} role="radiogroup" aria-label="Search engine">
        {
          engines.map((e, i) => (
            <button type="button" role="radio" aria-checked={i === 0 ? 'true' : 'false'} {...(i === 0 ? { 'data-active': true } : {})} data-engine-btn={e.id} data-sound="tick" class={engineBtn}>
              {e.label}
            </button>
          ))
        }
      </div>

      <div class={selectorField}>
        <label class={fieldLabel} for="dork-focus">Focus</label>
        <select id="dork-focus" class={selectInput} data-dork-focus>
          <option value="">— Manual (no focus) —</option>
          {focuses.map((f) => <option value={f.id}>{f.label}</option>)}
        </select>
      </div>

      <div class={selectorField}>
        <label class={fieldLabel} for="dork-preset">Preset</label>
        <select id="dork-preset" class={selectInput} data-dork-preset disabled>
          <option value="">— Pick a focus first —</option>
        </select>
      </div>
    </div>

    <div class={captionBox}>
      <p class={caption} data-dork-caption role="status" aria-live="polite"></p>
      <p class={tipCaption} data-dork-tip hidden></p>
    </div>

    <div class={workspaceGrid}>
      <div>
        <p class={paneLabel}>Ingredients</p>
        <div class={blockStack}>
          {
            operators.map((op) => (
              <div class={blockRow} data-dork-field-wrap data-engines={op.engines.join(' ')}>
                <span class={blockBadge} aria-hidden="true">
                  {syntaxLabel(op)}
                  {op.kind === 'phrase' && <span class={exactTag}>Exact</span>}
                </span>
                <input
                  id={`dork-${op.id}`}
                  type="text"
                  class={blockInput}
                  placeholder={op.placeholder}
                  aria-label={op.label}
                  title={op.description}
                  data-dork-field={op.id}
                  data-kind={op.kind}
                  data-prefix={op.prefix ?? ''}
                  autocomplete="off"
                />
              </div>
            ))
          }
        </div>
      </div>

      <div class={stage}>
        <p class={paneLabel}>Recipe</p>
        <pre class={outputBox}><code data-dork-output>&nbsp;</code></pre>
        <div class={actionCol}>
          <button type="button" class={primaryActionBtn} data-dork-copy data-sound="copy">
            <Icon name="copy" size={15} /> Copy
          </button>
          <a class={actionBtn} data-dork-search href="#" target="_blank" rel="noopener" data-sound="tick">
            <Icon name="search" size={15} /> Search <span data-dork-engine-label>Google</span>
          </a>
          <button type="button" class={actionBtn} data-dork-clear data-sound="tick">
            <Icon name="x" size={15} /> Clear
          </button>
        </div>
      </div>
    </div>
</WorkspaceShell>

<script>
  // @ts-nocheck — vanilla DOM client script
  (function () {
    function init() {
      var roots = document.querySelectorAll('[data-dork-builder]:not([data-ready])');
      Array.prototype.forEach.call(roots, function (root) {
        var engineBtns = Array.prototype.slice.call(root.querySelectorAll('[data-engine-btn]'));
        var fieldWraps = Array.prototype.slice.call(root.querySelectorAll('[data-dork-field-wrap]'));
        var fields = fieldWraps.map(function (wrap) {
          return {
            wrap: wrap,
            input: wrap.querySelector('[data-dork-field]'),
            engines: (wrap.getAttribute('data-engines') || '').split(' ').filter(Boolean),
          };
        });
        var output = root.querySelector('[data-dork-output]');
        var copyBtn = root.querySelector('[data-dork-copy]');
        var searchLink = root.querySelector('[data-dork-search]');
        var engineLabel = root.querySelector('[data-dork-engine-label]');
        var clearBtn = root.querySelector('[data-dork-clear]');
        var focusSelect = root.querySelector('[data-dork-focus]');
        var presetSelect = root.querySelector('[data-dork-preset]');
        var captionEl = root.querySelector('[data-dork-caption]');
        var tipEl = root.querySelector('[data-dork-tip]');
        if (!output || !copyBtn || !searchLink || !engineLabel || !clearBtn || !focusSelect || !presetSelect) return;

        var engines = [];
        try { engines = JSON.parse(root.getAttribute('data-dork-engines') || '[]'); } catch (e) { engines = []; }
        var focuses = [];
        try { focuses = JSON.parse(root.getAttribute('data-dork-focuses') || '[]'); } catch (e) { focuses = []; }
        var currentEngine = (engines[0] && engines[0].id) || 'google';

        function getFocus(id) {
          for (var i = 0; i < focuses.length; i++) if (focuses[i].id === id) return focuses[i];
          return null;
        }

        function fragmentFor(f) {
          var val = f.input.value.trim();
          if (!val) return '';
          var kind = f.input.getAttribute('data-kind');
          var prefix = f.input.getAttribute('data-prefix') || '';
          if (kind === 'phrase') return '"' + val + '"';
          if (kind === 'exclude') {
            return val.split(/\s+/).filter(Boolean).map(function (t) { return '-' + t; }).join(' ');
          }
          if (kind === 'or') {
            return val.split(/\s+/).filter(Boolean).join(' OR ');
          }
          // Prefix-kind fields (site:, filetype:, intitle:, ...) accept one or
          // several alternatives written as "termA OR termB" — expand that into
          // the correctly parenthesized, per-term-prefixed syntax; a single
          // multi-word value still just gets quoted so the operator applies to
          // the whole phrase rather than only its first word.
          var alts = val.split(/\s+OR\s+/i).map(function (t) { return t.trim(); }).filter(Boolean);
          function quoteIfMultiWord(t) { return t.indexOf(' ') !== -1 ? '"' + t + '"' : t; }
          if (alts.length > 1) {
            return '(' + alts.map(function (t) { return prefix + quoteIfMultiWord(t); }).join(' OR ') + ')';
          }
          return prefix + quoteIfMultiWord(val);
        }

        function buildQuery() {
          var parts = [];
          fields.forEach(function (f) {
            if (f.engines.indexOf(currentEngine) === -1) return;
            var frag = fragmentFor(f);
            if (frag) parts.push(frag);
          });
          return parts.join(' ');
        }

        function engineById(id) {
          for (var i = 0; i < engines.length; i++) if (engines[i].id === id) return engines[i];
          return engines[0];
        }

        function render() {
          var query = buildQuery();
          output.textContent = query || ' ';
          var eng = engineById(currentEngine);
          searchLink.href = query ? eng.searchUrl + encodeURIComponent(query) : '#';
          engineLabel.textContent = eng.label;
          // Light up each block's timeline dot once it has a value, so the
          // stack visually shows which ingredients are contributing right now.
          fields.forEach(function (f) {
            if (f.input.value.trim()) f.wrap.setAttribute('data-filled', '');
            else f.wrap.removeAttribute('data-filled');
          });
        }

        function setEngine(id) {
          currentEngine = id;
          engineBtns.forEach(function (b) {
            var active = b.getAttribute('data-engine-btn') === id;
            if (active) b.setAttribute('data-active', '');
            else b.removeAttribute('data-active');
            b.setAttribute('aria-checked', String(active));
          });
          fieldWraps.forEach(function (wrap, i) {
            var supported = fields[i].engines.indexOf(id) !== -1;
            wrap.hidden = !supported;
          });
          render();
        }

        function applyHighlight(focus) {
          var set = focus ? focus.highlight : [];
          fields.forEach(function (f) {
            var id = f.input.getAttribute('data-dork-field');
            if (set.indexOf(id) !== -1) f.wrap.setAttribute('data-highlighted', '');
            else f.wrap.removeAttribute('data-highlighted');
          });
        }

        function updateCaption() {
          var focus = getFocus(focusSelect.value);
          if (!focus) {
            if (captionEl) captionEl.textContent = '';
            if (tipEl) tipEl.hidden = true;
            return;
          }
          var preset = presetSelect.value !== '' ? focus.presets[Number(presetSelect.value)] : null;
          if (captionEl) captionEl.textContent = preset ? preset.desc : focus.desc;
          if (tipEl) {
            if (!preset && focus.tip) { tipEl.textContent = focus.tip; tipEl.hidden = false; }
            else tipEl.hidden = true;
          }
        }

        function populatePresets(focus) {
          presetSelect.innerHTML = '';
          var placeholder = document.createElement('option');
          placeholder.value = '';
          placeholder.textContent = focus ? '— Choose a preset —' : '— Pick a focus first —';
          presetSelect.appendChild(placeholder);
          (focus ? focus.presets : []).forEach(function (p, i) {
            var opt = document.createElement('option');
            opt.value = String(i);
            opt.textContent = p.title;
            presetSelect.appendChild(opt);
          });
          presetSelect.disabled = !focus;
        }

        focusSelect.addEventListener('change', function () {
          var focus = getFocus(focusSelect.value);
          populatePresets(focus);
          applyHighlight(focus);
          updateCaption();
        });

        presetSelect.addEventListener('change', function () {
          var focus = getFocus(focusSelect.value);
          updateCaption();
          if (!focus || presetSelect.value === '') return;
          var preset = focus.presets[Number(presetSelect.value)];
          if (!preset) return;
          setEngine('google');
          fields.forEach(function (f) {
            var id = f.input.getAttribute('data-dork-field');
            if (Object.prototype.hasOwnProperty.call(preset.values, id)) {
              f.input.value = preset.values[id];
            } else if (id !== 'site') {
              // Reset every non-domain field not supplied by this preset, so a
              // previously loaded preset can't silently blend into this one.
              f.input.value = '';
            }
            // A field named 'site' that the preset does NOT specify keeps
            // whatever the user already typed as their own target domain.
          });
          render();
        });

        engineBtns.forEach(function (b) {
          b.addEventListener('click', function () { setEngine(b.getAttribute('data-engine-btn')); });
        });
        fields.forEach(function (f) { f.input.addEventListener('input', render); });

        var status = document.createElement('div');
        status.setAttribute('role', 'status');
        status.setAttribute('aria-live', 'polite');
        status.style.cssText = 'position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;';
        document.body.appendChild(status);

        copyBtn.addEventListener('click', function () {
          var text = output.textContent || '';
          if (!text.trim()) return;
          navigator.clipboard.writeText(text).then(function () {
            status.textContent = 'Recipe copied to clipboard';
            setTimeout(function () { status.textContent = ''; }, 1600);
          }).catch(function () {});
        });

        clearBtn.addEventListener('click', function () {
          fields.forEach(function (f) { f.input.value = ''; });
          render();
        });

        setEngine(currentEngine);
        root.setAttribute('data-ready', '');
      });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
