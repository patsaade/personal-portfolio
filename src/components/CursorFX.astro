---
// Retro custom cursor — implemented with the browser's NATIVE `cursor` property
// (SVG data-URIs), not a JS follower. The OS renders it, so it always shows with
// no lag, flash, or follower gap, for every state. Enforced with `* { cursor:
// inherit }` so no element falls back to an OS cursor; specific rules then set the
// pointer (hand), text (I-beam) and disabled (not-allowed) states. Cream fill +
// brown outline keeps it visible on every theme (light and dark). Fine-pointer
// (mouse) only — touch devices have no cursor. No dependency, no script.
---

<style is:global>
  @media (hover: hover) and (pointer: fine) {
    /* Nothing inherits an OS cursor; everything uses the custom set below. */
    *,
    *::before,
    *::after {
      cursor: inherit;
    }

    /* Default — retro arrow. */
    html {
      cursor: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20width%3D'20'%20height%3D'20'%20viewBox%3D'0%200%2020%2020'%20shape-rendering%3D'crispEdges'%3E%3Cpath%20d%3D'M2%201%20L2%2014%20L5.5%2011%20L7.6%2015.6%20L9.7%2014.7%20L7.6%2010.3%20L12.6%2010.3%20Z'%20fill%3D'%23efe6d6'%20stroke%3D'%233a302b'%20stroke-width%3D'1.3'%20stroke-linejoin%3D'miter'%2F%3E%3C%2Fsvg%3E") 2 1, auto;
    }

    /* Pointer — retro hand, over anything clickable. */
    a, button, summary, label, select,
    [role='button'], .hovercard, .copy-btn, [data-search-trigger], [data-sound-toggle],
    input[type='submit'], input[type='button'], input[type='checkbox'], input[type='radio'] {
      cursor: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20width%3D'20'%20height%3D'20'%20viewBox%3D'0%200%2020%2020'%20shape-rendering%3D'crispEdges'%3E%3Cpath%20d%3D'M6%202%20L8%202%20L8%208.5%20L9.5%208.5%20L9.5%207.5%20L11%207.5%20L11%208.5%20L12.5%208.5%20L12.5%208%20L14%208%20L14%209.5%20L15%209.5%20L15%2015%20L13.5%2018%20L8.5%2018%20L6%2015.5%20L4.5%2012.5%20L4.5%2011%20L6%2011%20Z'%20fill%3D'%23efe6d6'%20stroke%3D'%233a302b'%20stroke-width%3D'1.2'%20stroke-linejoin%3D'round'%2F%3E%3C%2Fsvg%3E") 7 2, pointer;
    }

    /* Text — I-beam, over editable + prose text. */
    input[type='text'], input[type='search'], input[type='email'], input[type='password'],
    input[type='url'], input[type='tel'], input[type='number'], textarea, [contenteditable='true'],
    p, li, blockquote, code, pre, dd, dt, figcaption, td, th {
      cursor: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20width%3D'20'%20height%3D'20'%20viewBox%3D'0%200%2020%2020'%20shape-rendering%3D'crispEdges'%3E%3Cpath%20d%3D'M6.5%202.5%20H13.5%20V4.5%20H11%20V15.5%20H13.5%20V17.5%20H6.5%20V15.5%20H9%20V4.5%20H6.5%20Z'%20fill%3D'%23efe6d6'%20stroke%3D'%233a302b'%20stroke-width%3D'1.1'%2F%3E%3C%2Fsvg%3E") 10 10, text;
    }

    /* Disabled — not-allowed, wins over the pointer rule via higher specificity. */
    [disabled], [aria-disabled='true'], button:disabled, input:disabled, a[aria-disabled='true'] {
      cursor: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20width%3D'20'%20height%3D'20'%20viewBox%3D'0%200%2020%2020'%20shape-rendering%3D'crispEdges'%3E%3Ccircle%20cx%3D'10'%20cy%3D'10'%20r%3D'7.6'%20fill%3D'%23efe6d6'%20stroke%3D'%233a302b'%20stroke-width%3D'1.4'%2F%3E%3Ccircle%20cx%3D'10'%20cy%3D'10'%20r%3D'5'%20fill%3D'none'%20stroke%3D'%233a302b'%20stroke-width%3D'1.8'%2F%3E%3Cline%20x1%3D'6.4'%20y1%3D'6.4'%20x2%3D'13.6'%20y2%3D'13.6'%20stroke%3D'%233a302b'%20stroke-width%3D'1.8'%2F%3E%3C%2Fsvg%3E") 10 10, not-allowed;
    }
  }
</style>
