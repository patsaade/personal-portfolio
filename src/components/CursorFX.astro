---
// Custom retro cursor — a hand-built, dependency-free morphing cursor (no package;
// the well-known ones are framework-bound and heavier than this). A fixed overlay
// follows the pointer with a light lerp and morphs between states (idle reticle →
// hand → I-beam → "?" → blocked), firing a star-shine "pop" on click. Cream fill +
// brown outline is the site's retro design language, legible on every theme.
//
// Progressive enhancement: the OS cursor is hidden ONLY once the script arms (it
// adds `cursorfx-on` to <html>), so no-JS, touch, and reduced-motion visitors keep
// the native cursor untouched — the custom one is a fine-pointer, motion-OK delight.
//
// Hotspots: each glyph is offset by left/top = −hotspot so its active point sits at
// the container origin (the pointer); transform-origin matches so the scale-morph
// keeps that point fixed.
---

<div id="cursorfx" hidden aria-hidden="true">
  <div class="cfx-inner">
    <svg class="cfx-glyph" data-glyph="idle" width="20" height="20" viewBox="0 0 20 20" style="left:-10px;top:-10px;transform-origin:10px 10px">
      <circle cx="10" cy="10" r="4" fill="#efe6d6" stroke="#3a302b" stroke-width="1.4" />
      <circle cx="10" cy="10" r="1.1" fill="#3a302b" />
    </svg>
    <svg class="cfx-glyph" data-glyph="pointer" width="20" height="20" viewBox="0 0 20 20" shape-rendering="crispEdges" style="left:-7px;top:-2px;transform-origin:7px 2px">
      <path d="M6 2 L8 2 L8 8.5 L9.5 8.5 L9.5 7.5 L11 7.5 L11 8.5 L12.5 8.5 L12.5 8 L14 8 L14 9.5 L15 9.5 L15 15 L13.5 18 L8.5 18 L6 15.5 L4.5 12.5 L4.5 11 L6 11 Z" fill="#efe6d6" stroke="#3a302b" stroke-width="1.2" stroke-linejoin="round" />
    </svg>
    <svg class="cfx-glyph" data-glyph="text" width="20" height="20" viewBox="0 0 20 20" shape-rendering="crispEdges" style="left:-10px;top:-10px;transform-origin:10px 10px">
      <path d="M6.5 2.5 H13.5 V4.5 H11 V15.5 H13.5 V17.5 H6.5 V15.5 H9 V4.5 H6.5 Z" fill="#efe6d6" stroke="#3a302b" stroke-width="1.1" />
    </svg>
    <svg class="cfx-glyph" data-glyph="help" width="20" height="20" viewBox="0 0 20 20" style="left:-2px;top:-1px;transform-origin:2px 1px">
      <path d="M2 1 L2 14 L5.5 11 L7.6 15.6 L9.7 14.7 L7.6 10.3 L12.6 10.3 Z" fill="#efe6d6" stroke="#3a302b" stroke-width="1.3" stroke-linejoin="miter" />
      <path d="M12.8 11.6 Q12.8 9.4 15 9.4 Q17.2 9.4 17.2 11.6 Q17.2 13.3 15 13.9 L15 15.2" fill="none" stroke="#efe6d6" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
      <line x1="15" y1="17.2" x2="15" y2="17.2" stroke="#efe6d6" stroke-width="3.2" stroke-linecap="round" />
      <path d="M12.8 11.6 Q12.8 9.4 15 9.4 Q17.2 9.4 17.2 11.6 Q17.2 13.3 15 13.9 L15 15.2" fill="none" stroke="#3a302b" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      <line x1="15" y1="17.2" x2="15" y2="17.2" stroke="#3a302b" stroke-width="1.9" stroke-linecap="round" />
    </svg>
    <svg class="cfx-glyph" data-glyph="disabled" width="20" height="20" viewBox="0 0 20 20" style="left:-10px;top:-10px;transform-origin:10px 10px">
      <circle cx="10" cy="10" r="7.6" fill="#efe6d6" stroke="#3a302b" stroke-width="1.4" />
      <circle cx="10" cy="10" r="5" fill="none" stroke="#3a302b" stroke-width="1.8" />
      <line x1="6.4" y1="6.4" x2="13.6" y2="13.6" stroke="#3a302b" stroke-width="1.8" />
    </svg>
    <svg class="cfx-pop" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true" style="left:-10px;top:-10px;transform-origin:10px 10px">
      <path d="M10 2 L11.4 8.6 L18 10 L11.4 11.4 L10 18 L8.6 11.4 L2 10 L8.6 8.6 Z" fill="#efe6d6" stroke="#3a302b" stroke-width="0.9" />
    </svg>
  </div>
</div>

<style is:global>
  /* Hide the OS cursor only when JS has armed the custom one (progressive). */
  html.cursorfx-on,
  html.cursorfx-on * {
    cursor: none !important;
  }

  #cursorfx {
    position: fixed;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    will-change: transform;
  }

  /* Inner layer carries the press scale, around the pointer (origin 0,0). */
  #cursorfx .cfx-inner {
    position: absolute;
    top: 0;
    left: 0;
    transform: scale(1);
    transform-origin: 0 0;
    transition: transform 0.12s ease;
  }
  #cursorfx.is-down .cfx-inner {
    transform: scale(0.84);
  }

  /* Glyphs stack; only the active state's glyph is shown, the rest morph away. */
  #cursorfx .cfx-glyph {
    position: absolute;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.14s ease, transform 0.14s ease;
    will-change: opacity, transform;
  }
  #cursorfx[data-state='idle'] .cfx-glyph[data-glyph='idle'],
  #cursorfx[data-state='pointer'] .cfx-glyph[data-glyph='pointer'],
  #cursorfx[data-state='text'] .cfx-glyph[data-glyph='text'],
  #cursorfx[data-state='help'] .cfx-glyph[data-glyph='help'],
  #cursorfx[data-state='disabled'] .cfx-glyph[data-glyph='disabled'] {
    opacity: 1;
    transform: scale(1);
  }

  /* Star-shine pop on click. */
  #cursorfx .cfx-pop {
    position: absolute;
    opacity: 0;
    transform: scale(0.3);
    pointer-events: none;
  }
  #cursorfx .cfx-pop.cfx-burst {
    animation: cfx-pop 0.42s ease-out;
  }
  @keyframes cfx-pop {
    0% {
      opacity: 1;
      transform: scale(0.3) rotate(0deg);
    }
    100% {
      opacity: 0;
      transform: scale(1.7) rotate(50deg);
    }
  }
</style>

<script>
  // @ts-nocheck
  (function () {
    var fine = window.matchMedia && window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var el = document.getElementById('cursorfx');
    // No-JS / touch / reduced-motion → leave the native OS cursor in place.
    if (!el || !fine || reduce) return;

    document.documentElement.classList.add('cursorfx-on');
    el.hidden = false;
    var pop = el.querySelector('.cfx-pop');

    // State selectors, checked in priority order (most specific first).
    var DISABLED = '[disabled],[aria-disabled="true"],button:disabled,input:disabled,a[aria-disabled="true"]';
    var HELP = '.hovercard';
    var POINTER =
      'a,button,summary,label,select,[role="button"],.copy-btn,[data-search-trigger],[data-sound-toggle],' +
      'input[type="submit"],input[type="button"],input[type="checkbox"],input[type="radio"]';
    var TEXT =
      'input[type="text"],input[type="search"],input[type="email"],input[type="password"],input[type="url"],' +
      'input[type="tel"],input[type="number"],textarea,[contenteditable="true"],p,li,blockquote,code,pre,dd,dt,figcaption,td,th';

    function stateFor(t) {
      if (!t || !t.closest) return 'idle';
      if (t.closest(DISABLED)) return 'disabled';
      if (t.closest(HELP)) return 'help';
      if (t.closest(POINTER)) return 'pointer';
      if (t.closest(TEXT)) return 'text';
      return 'idle';
    }

    var tx = window.innerWidth / 2,
      ty = window.innerHeight / 2;
    var cx = tx,
      cy = ty;
    var raf = null,
      shown = false;

    function loop() {
      cx += (tx - cx) * 0.35;
      cy += (ty - cy) * 0.35;
      var arrived = Math.abs(tx - cx) < 0.1 && Math.abs(ty - cy) < 0.1;
      if (arrived) {
        cx = tx;
        cy = ty;
      }
      el.style.transform = 'translate(' + cx + 'px,' + cy + 'px)';
      raf = arrived ? null : requestAnimationFrame(loop);
    }
    function kick() {
      if (raf === null) raf = requestAnimationFrame(loop);
    }

    function onMove(e) {
      if (e.pointerType && e.pointerType !== 'mouse') return;
      tx = e.clientX;
      ty = e.clientY;
      if (!shown) {
        shown = true;
        el.style.opacity = '1';
      }
      el.setAttribute('data-state', stateFor(e.target));
      kick();
    }

    document.addEventListener('pointermove', onMove, { passive: true });
    document.addEventListener(
      'pointerover',
      function (e) {
        if (e.pointerType && e.pointerType !== 'mouse') return;
        el.setAttribute('data-state', stateFor(e.target));
      },
      { passive: true },
    );
    document.addEventListener(
      'pointerdown',
      function (e) {
        if (e.pointerType && e.pointerType !== 'mouse') return;
        el.classList.add('is-down');
        if (pop) {
          pop.classList.remove('cfx-burst');
          void pop.offsetWidth; // reflow so the animation can retrigger
          pop.classList.add('cfx-burst');
        }
      },
      { passive: true },
    );
    document.addEventListener('pointerup', function () { el.classList.remove('is-down'); }, { passive: true });
    window.addEventListener('blur', function () { el.classList.remove('is-down'); });
    // Fade out when the pointer leaves the window, back in on return.
    document.addEventListener('mouseleave', function () { shown = false; el.style.opacity = '0'; });
    document.addEventListener('mouseenter', function () { shown = true; el.style.opacity = '1'; });
  })();
</script>
