---
// Full retro custom-cursor system.
//
// - Hides the OS cursor entirely on fine-pointer (mouse) devices and replaces it
//   with a pixel cursor that follows the pointer — so the native cursor is never
//   revealed in any state.
// - Covers every real cursor state: default (arrow), pointer (hand, for links /
//   buttons / hover-card terms), text (I-beam, over inputs + prose), and disabled
//   (not-allowed).
// - Theme-matched: the cursor is filled with the active theme's text color and
//   outlined with its background color (via CSS tokens), so it adapts to whatever
//   palette + light/dark mode is selected. A star-shine glow (theme primary)
//   brightens over interactive targets.
//
// Safety: the OS cursor is hidden only AFTER the follower has positioned itself on
// the first mouse move (via the .cursorfx-on class), so if the script never runs or
// errors first, the native cursor stays. Everything is gated to fine pointers and
// try/caught. Touch/coarse pointers keep their normal (absent) cursor.
---

<div id="cursorfx" data-state="default" aria-hidden="true">
  <span class="cfx-shine"></span>
  <svg class="cfx cfx-default" viewBox="0 0 24 24" width="20" height="20"><path d="M3 2 L3 17 L7 13.5 L9.6 19 L11.8 18 L9.2 12.8 L15 12.8 Z" /></svg>
  <svg class="cfx cfx-pointer" viewBox="0 0 24 24" width="20" height="20"><path d="M9.5 3 L11.5 3 L11.5 10 L13 10 L13 9 L14.5 9 L14.5 10 L16 10 L16 10.5 L17.5 10.5 L17.5 16.5 L16.5 19 L14.5 21 L10 21 L7 18.5 L5.5 15.5 L5 13 L5 11.5 L6.5 11.5 L7.5 13 L9.5 13 Z" /></svg>
  <svg class="cfx cfx-text" viewBox="0 0 24 24" width="20" height="20"><path d="M8 3 H16 V5 H13 V19 H16 V21 H8 V19 H11 V5 H8 Z" /></svg>
  <svg class="cfx cfx-disabled" viewBox="0 0 24 24" width="20" height="20">
    <path fill-rule="evenodd" d="M12 2 A10 10 0 1 0 12.01 2 Z M12 5 A7 7 0 1 1 11.99 5 Z" />
    <rect x="10.4" y="2.5" width="3.2" height="19" transform="rotate(45 12 12)" />
  </svg>
</div>

<style is:global>
  /* Hide the OS cursor everywhere once the custom cursor is confirmed tracking. */
  @media (hover: hover) and (pointer: fine) {
    html.cursorfx-on,
    html.cursorfx-on * {
      cursor: none !important;
    }
  }

  #cursorfx {
    position: fixed;
    left: 0;
    top: 0;
    width: 0;
    height: 0;
    z-index: 10000;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
    will-change: transform;
  }
  /* Each state SVG: filled with the theme text color, outlined with the theme bg
     color via a crisp 4-direction drop-shadow, so it reads on any background. */
  #cursorfx .cfx {
    position: absolute;
    display: none;
    fill: var(--colors-text);
    shape-rendering: crispEdges;
    filter:
      drop-shadow(1px 0 0 var(--colors-bg)) drop-shadow(-1px 0 0 var(--colors-bg))
      drop-shadow(0 1px 0 var(--colors-bg)) drop-shadow(0 -1px 0 var(--colors-bg));
  }
  /* Per-state hotspot alignment (offset so the active point sits at the pointer). */
  #cursorfx[data-state='default'] .cfx-default { display: block; left: -2px; top: -1px; }
  #cursorfx[data-state='pointer'] .cfx-pointer { display: block; left: -9px; top: -2px; }
  #cursorfx[data-state='text'] .cfx-text { display: block; left: -10px; top: -10px; }
  #cursorfx[data-state='disabled'] .cfx-disabled { display: block; left: -10px; top: -10px; }

  /* Star-shine glow — brightens + twinkles over interactive (pointer-state) targets. */
  #cursorfx .cfx-shine {
    position: absolute;
    left: 0;
    top: 0;
    width: 13px;
    height: 13px;
    margin: -6.5px;
    border-radius: 50%;
    opacity: 0;
    background: radial-gradient(circle, color-mix(in srgb, var(--colors-primary) 70%, transparent) 0%, transparent 65%);
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  #cursorfx[data-active] .cfx-shine {
    opacity: 1;
    transform: scale(1.7);
    animation: cfx-twinkle 1.2s ease-in-out infinite;
  }
  @keyframes cfx-twinkle {
    0%, 100% { opacity: 0.9; filter: brightness(1); }
    50% { opacity: 0.5; filter: brightness(1.35); }
  }
  @media (prefers-reduced-motion: reduce) {
    #cursorfx[data-active] .cfx-shine { animation: none; }
  }
  /* No custom cursor on touch / coarse pointers. */
  @media (pointer: coarse) {
    #cursorfx { display: none !important; }
  }
</style>

<script is:inline>
  (function () {
    try {
      if (!window.matchMedia || !matchMedia('(hover: hover) and (pointer: fine)').matches) return;
      var el = document.getElementById('cursorfx');
      if (!el) return;
      var root = document.documentElement;
      var x = 0, y = 0, raf = 0, armed = false;

      var INTERACTIVE = "a[href],button,summary,label,select,[role='button'],.hovercard,.copy-btn,[data-search-trigger],[data-sound-toggle],input[type='submit'],input[type='button']";
      var TEXTUAL = "input,textarea,[contenteditable='true'],p,h1,h2,h3,h4,h5,h6,li,code,pre,blockquote,td,th,dd,dt,figcaption";

      function stateFor(t) {
        if (!t || !t.closest) return 'default';
        if (t.closest('[disabled],[aria-disabled="true"]')) return 'disabled';
        if (t.closest(INTERACTIVE)) return 'pointer';
        if (t.closest(TEXTUAL)) return 'text';
        return 'default';
      }
      function draw() {
        raf = 0;
        el.style.transform = 'translate(' + x + 'px,' + y + 'px)';
      }
      window.addEventListener('mousemove', function (e) {
        x = e.clientX; y = e.clientY;
        if (!armed) { armed = true; root.classList.add('cursorfx-on'); el.style.opacity = '1'; }
        var st = stateFor(e.target);
        if (el.getAttribute('data-state') !== st) el.setAttribute('data-state', st);
        if (st === 'pointer') el.setAttribute('data-active', '');
        else el.removeAttribute('data-active');
        if (!raf) raf = requestAnimationFrame(draw);
      }, { passive: true });

      // Hide the follower (and reveal nothing — OS cursor stays hidden) when off-window.
      document.addEventListener('mouseleave', function () { el.style.opacity = '0'; });
      document.addEventListener('mouseenter', function () { if (armed) el.style.opacity = '1'; });
    } catch (err) {
      /* on any failure, leave the native cursor untouched */
    }
  })();
</script>
