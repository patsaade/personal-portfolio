---
// Post preview card used in listings and the home grid.
import { css } from 'styled-system/css';
import Badge from './Badge.astro';
import PostMeta from './PostMeta.astro';
import { categoryIcon } from '../consts';

interface Props {
  href: string;
  title: string;
  excerpt: string;
  category: string;
  date: Date;
  readTime?: number;
  difficulty?: string;
  tags?: string[];
  featured?: boolean;
}

const {
  href,
  title,
  excerpt,
  category,
  date,
  readTime,
  difficulty,
  tags = [],
  featured = false,
} = Astro.props;
---

<article
  class={css({
    position: 'relative',
    display: 'flex',
    flexDirection: 'column',
    gap: '0.75rem',
    p: { base: '1.25rem', md: '1.5rem' },
    bg: 'bgCard',
    border: '1px solid token(colors.border)',
    borderRadius: 'lg',
    boxShadow: 'card',
    transition: 'transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease',
    height: '100%',
    _hover: {
      transform: 'translateY(-3px)',
      boxShadow: 'cardHover',
      borderColor: 'primary',
    },
  })}
>
  <div class={css({ display: 'flex', alignItems: 'center', gap: '0.5rem', flexWrap: 'wrap' })}>
    <Badge variant="primary" icon={categoryIcon(category)}>{category}</Badge>
    {featured && <Badge variant="accent">Featured</Badge>}
  </div>

  <h3 class={css({ fontSize: '1.2rem', fontWeight: 700, lineHeight: 1.3 })}>
    <a
      href={href}
      class={css({
        _before: { content: '""', position: 'absolute', inset: 0 },
        _hover: { color: 'primary' },
      })}>{title}</a
    >
  </h3>

  <p class={css({ color: 'textMuted', fontSize: '0.95rem', flex: 1 })}>{excerpt}</p>

  <PostMeta date={date} readTime={readTime} difficulty={difficulty} />

  {
    tags.length > 0 && (
      <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.4rem' })}>
        {tags.slice(0, 4).map((t) => (
          <Badge>#{t}</Badge>
        ))}
      </div>
    )
  }
</article>
