---
// Related-posts grid shown at the foot of an article.
import { css } from 'styled-system/css';
import Badge from './Badge.astro';
import type { BlogPost } from '../utils/posts';

interface Props {
  posts: BlogPost[];
}
const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <section
      class={css({
        mt: '3.5rem',
        pt: '2rem',
        borderTop: '1px solid token(colors.border)',
      })}
    >
      <h2 class={css({ fontSize: '1.3rem', fontWeight: 700, mb: '1.25rem' })}>Related posts</h2>
      <div
        class={css({
          display: 'grid',
          gridTemplateColumns: { base: '1fr', sm: 'repeat(3, 1fr)' },
          gap: '1rem',
        })}
      >
        {posts.map((p) => (
          <a
            href={`/blog/${p.id}`}
            class={css({
              display: 'flex',
              flexDirection: 'column',
              gap: '0.5rem',
              p: '1rem',
              border: '1px solid token(colors.border)',
              borderRadius: 'md',
              bg: 'bgCard',
              transition: 'border-color 200ms ease, transform 200ms ease',
              _hover: { borderColor: 'primary', transform: 'translateY(-2px)' },
            })}
          >
            <Badge variant="primary">{p.data.category}</Badge>
            <span class={css({ fontWeight: 600, fontSize: '0.95rem', lineHeight: 1.35 })}>
              {p.data.title}
            </span>
          </a>
        ))}
      </div>
    </section>
  )
}
