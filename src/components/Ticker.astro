---
// Site-wide "Word of the Day" ticker — a scrolling digital banner pinned to the
// top of every page. The build renders the build-day term (a valid no-JS /
// crawler fallback); the inline script below recomputes the term for the
// VISITOR'S local day and swaps it in, so it genuinely changes daily without a
// rebuild. The marquee track holds the content twice and animates to -50% for a
// seamless loop (see global.css → @keyframes wotd-marquee).
import { css } from 'styled-system/css';
import Icon from './Icon.astro';
import { SECURITY_TERMS, termForDate } from '../data/securityTerms';

const today = termForDate(new Date());
const href = `/word-of-the-day/${today.slug}/`;

// Slim bank for the client-side daily recompute (term, slug, short only).
const bank = SECURITY_TERMS.map((t) => ({ t: t.term, s: t.slug, d: t.short }));

// Identical copies; -50% translate lands on a matching frame. Enough copies to
// span ultra-wide viewports without a gap.
const COPIES = 12;

const itemClass = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.5rem',
  flexShrink: 0,
});
const termClass = css({ color: 'primary', fontWeight: 700, letterSpacing: '0.02em' });
const dashClass = css({ color: 'textMuted', opacity: 0.7 });
const shortClass = css({ color: 'text' });
const sepClass = css({ color: 'primary', opacity: 0.45, px: '0.95rem', fontSize: '0.7em' });
---

<aside aria-label="Cybersecurity word of the day" class={css({
  position: 'relative',
  w: '100%',
  bg: 'bgSubtle',
  borderBottom: '1px solid token(colors.border)',
  overflow: 'hidden',
  fontFamily: 'mono',
  lineHeight: 1,
})}>
  <a
    id="wotd-ticker-link"
    href={href}
    aria-label={`Cybersecurity word of the day: ${today.term}. ${today.short} Read the full entry.`}
    class={css({
      display: 'flex',
      alignItems: 'stretch',
      h: { base: '34px', sm: '36px' },
      color: 'text',
      _hover: {
        '& .wotd-marquee-track': { animationPlayState: 'paused' },
        '& .wotd-cue': { color: 'primary', transform: 'translateX(2px)' },
      },
    })}
  >
    {/* Static label chip */}
    <span class={css({
      display: 'inline-flex',
      alignItems: 'center',
      gap: '0.45rem',
      flexShrink: 0,
      px: { base: '0.7rem', sm: '0.95rem' },
      bg: 'color-mix(in srgb, token(colors.primary) 13%, transparent)',
      borderRight: '1px solid token(colors.border)',
      color: 'primary',
      fontSize: { base: '0.58rem', sm: '0.68rem' },
      fontWeight: 700,
      letterSpacing: '0.12em',
      textTransform: 'uppercase',
      whiteSpace: 'nowrap',
    })}>
      <span class={`wotd-pulse-dot ${css({
        w: '6px',
        h: '6px',
        borderRadius: 'full',
        bg: 'currentColor',
        flexShrink: 0,
        animation: 'wotd-pulse 2s ease-in-out infinite',
      })}`} aria-hidden="true"></span>
      <span>Word of the Day</span>
    </span>

    {/* Scrolling viewport (decorative; the link's aria-label carries the text) */}
    <span
      aria-hidden="true"
      class={css({
        position: 'relative',
        flex: 1,
        minW: 0,
        display: 'flex',
        alignItems: 'center',
        overflow: 'hidden',
        maskImage: 'linear-gradient(to right, transparent, #000 1.25rem, #000 calc(100% - 1.25rem), transparent)',
        WebkitMaskImage: 'linear-gradient(to right, transparent, #000 1.25rem, #000 calc(100% - 1.25rem), transparent)',
      })}
    >
      <span class={`wotd-marquee-track ${css({
        display: 'inline-flex',
        alignItems: 'center',
        flexShrink: 0,
        whiteSpace: 'nowrap',
        pl: '1.25rem',
        fontSize: { base: '0.72rem', sm: '0.8rem' },
        willChange: 'transform',
        animation: 'wotd-marquee 38s linear infinite',
      })}`}>
        {
          Array.from({ length: COPIES }).map(() => (
            <span class={itemClass}>
              <strong class={`js-wotd-term ${termClass}`}>{today.term}</strong>
              <span class={dashClass}>—</span>
              <span class={`js-wotd-short ${shortClass}`}>{today.short}</span>
              <span class={sepClass}>◆</span>
            </span>
          ))
        }
      </span>
    </span>

    {/* "More" cue */}
    <span class={`wotd-cue ${css({
      display: { base: 'none', sm: 'inline-flex' },
      alignItems: 'center',
      flexShrink: 0,
      px: '0.7rem',
      color: 'textMuted',
      borderLeft: '1px solid token(colors.border)',
      transition: 'color 200ms ease, transform 200ms ease',
    })}`} aria-hidden="true">
      <Icon name="chevron-right" size={14} strokeWidth={2.5} />
    </span>
  </a>

  <script is:inline define:vars={{ bank }}>
    (function () {
      var link = document.getElementById('wotd-ticker-link');
      if (!link || !Array.isArray(bank) || !bank.length) return;
      // Same calendar math as termForDate(): local Y/M/D → day serial → index.
      var d = new Date();
      var serial = Math.floor(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()) / 86400000);
      var t = bank[((serial % bank.length) + bank.length) % bank.length];
      var href = '/word-of-the-day/' + t.s + '/';
      if (link.getAttribute('href') === href) return; // build day == visitor day
      link.setAttribute('href', href);
      link.setAttribute(
        'aria-label',
        'Cybersecurity word of the day: ' + t.t + '. ' + t.d + ' Read the full entry.',
      );
      var terms = link.querySelectorAll('.js-wotd-term');
      var shorts = link.querySelectorAll('.js-wotd-short');
      for (var i = 0; i < terms.length; i++) terms[i].textContent = t.t;
      for (var j = 0; j < shorts.length; j++) shorts[j].textContent = t.d;
    })();
  </script>
</aside>
