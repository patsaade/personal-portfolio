---
// Comprehensive, bidirectional timestamp converter — every field is both an
// input and an output: edit any one of the 19 formats and every other field
// updates live from the same underlying instant (src/utils/timestamps.ts).
// A "Detect" box up top runs the raw pasted value through every format and
// offers plausible matches, for when you don't already know what you're
// looking at. Same "Scratch-inspired workspace" visual language as the OSINT
// Crock Pot's DorkBuilder (corner brackets, dot-grid texture, a left-rail
// timeline of blocks, a sticky "stage" — here showing the one instant every
// field currently represents as three permanent, independently copyable
// boxes: UTC (always), Local (always, the browser's own zone), and
// Converted (a specific other timezone, picked via the searchable zone
// picker below — a small always-visible "Common" list plus type-to-search
// over every IANA zone from Intl.supportedValuesOf('timeZone'), each option
// live-annotated with its current UTC offset; replaces the old single
// `<select>` with ~400 flat alphabetical `<option>`s, which had no search
// and buried e.g. Tokyo three scroll-screens deep under "Asia"). Converted
// shows a muted placeholder until a zone is picked — no separate UTC/Local
// switch is needed since both are always visible as their own boxes. The
// picked zone (or Local, if none is picked) governs the local-time-only
// formats below (FAT/DOS, RFC 3164 syslog); the offset is re-resolved from
// the zone name on every render (not cached), since DST-observing zones'
// offsets depend on the date. Genuinely requires JS (there's no meaningful
// static form for live N-way conversion), so the workspace stays hidden
// until the script confirms it's running — same JS-armed, no-JS-safe
// philosophy as DorkBuilder/CollapseAll/ViewToggle.
import { css } from 'styled-system/css';
import Icon from './Icon.astro';
import WorkspaceShell from './WorkspaceShell.astro';
import { TIMESTAMP_FORMATS } from '../utils/timestamps';

const GROUPS: { label: string; ids: string[] }[] = [
  { label: 'Unix / epoch', ids: ['unix-s', 'unix-ms', 'unix-us', 'unix-ns'] },
  { label: 'Windows', ids: ['filetime', 'webkit', 'net-ticks', 'ole-date'] },
  { label: 'Apple / macOS', ids: ['mac-absolute', 'hfsplus'] },
  { label: 'Other epochs', ids: ['uuid-v1', 'gps', 'tai64', 'fat-dos'] },
  { label: 'Text formats', ids: ['iso8601', 'rfc2822', 'http-date', 'syslog-3164', 'clf'] },
];
const byId = new Map(TIMESTAMP_FORMATS.map((f) => [f.id, f]));

// A short, pinned "quick pick" list of major zones (real IANA identifiers) so
// the common case never needs typing — searched/typed zones (any of the
// ~400 Intl.supportedValuesOf('timeZone') results) are rendered by the client
// script on demand. UTC itself isn't listed here since it already has its own
// quick button above.
const COMMON_ZONES: { id: string; label: string }[] = [
  { id: 'America/New_York', label: 'New York' },
  { id: 'America/Chicago', label: 'Chicago' },
  { id: 'America/Denver', label: 'Denver' },
  { id: 'America/Los_Angeles', label: 'Los Angeles' },
  { id: 'America/Sao_Paulo', label: 'São Paulo' },
  { id: 'Europe/London', label: 'London' },
  { id: 'Europe/Paris', label: 'Paris' },
  { id: 'Europe/Berlin', label: 'Berlin' },
  { id: 'Europe/Moscow', label: 'Moscow' },
  { id: 'Africa/Cairo', label: 'Cairo' },
  { id: 'Asia/Dubai', label: 'Dubai' },
  { id: 'Asia/Kolkata', label: 'Mumbai / Kolkata' },
  { id: 'Asia/Bangkok', label: 'Bangkok' },
  { id: 'Asia/Shanghai', label: 'Shanghai' },
  { id: 'Asia/Tokyo', label: 'Tokyo' },
  { id: 'Australia/Sydney', label: 'Sydney' },
  { id: 'Pacific/Auckland', label: 'Auckland' },
];

const detectRow = css({ display: 'flex', flexDirection: 'column', gap: '0.3rem' });
const fieldLabel = css({ fontFamily: 'sans', fontSize: '0.68rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.08em', color: 'textMuted' });
const detectInput = css({
  fontFamily: 'mono',
  fontSize: '0.9rem',
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  px: '0.7rem',
  py: '0.5rem',
  transition: 'border-color 150ms ease',
  _focus: { outline: 'none', borderColor: 'primary' },
  '&::placeholder': { color: 'textMuted', opacity: 0.7 },
});
const detectResults = css({ display: 'flex', flexDirection: 'column', gap: '0.3rem', minH: '1.4em' });
const detectChip = css({
  display: 'inline-flex',
  alignItems: 'center',
  justifyContent: 'space-between',
  gap: '0.5rem',
  fontFamily: 'mono',
  fontSize: '0.78rem',
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'sm',
  px: '0.6rem',
  py: '0.35rem',
  cursor: 'pointer',
  transition: 'border-color 150ms ease, color 150ms ease',
  _hover: { borderColor: 'primary', color: 'primary' },
});

const paneLabel = css({ fontFamily: 'sans', fontSize: '0.7rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.1em', color: 'textMuted', mb: '0.6rem' });
const workspaceGrid = css({ display: 'grid', gridTemplateColumns: { base: '1fr', lg: 'minmax(0, 1fr) 280px' }, gap: '1.5rem', alignItems: 'start' });

const groupLabel = css({ fontFamily: 'sans', fontSize: '0.65rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.08em', color: 'primary', mt: '0.9rem', '&:first-child': { mt: 0 } });
const blockStack = css({ display: 'flex', flexDirection: 'column', gap: '0.4rem', borderLeft: '2px solid token(colors.border)', ml: '0.4rem', pl: '1.1rem' });
const blockRow = css({
  position: 'relative',
  display: 'flex',
  alignItems: 'flex-start',
  gap: '0.6rem',
  py: '0.15rem',
  px: '0.3rem',
  borderRadius: 'sm',
  transition: 'background 150ms ease',
  '&::before': {
    content: '""',
    position: 'absolute',
    left: '-1.5rem',
    top: '0.65rem',
    w: '8px',
    h: '8px',
    borderRadius: 'full',
    bg: 'border',
    transition: 'background 150ms ease',
  },
  '&[data-filled]::before': { bg: 'primary' },
  '&[data-invalid]': { bg: 'color-mix(in srgb, red 8%, transparent)' },
});
// No truncation — a label that doesn't fit wraps onto a second line rather
// than losing text to an ellipsis; the fixed width means this never eats
// into the value input's space next to it.
const blockBadge = css({
  flexShrink: 0,
  w: '9.5rem',
  pt: '0.4rem',
  fontFamily: 'sans',
  fontSize: '0.75rem',
  fontWeight: 600,
  color: 'text',
  lineHeight: 1.3,
  overflowWrap: 'break-word',
});
const blockInput = css({
  flex: 1,
  minW: 0,
  fontFamily: 'mono',
  fontSize: '0.84rem',
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  px: '0.6rem',
  py: '0.4rem',
  transition: 'border-color 150ms ease',
  _focus: { outline: 'none', borderColor: 'primary' },
  '&::placeholder': { color: 'textMuted', opacity: 0.7 },
});
const rowCopyBtn = css({
  flexShrink: 0,
  display: 'inline-flex',
  alignItems: 'center',
  justifyContent: 'center',
  w: '2rem',
  h: '2rem',
  borderRadius: 'md',
  border: '1px solid token(colors.border)',
  bg: 'bgCard',
  color: 'textMuted',
  cursor: 'pointer',
  transition: 'all 150ms ease',
  _hover: { borderColor: 'primary', color: 'primary' },
});

const stage = css({ display: 'flex', flexDirection: 'column', gap: '0.9rem', position: { lg: 'sticky' }, top: { lg: '90px' } });
const instantGroup = css({ display: 'flex', flexDirection: 'column', gap: '0.6rem' });
const instantBoxWrap = css({ display: 'flex', flexDirection: 'column', gap: '0.3rem' });
const instantZoneLabel = css({ fontFamily: 'sans', fontSize: '0.68rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.08em', color: 'textMuted' });
const instantRow = css({ display: 'flex', alignItems: 'stretch', gap: '0.4rem' });
const instantBox = css({
  flex: 1,
  minW: 0,
  m: 0,
  p: '0.85rem 0.9rem',
  fontFamily: 'mono',
  fontSize: '0.98rem',
  fontWeight: 700,
  color: 'primary',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  overflowX: 'hidden',
  whiteSpace: 'pre-wrap',
  wordBreak: 'break-word',
  // The Converted box before a timezone is picked: a muted placeholder
  // rather than dashes-with-no-explanation, so it's obvious what to do.
  '&[data-empty]': { color: 'textMuted', fontWeight: 500, fontStyle: 'italic' },
});
const zonePicker = css({ position: 'relative' });
const zonePickerControl = css({
  display: 'flex',
  alignItems: 'center',
  gap: '0.4rem',
  fontFamily: 'mono',
  fontSize: '0.8rem',
  color: 'text',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  px: '0.6rem',
  py: '0.4rem',
  cursor: 'text',
  transition: 'border-color 150ms ease',
  _focusWithin: { borderColor: 'primary' },
  '&[data-active]': { borderColor: 'primary', color: 'primary' },
});
const zonePickerIco = css({ flexShrink: 0, color: 'textMuted' });
const zonePickerInput = css({
  flex: 1,
  minW: 0,
  border: 'none',
  bg: 'transparent',
  color: 'inherit',
  fontFamily: 'inherit',
  fontSize: 'inherit',
  outline: 'none',
  '&::placeholder': { color: 'textMuted', opacity: 0.7 },
});
const zonePickerList = css({
  position: 'absolute',
  top: 'calc(100% + 0.4rem)',
  left: 0,
  right: 0,
  zIndex: 40,
  m: 0,
  p: '0.35rem',
  listStyle: 'none',
  maxH: '16rem',
  overflowY: 'auto',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  boxShadow: 'cardHover',
});
const zoneGroupLabel = css({
  fontFamily: 'sans',
  fontSize: '0.65rem',
  fontWeight: 700,
  textTransform: 'uppercase',
  letterSpacing: '0.08em',
  color: 'primary',
  px: '0.5rem',
  pt: '0.4rem',
  pb: '0.2rem',
  '&:first-child': { pt: '0.1rem' },
});
const zoneOption = css({
  display: 'flex',
  alignItems: 'center',
  justifyContent: 'space-between',
  gap: '0.6rem',
  px: '0.55rem',
  py: '0.4rem',
  borderRadius: 'sm',
  fontFamily: 'sans',
  fontSize: '0.85rem',
  color: 'text',
  cursor: 'pointer',
  '&[hidden]': { display: 'none' },
  '_hover': { bg: 'bgSubtle', color: 'primary' },
  '&[data-active]': { bg: 'bgSubtle', color: 'primary' },
});
const zoneOptionOffset = css({
  flexShrink: 0,
  fontFamily: 'mono',
  fontSize: '0.72rem',
  fontWeight: 600,
  color: 'textMuted',
  bg: 'bgSubtle',
  border: '1px solid token(colors.border)',
  borderRadius: 'full',
  px: '0.45rem',
  py: '0.05rem',
});
const zoneEmpty = css({ px: '0.65rem', py: '0.5rem', color: 'textMuted', fontSize: '0.85rem', textAlign: 'center' });
const actionCol = css({ display: 'flex', flexDirection: 'column', gap: '0.5rem' });
const actionBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  justifyContent: 'center',
  gap: '0.4rem',
  fontSize: '0.85rem',
  fontFamily: 'sans',
  fontWeight: 600,
  px: '0.8rem',
  py: '0.5rem',
  borderRadius: 'md',
  border: '1px solid token(colors.border)',
  color: 'text',
  cursor: 'pointer',
  bg: 'bgCard',
  transition: 'all 150ms ease',
  _hover: { borderColor: 'primary', color: 'primary' },
});
const primaryBtn = css({ bg: 'primary', color: 'onPrimary', borderColor: 'primary', _hover: { opacity: 0.9, color: 'onPrimary' } });
---

<WorkspaceShell hook="data-ts-converter" noJsMessage="The interactive timestamp converter needs JavaScript enabled.">
    <div class={detectRow}>
      <label class={fieldLabel} for="ts-detect">Paste any timestamp — auto-detect</label>
      <input
        id="ts-detect"
        type="text"
        class={detectInput}
        placeholder="e.g. 132587904000000000, 2024-03-05T13:22:07+02:00, Sun, 06 Nov 1994 08:49:37 GMT…"
        autocomplete="off"
        data-ts-detect
      />
      <div class={detectResults} data-ts-detect-results role="status" aria-live="polite"></div>
      {/* Cloned per detected match — keeps the client script free of Panda class-name strings. */}
      <template data-ts-detect-chip-template>
        <button type="button" class={detectChip}>
          <span data-detect-label></span>
          <Icon name="arrow-right" size={12} />
        </button>
      </template>
    </div>

    <div class={workspaceGrid}>
      <div>
        <p class={paneLabel}>Formats</p>
        {
          GROUPS.map((g) => (
            <>
              <p class={groupLabel}>{g.label}</p>
              <div class={blockStack}>
                {g.ids.map((id) => {
                  const f = byId.get(id)!;
                  return (
                    <div class={blockRow} data-ts-row data-ts-id={f.id}>
                      <span class={blockBadge} title={f.label}>{f.label}</span>
                      <input
                        id={`ts-${f.id}`}
                        type="text"
                        class={blockInput}
                        placeholder={f.placeholder}
                        aria-label={f.label}
                        data-ts-field={f.id}
                        autocomplete="off"
                        spellcheck="false"
                      />
                      <button type="button" class={rowCopyBtn} data-ts-row-copy={f.id} data-copy-pop data-sound="copy" aria-label={`Copy ${f.label}`} title="Copy">
                        <Icon name="copy" size={13} />
                      </button>
                    </div>
                  );
                })}
              </div>
            </>
          ))
        }
      </div>

      <div class={stage}>
        <p class={paneLabel}>Current instant</p>
        <div class={instantGroup}>
          <div class={instantBoxWrap}>
            <span class={instantZoneLabel}>UTC</span>
            <div class={instantRow}>
              <pre class={instantBox} data-ts-instant-utc>&nbsp;</pre>
              <button type="button" class={rowCopyBtn} data-ts-instant-copy="utc" data-copy-pop data-sound="copy" aria-label="Copy UTC time" title="Copy UTC time">
                <Icon name="copy" size={13} />
              </button>
            </div>
          </div>
          <div class={instantBoxWrap}>
            <span class={instantZoneLabel} data-ts-instant-local-label>Local</span>
            <div class={instantRow}>
              <pre class={instantBox} data-ts-instant-local>&nbsp;</pre>
              <button type="button" class={rowCopyBtn} data-ts-instant-copy="local" data-copy-pop data-sound="copy" aria-label="Copy local time" title="Copy local time">
                <Icon name="copy" size={13} />
              </button>
            </div>
          </div>
          <div class={instantBoxWrap}>
            <span class={instantZoneLabel} data-ts-instant-converted-label>Converted</span>
            <div class={instantRow}>
              <pre class={instantBox} data-ts-instant-converted data-empty>Pick a timezone below…</pre>
              <button type="button" class={rowCopyBtn} data-ts-instant-copy="converted" data-copy-pop data-sound="copy" aria-label="Copy converted time" title="Copy converted time">
                <Icon name="copy" size={13} />
              </button>
            </div>
          </div>
        </div>

        <p class={fieldLabel}>Convert to a timezone (also drives the local-time-only formats below)</p>
        <div class={zonePicker} data-ts-zone-picker>
          <div class={zonePickerControl} data-ts-zone-control>
            <span class={zonePickerIco}><Icon name="search" size={14} /></span>
            <input
              type="text"
              class={zonePickerInput}
              data-ts-zone-input
              role="combobox"
              aria-expanded="false"
              aria-autocomplete="list"
              aria-controls="ts-zone-list"
              aria-label="Search for a timezone"
              autocomplete="off"
              placeholder="Search any city or timezone…"
            />
          </div>
          <ul class={zonePickerList} id="ts-zone-list" role="listbox" aria-label="Timezone results" hidden data-ts-zone-list>
            <li class={zoneGroupLabel} data-ts-zone-common-label>Common</li>
            {
              COMMON_ZONES.map((z) => (
                <li class={zoneOption} role="option" data-zone-id={z.id} data-zone-label={z.label.toLowerCase()} aria-selected="false">
                  <span>{z.label}</span>
                  <span class={zoneOptionOffset} data-zone-offset>—</span>
                </li>
              ))
            }
            <li class={zoneGroupLabel} data-ts-zone-search-label hidden>Matches</li>
            <li class={zoneEmpty} data-ts-zone-empty hidden>No matching timezone</li>
          </ul>
          {/* Cloned per search match — keeps the client script free of Panda class-name strings. */}
          <template data-ts-zone-option-template>
            <li class={zoneOption} role="option" aria-selected="false">
              <span data-zone-option-label></span>
              <span class={zoneOptionOffset} data-zone-offset>—</span>
            </li>
          </template>
        </div>

        <div class={actionCol}>
          <button type="button" class={`${actionBtn} ${primaryBtn}`} data-ts-now data-sound="tick">
            <Icon name="clock" size={15} /> Use current time
          </button>
          <button type="button" class={actionBtn} data-ts-copy-all data-copy-pop data-sound="copy">
            <Icon name="copy" size={15} /> Copy all as JSON
          </button>
        </div>
      </div>
    </div>
</WorkspaceShell>

<script>
  // @ts-nocheck — vanilla DOM client script
  import { formatById, detectFormat, offsetMinutesForZone, DEFAULT_CONTEXT } from '../utils/timestamps';
  import { pop } from '../scripts/copyPop';

  (function () {
    function init() {
      var roots = document.querySelectorAll('[data-ts-converter]:not([data-ready])');
      Array.prototype.forEach.call(roots, function (root) {
        var rows = Array.prototype.slice.call(root.querySelectorAll('[data-ts-row]'));
        var fields = rows.map(function (row) {
          return { row: row, id: row.getAttribute('data-ts-id'), input: row.querySelector('[data-ts-field]') };
        });
        var detectInput = root.querySelector('[data-ts-detect]');
        var detectResults = root.querySelector('[data-ts-detect-results]');
        var instantUtcEl = root.querySelector('[data-ts-instant-utc]');
        var instantLocalEl = root.querySelector('[data-ts-instant-local]');
        var instantLocalLabelEl = root.querySelector('[data-ts-instant-local-label]');
        var instantConvertedEl = root.querySelector('[data-ts-instant-converted]');
        var instantConvertedLabelEl = root.querySelector('[data-ts-instant-converted-label]');
        var zonePicker = root.querySelector('[data-ts-zone-picker]');
        var zoneControl = root.querySelector('[data-ts-zone-control]');
        var zoneInput = root.querySelector('[data-ts-zone-input]');
        var zoneList = root.querySelector('[data-ts-zone-list]');
        var zoneCommonLabel = root.querySelector('[data-ts-zone-common-label]');
        var zoneSearchLabel = root.querySelector('[data-ts-zone-search-label]');
        var zoneEmpty = root.querySelector('[data-ts-zone-empty]');
        var zoneOptionTemplate = root.querySelector('[data-ts-zone-option-template]');
        var commonZoneOptions = zoneList ? Array.prototype.slice.call(zoneList.querySelectorAll('[data-zone-id]')) : [];
        var nowBtn = root.querySelector('[data-ts-now]');
        var copyAllBtn = root.querySelector('[data-ts-copy-all]');
        if (!instantUtcEl || !instantLocalEl || !nowBtn) return;

        // `ctx.refOffsetMinutes` drives the local-time-only formats (FAT/DOS,
        // syslog) below — it follows the picked zone once one is chosen, else
        // falls back to Local, so those fields always represent SOME real
        // local wall-clock rather than needing their own separate control.
        var ctx = { refOffsetMinutes: 0, refYear: DEFAULT_CONTEXT.refYear };
        var current = null; // canonical ns (bigint) | null
        var pickedZone = null; // null | an IANA zone name (e.g. 'America/New_York')

        function browserZoneName() {
          try { return Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC'; } catch (e) { return 'UTC'; }
        }

        // Searchable timezone picker: a small pinned "Common" list (server-rendered,
        // always in the DOM) plus type-to-search over every IANA zone the runtime
        // knows about (fetched lazily, on first search, from Intl.supportedValuesOf —
        // newer API, Safari 15.4+/Chrome+Firefox ~2022+; on older runtimes the search
        // just yields no extra matches and the Common list + UTC/Local buttons still
        // cover the common cases). Matches are capped and rendered on demand (cloned
        // from a <template>) instead of pre-rendering all ~400 zones as hidden DOM.
        var allZoneIds = null; // lazy: null until first search
        function loadAllZoneIds() {
          if (allZoneIds !== null) return;
          allZoneIds = [];
          if (typeof Intl.supportedValuesOf !== 'function') return;
          try {
            var commonIds = {};
            commonZoneOptions.forEach(function (o) { commonIds[o.getAttribute('data-zone-id')] = true; });
            allZoneIds = Intl.supportedValuesOf('timeZone').filter(function (z) { return z !== 'UTC' && !commonIds[z]; });
          } catch (e) {}
        }
        function zoneDisplayLabel(id) {
          var parts = id.split('/');
          var city = parts[parts.length - 1].replace(/_/g, ' ');
          if (parts.length > 2) return city + ' (' + parts.slice(1, -1).join('/').replace(/_/g, ' ') + ')';
          return city;
        }
        function zoneSearchText(id) {
          return id.replace(/\//g, ' ').replace(/_/g, ' ').toLowerCase();
        }
        function formatOffset(mins) {
          if (mins === null) return '—';
          var sign = mins < 0 ? '-' : '+';
          var abs = Math.abs(mins);
          var h = String(Math.floor(abs / 60)).padStart(2, '0');
          var m = String(abs % 60).padStart(2, '0');
          return sign + h + ':' + m;
        }
        var dynamicZoneOptions = [];
        function clearDynamicZoneOptions() {
          dynamicZoneOptions.forEach(function (o) { o.remove(); });
          dynamicZoneOptions = [];
        }
        function visibleZoneOptions() {
          return Array.prototype.slice.call(zoneList.querySelectorAll('[data-zone-id]')).filter(function (o) { return !o.hidden; });
        }
        var zoneActiveIdx = -1;
        function setZoneActive(idx) {
          var vis = visibleZoneOptions();
          vis.forEach(function (o) { o.removeAttribute('data-active'); o.setAttribute('aria-selected', 'false'); });
          zoneActiveIdx = idx >= 0 && idx < vis.length ? idx : -1;
          if (zoneActiveIdx >= 0) {
            vis[zoneActiveIdx].setAttribute('data-active', '');
            vis[zoneActiveIdx].setAttribute('aria-selected', 'true');
            vis[zoneActiveIdx].scrollIntoView({ block: 'nearest' });
          }
        }
        function refreshZoneOffsets() {
          visibleZoneOptions().forEach(function (o) {
            var badge = o.querySelector('[data-zone-offset]');
            if (!badge) return;
            badge.textContent = current === null ? '—' : formatOffset(offsetMinutesForZone(current, o.getAttribute('data-zone-id')));
          });
        }
        function refreshZoneList() {
          var q = zoneInput.value.trim().toLowerCase();
          if (!q) {
            commonZoneOptions.forEach(function (o) { o.hidden = false; });
            clearDynamicZoneOptions();
            zoneCommonLabel.hidden = false;
            zoneSearchLabel.hidden = true;
            zoneEmpty.hidden = true;
            refreshZoneOffsets();
            setZoneActive(-1);
            return;
          }
          loadAllZoneIds();
          var matchedCommon = 0;
          commonZoneOptions.forEach(function (o) {
            var match = o.getAttribute('data-zone-label').indexOf(q) !== -1;
            o.hidden = !match;
            if (match) matchedCommon++;
          });
          zoneCommonLabel.hidden = matchedCommon === 0;
          clearDynamicZoneOptions();
          var matches = allZoneIds.filter(function (id) { return zoneSearchText(id).indexOf(q) !== -1; }).slice(0, 30);
          matches.forEach(function (id) {
            var li = zoneOptionTemplate.content.firstElementChild.cloneNode(true);
            li.setAttribute('data-zone-id', id);
            li.querySelector('[data-zone-option-label]').textContent = zoneDisplayLabel(id);
            zoneList.insertBefore(li, zoneEmpty);
            dynamicZoneOptions.push(li);
          });
          zoneSearchLabel.hidden = matches.length === 0;
          zoneEmpty.hidden = matchedCommon > 0 || matches.length > 0;
          refreshZoneOffsets();
          setZoneActive(-1);
        }
        function openZoneList() {
          zoneList.hidden = false;
          zoneInput.setAttribute('aria-expanded', 'true');
          refreshZoneList();
        }
        function closeZoneList() {
          zoneList.hidden = true;
          zoneInput.setAttribute('aria-expanded', 'false');
        }
        function chooseZone(id) {
          pickedZone = id;
          zoneInput.value = zoneDisplayLabel(id);
          zoneControl.setAttribute('data-active', '');
          closeZoneList();
          render(null);
        }
        if (zonePicker && zoneInput && zoneList) {
          zoneInput.addEventListener('focus', openZoneList);
          zoneInput.addEventListener('input', refreshZoneList);
          zoneInput.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowDown') { e.preventDefault(); if (zoneList.hidden) openZoneList(); else setZoneActive(zoneActiveIdx + 1); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); setZoneActive(zoneActiveIdx - 1); }
            else if (e.key === 'Enter') {
              var vis = visibleZoneOptions();
              if (zoneActiveIdx >= 0 && vis[zoneActiveIdx]) { e.preventDefault(); chooseZone(vis[zoneActiveIdx].getAttribute('data-zone-id')); }
            } else if (e.key === 'Escape') { closeZoneList(); }
          });
          zoneList.addEventListener('click', function (e) {
            var opt = e.target.closest('[data-zone-id]');
            if (opt) chooseZone(opt.getAttribute('data-zone-id'));
          });
          document.addEventListener('pointerdown', function (e) { if (!zonePicker.contains(e.target)) closeZoneList(); });
        }

        // Recomputed on every render (not cached) since a DST-observing zone's
        // offset depends on the DATE, not just the zone name — editing a field
        // to a different date must re-resolve it, not keep a stale offset.
        // Drives the local-time-only formats: the picked zone if there is
        // one, else Local — these fields always represent a real local
        // wall-clock, never UTC (that was never really what "local-time-only"
        // meant for FAT/DOS or syslog anyway).
        function recomputeOffset(localZone) {
          if (current === null) { ctx.refOffsetMinutes = 0; return; }
          var zoneName = pickedZone || localZone;
          var offset = offsetMinutesForZone(current, zoneName);
          ctx.refOffsetMinutes = offset === null ? 0 : offset;
        }

        function render(skipId) {
          // Computed once per render and reused below for the Local box, rather
          // than calling browserZoneName() a second time for the same value.
          var localZone = browserZoneName();
          recomputeOffset(localZone);
          fields.forEach(function (f) {
            if (f.id === skipId) return;
            var fmt = formatById(f.id);
            var text = current === null ? '' : fmt.format(current, ctx);
            f.input.value = text;
            if (text) f.row.setAttribute('data-filled', '');
            else f.row.removeAttribute('data-filled');
            f.row.removeAttribute('data-invalid');
          });
          if (current === null) {
            instantUtcEl.textContent = ' ';
            instantLocalEl.textContent = ' ';
            instantConvertedEl.textContent = 'Pick a timezone below…';
            instantConvertedEl.setAttribute('data-empty', '');
            if (zoneList && !zoneList.hidden) refreshZoneOffsets();
            return;
          }
          var isoUtc = formatById('iso8601').format(current, { refOffsetMinutes: 0, refYear: ctx.refYear });
          instantUtcEl.textContent = isoUtc;

          // Local is always the browser's own zone, independent of whatever
          // zone is picked for the Converted box below.
          var localOffset = offsetMinutesForZone(current, localZone);
          var localCtx = { refOffsetMinutes: localOffset === null ? 0 : localOffset, refYear: ctx.refYear };
          instantLocalEl.textContent = formatById('iso8601').format(current, localCtx);
          instantLocalLabelEl.textContent = 'Local (' + localZone + ')';

          if (pickedZone) {
            var convertedOffset = offsetMinutesForZone(current, pickedZone);
            var convertedCtx = { refOffsetMinutes: convertedOffset === null ? 0 : convertedOffset, refYear: ctx.refYear };
            instantConvertedEl.textContent = formatById('iso8601').format(current, convertedCtx);
            instantConvertedEl.removeAttribute('data-empty');
            instantConvertedLabelEl.textContent = 'Converted (' + zoneDisplayLabel(pickedZone) + ')';
          } else {
            instantConvertedEl.textContent = 'Pick a timezone below…';
            instantConvertedEl.setAttribute('data-empty', '');
            instantConvertedLabelEl.textContent = 'Converted';
          }
          if (zoneList && !zoneList.hidden) refreshZoneOffsets();
        }

        function setFromField(id) {
          var f = fields.filter(function (x) { return x.id === id; })[0];
          if (!f) return;
          var fmt = formatById(id);
          var raw = f.input.value;
          if (!raw.trim()) {
            f.row.removeAttribute('data-filled');
            f.row.removeAttribute('data-invalid');
            return;
          }
          var ns = fmt.parse(raw, ctx);
          if (ns === null) {
            f.row.removeAttribute('data-filled');
            f.row.setAttribute('data-invalid', '');
            return;
          }
          current = ns;
          f.row.setAttribute('data-filled', '');
          f.row.removeAttribute('data-invalid');
          render(id);
        }

        fields.forEach(function (f) {
          f.input.addEventListener('input', function () { setFromField(f.id); });
        });

        nowBtn.addEventListener('click', function () {
          current = BigInt(Date.now()) * 1000000n;
          render(null);
        });

        // Shared copy-confirm pop (see motion.css's [data-copy-pop] rule) — same
        // attribute-toggle convention as the blog code-block copy button.
        function copyText(btn, text) {
          if (!text) return;
          navigator.clipboard.writeText(text).then(function () { pop(btn); }).catch(function () {});
        }

        // Row copy buttons
        Array.prototype.forEach.call(root.querySelectorAll('[data-ts-row-copy]'), function (btn) {
          btn.addEventListener('click', function () {
            var id = btn.getAttribute('data-ts-row-copy');
            var f = fields.filter(function (x) { return x.id === id; })[0];
            if (!f) return;
            copyText(btn, f.input.value);
          });
        });

        // Current-instant copy buttons (UTC / Local / Converted boxes) — the
        // Converted box no-ops while it's still showing its placeholder.
        var instantBoxes = { utc: instantUtcEl, local: instantLocalEl, converted: instantConvertedEl };
        Array.prototype.forEach.call(root.querySelectorAll('[data-ts-instant-copy]'), function (btn) {
          btn.addEventListener('click', function () {
            var kind = btn.getAttribute('data-ts-instant-copy');
            var el = instantBoxes[kind];
            if (!el || el.hasAttribute('data-empty')) return;
            var text = el.textContent;
            copyText(btn, text && text.trim());
          });
        });

        if (copyAllBtn) {
          copyAllBtn.addEventListener('click', function () {
            if (current === null) return;
            var out = {};
            fields.forEach(function (f) { out[f.id] = formatById(f.id).format(current, ctx); });
            copyText(copyAllBtn, JSON.stringify(out, null, 2));
          });
        }

        // Auto-detect quick-paste box — chips are cloned from a <template> so
        // their styling comes from the Panda class baked into that markup,
        // not a class-name string reconstructed here.
        var chipTemplate = root.querySelector('[data-ts-detect-chip-template]');
        if (detectInput && detectResults && chipTemplate) {
          detectInput.addEventListener('input', function () {
            var raw = detectInput.value;
            detectResults.innerHTML = '';
            if (!raw.trim()) return;
            var matches = detectFormat(raw);
            matches.slice(0, 6).forEach(function (m) {
              var chip = chipTemplate.content.firstElementChild.cloneNode(true);
              chip.querySelector('[data-detect-label]').textContent = m.format.label + ' — click to load';
              chip.addEventListener('click', function () {
                current = m.ns;
                render(null);
              });
              detectResults.appendChild(chip);
            });
          });
        }

        // Seed with the current time on load.
        current = BigInt(Date.now()) * 1000000n;
        render(null);

        root.setAttribute('data-ready', '');
      });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
