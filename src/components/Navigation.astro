---
// Sticky top nav — brand, links, theme picker, mode toggle, mobile menu.
import { css } from 'styled-system/css';
import { NAV_LINKS, MORE_LINKS, SITE } from '../consts';
import ThemePicker from './ThemePicker.astro';
import ModeToggle from './ModeToggle.astro';
import SoundToggle from './SoundToggle.astro';
import PixelStar from './PixelStar.astro';
import Icon from './Icon.astro';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
const moreActive = MORE_LINKS.some((l) => isActive(l.href));

// Desktop nav "More" dropdown (mirrors the footer's More column). Opens on
// hover/focus via CSS (the `.nav-more` ancestor) and on click/tap via JS.
const moreWrap = css({ position: 'relative', display: 'flex', alignItems: 'center' });
const moreBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.2rem',
  fontFamily: 'inherit',
  fontSize: '0.95rem',
  fontWeight: 500,
  color: 'textMuted',
  bg: 'transparent',
  border: 'none',
  p: 0,
  cursor: 'pointer',
  borderBottom: '2px solid transparent',
  pb: '2px',
  transition: 'color 200ms ease',
  _hover: { color: 'text' },
  '& .nav-more-chev': { transition: 'transform 200ms ease' },
});
const moreBtnActive = css({ color: 'primary', borderBottomColor: 'primary' });
const moreMenuOuter = css({
  position: 'absolute',
  top: '100%',
  right: 0,
  pt: '0.6rem', // transparent hover-bridge so the menu stays open between button and panel
  display: 'none',
  zIndex: 60,
});
const moreMenuInner = css({
  minW: '190px',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'lg',
  boxShadow: 'cardHover',
  p: '0.4rem',
  display: 'flex',
  flexDirection: 'column',
  gap: '0.05rem',
});
const moreLink = css({
  display: 'block',
  px: '0.65rem',
  py: '0.45rem',
  fontSize: '0.9rem',
  color: 'textMuted',
  borderRadius: 'md',
  whiteSpace: 'nowrap',
  transition: 'color 150ms ease, background 150ms ease',
  _hover: { color: 'primary', bg: 'bgSubtle' },
  '&[aria-current=page]': { color: 'primary', fontWeight: 600 },
});
const mobileLink = css({
  display: 'block',
  py: '0.6rem',
  fontSize: '1rem',
  color: 'textMuted',
  '&[aria-current=page]': { color: 'primary', fontWeight: 600 },
});
---

<header
  class={css({
    position: 'sticky',
    top: 0,
    zIndex: 50,
    // Same dissolve recipe as the footer (Footer.astro): 55% surface + blur(5px),
    // so the background nodes and any content scrolling behind read through clearly
    // (a heavy blur smears the thin node lines into nothing). The gradient seam
    // below fades the header into the content (mirror of the footer's top seam).
    bg: 'color-mix(in srgb, token(colors.bg) 55%, transparent)',
    backdropFilter: 'blur(5px)',
    borderBottom: '1px solid token(colors.border)',
    _after: {
      content: '""',
      position: 'absolute',
      left: 0,
      right: 0,
      top: '100%',
      height: '1.25rem',
      pointerEvents: 'none',
      background: 'linear-gradient(to bottom, color-mix(in srgb, token(colors.bg) 55%, transparent), transparent)',
    },
  })}
>
  <nav
    class={css({
      maxW: '960px',
      mx: 'auto',
      px: '1.25rem',
      h: '64px',
      display: 'flex',
      alignItems: 'center',
      justifyContent: 'space-between',
      gap: '1rem',
    })}
  >
    <a
      href="/"
      class={css({
        display: 'inline-flex',
        alignItems: 'center',
        gap: '0.45rem',
        fontFamily: 'redaction50',
        fontWeight: 700,
        fontSize: '1.25rem',
        letterSpacing: '-0.01em',
        whiteSpace: 'nowrap',
      })}
    >
      <PixelStar size={17} twinkle={false} class={css({ flexShrink: 0 })} />
      <span class={css({ display: { base: 'inline', sm: 'none' } })}>{SITE.brandShort}</span>
      <span class={css({ display: { base: 'none', sm: 'inline' } })}>{SITE.brand}</span>
    </a>

    <div
      class={css({
        display: 'flex',
        alignItems: 'center',
        gap: { base: '0.5rem', md: '1.5rem' },
      })}
    >
      <ul
        class={css({
          display: { base: 'none', md: 'flex' },
          alignItems: 'center',
          gap: '1.5rem',
          listStyle: 'none',
          m: 0,
          p: 0,
        })}
      >
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
                class={css({
                  fontSize: '0.95rem',
                  color: 'textMuted',
                  fontWeight: 500,
                  transition: 'color 200ms ease',
                  borderBottom: '2px solid transparent',
                  pb: '2px',
                  _hover: { color: 'text' },
                  '&[aria-current=page]': {
                    color: 'primary',
                    borderBottomColor: 'primary',
                  },
                })}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class={`nav-more ${moreWrap}`}>
          <button
            type="button"
            id="nav-more-btn"
            aria-haspopup="true"
            aria-expanded="false"
            aria-label="More links"
            data-sound="tick"
            class={`nav-more-btn ${moreBtn} ${moreActive ? moreBtnActive : ''}`}
          >
            More
            <Icon name="chevron-down" size={13} strokeWidth={2.5} class="nav-more-chev" />
          </button>
          <div id="nav-more-menu" class={`nav-more-menu ${moreMenuOuter}`}>
            <div class={moreMenuInner} role="menu" aria-label="More">
              {MORE_LINKS.map((link) => (
                <a href={link.href} role="menuitem" aria-current={isActive(link.href) ? 'page' : undefined} class={moreLink}>
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </li>
      </ul>

      <button
        type="button"
        data-search-trigger
        aria-label="Search"
        title="Search (⌘K)"
        class={css({
          display: { base: 'none', md: 'inline-flex' },
          alignItems: 'center',
          gap: '0.45rem',
          h: '34px',
          pl: '0.6rem',
          pr: '0.4rem',
          borderRadius: 'md',
          border: '1px solid token(colors.border)',
          bg: 'bgSubtle',
          color: 'textMuted',
          cursor: 'pointer',
          transition: 'all 150ms ease',
          _hover: { color: 'text', borderColor: 'primary', transform: 'translateY(-1px)' },
        })}
      >
        <Icon name="search" size={15} />
        <kbd
          data-cmdk-hint
          aria-hidden="true"
          class={css({
            fontFamily: 'mono',
            fontSize: '0.68rem',
            lineHeight: 1,
            color: 'textMuted',
            bg: 'bgCard',
            border: '1px solid token(colors.border)',
            borderRadius: 'sm',
            px: '0.3rem',
            py: '0.18rem',
          })}
        >⌘K</kbd>
      </button>

      <SoundToggle />

      <ThemePicker />

      {/* Standalone light/dark/system switch — furthest-right control */}
      <ModeToggle />

      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class={css({
          display: { base: 'inline-flex', md: 'none' },
          alignItems: 'center',
          justifyContent: 'center',
          w: '38px',
          h: '38px',
          borderRadius: 'md',
          border: '1px solid token(colors.border)',
          bg: 'transparent',
          color: 'text',
          cursor: 'pointer',
        })}
      >
        <Icon name="menu" size={20} />
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <ul
    id="mobile-menu"
    hidden
    class={css({
      display: { base: 'flex', md: 'none' },
      flexDirection: 'column',
      gap: '0.25rem',
      listStyle: 'none',
      m: 0,
      px: '1.25rem',
      py: '0.75rem',
      borderTop: '1px solid token(colors.border)',
      bg: 'bg',
    })}
  >
    <li>
      <button
        type="button"
        data-search-trigger
        class={css({
          display: 'flex',
          alignItems: 'center',
          gap: '0.5rem',
          w: '100%',
          py: '0.6rem',
          fontSize: '1rem',
          color: 'textMuted',
          bg: 'transparent',
          border: 'none',
          cursor: 'pointer',
          textAlign: 'left',
          _hover: { color: 'primary' },
        })}
      >
        <Icon name="search" size={16} /> Search
      </button>
    </li>
    {
      NAV_LINKS.map((link) => (
        <li>
          <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined} class={mobileLink}>
            {link.label}
          </a>
        </li>
      ))
    }
    <li class={css({ pt: '0.5rem', mt: '0.3rem', borderTop: '1px solid token(colors.border)' })}>
      <span class={css({ fontFamily: 'sans', fontSize: '0.7rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.1em', color: 'textMuted' })}>More</span>
    </li>
    {
      MORE_LINKS.map((link) => (
        <li>
          <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined} class={mobileLink}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</header>

<script is:inline>
  (function () {
    var toggle = document.getElementById('mobile-menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;
    // Dismiss on outside click / Escape, mirroring ThemePicker. Listeners are
    // attached only while open (capture phase, so the toggle's own click that
    // opened it doesn't immediately re-close it) and removed on close.
    function onDocClick(e) {
      if (!menu.contains(e.target) && !toggle.contains(e.target)) close();
    }
    function onKey(e) {
      if (e.key === 'Escape') { close(); toggle.focus(); }
    }
    function open() {
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.addEventListener('click', onDocClick, true);
      document.addEventListener('keydown', onKey);
    }
    function close() {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      document.removeEventListener('click', onDocClick, true);
      document.removeEventListener('keydown', onKey);
    }
    toggle.addEventListener('click', function () {
      if (menu.hasAttribute('hidden')) open();
      else close();
    });

    // Desktop "More" dropdown: hover/focus open via CSS; click toggles for touch.
    var moreBtn = document.getElementById('nav-more-btn');
    var moreMenu = document.getElementById('nav-more-menu');
    if (moreBtn && moreMenu) {
      function moreClose() {
        moreMenu.removeAttribute('data-open');
        moreBtn.setAttribute('aria-expanded', 'false');
        document.removeEventListener('click', moreDoc, true);
        document.removeEventListener('keydown', moreKey);
      }
      function moreDoc(e) { if (!moreMenu.contains(e.target) && !moreBtn.contains(e.target)) moreClose(); }
      function moreKey(e) { if (e.key === 'Escape') { moreClose(); moreBtn.focus(); } }
      moreBtn.addEventListener('click', function () {
        if (moreMenu.hasAttribute('data-open')) { moreClose(); return; }
        moreMenu.setAttribute('data-open', '');
        moreBtn.setAttribute('aria-expanded', 'true');
        document.addEventListener('click', moreDoc, true);
        document.addEventListener('keydown', moreKey);
      });
    }
  })();
</script>
