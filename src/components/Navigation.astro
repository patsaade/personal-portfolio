---
// Sticky top nav — brand, links, theme picker, mode toggle, mobile menu.
import { css } from 'styled-system/css';
import { NAV_LINKS, DFIR_GROUPS, MORE_LINKS, SITE } from '../consts';
import ThemePicker from './ThemePicker.astro';
import ModeToggle from './ModeToggle.astro';
import SoundToggle from './SoundToggle.astro';
import PixelStar from './PixelStar.astro';
import Icon from './Icon.astro';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
// Two dropdowns — desktop menus, mobile collapsible <details>. Each is a list
// of categories (a category's `label` renders as a small header inside the
// menu; "More" has just one, unlabeled category so it stays a flat list).
const dropdowns = [
  { id: 'dfir', label: 'DFIR', groups: DFIR_GROUPS },
  { id: 'more', label: 'More', groups: [{ category: undefined, links: MORE_LINKS }] },
] as const;
const isAnyActive = (groups: readonly { links: readonly { href: string }[] }[]) =>
  groups.some((g) => g.links.some((l) => isActive(l.href)));
// /dfir/ itself isn't inside any DFIR_GROUPS category's links (it's the
// landing page those categories point AT), so isAnyActive alone would leave
// the "DFIR" trigger looking unselected while actually on that page.
const isDropdownActive = (d: (typeof dropdowns)[number]) =>
  isAnyActive(d.groups) || (d.id === 'dfir' && isActive('/dfir/'));

// Desktop nav "More" dropdown (mirrors the footer's More column). Opens on
// hover/focus via CSS (the `.nav-more` ancestor) and on click/tap via JS.
const moreWrap = css({ position: 'relative', display: 'flex', alignItems: 'center' });
const moreBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.2rem',
  fontFamily: 'inherit',
  fontSize: '0.95rem',
  fontWeight: 500,
  color: 'textMuted',
  bg: 'transparent',
  border: 'none',
  p: 0,
  cursor: 'pointer',
  borderBottom: '2px solid transparent',
  pb: '2px',
  transition: 'color 200ms ease',
  _hover: { color: 'text' },
  '& .nav-more-chev': { transition: 'transform 200ms ease' },
});
const moreBtnActive = css({ color: 'primary', borderBottomColor: 'primary' });
const moreMenuOuter = css({
  position: 'absolute',
  top: '100%',
  right: 0,
  pt: '0.6rem', // transparent hover-bridge so the menu stays open between button and panel
  zIndex: 60,
  // DFIR and More are two separate .nav-more groups whose panels (each
  // min-width ~210px, right: 0) can genuinely overlap in screen space at
  // typical nav widths. Both panels share this same base z-index, so with
  // no further rule, plain DOM order decides the tie — the later-in-markup
  // dropdown (More) always paints on top of the earlier one (DFIR),
  // regardless of which one you're actually interacting with. That means
  // moving the pointer from More back to DFIR hid DFIR's entire 1500ms
  // opening slide behind More's still-fading-out panel — "only one slide
  // visible at a time," and always the wrong one when going in that
  // direction. Fix: whichever dropdown is currently open/opening (hovered,
  // focus-within, or JS-armed via [data-open] for touch) always wins the
  // stacking order over its sibling, so the one you're looking at is always
  // the one you see animate.
  '.nav-more:hover &': { zIndex: 70 },
  '.nav-more:focus-within &': { zIndex: 70 },
  '&[data-open]': { zIndex: 70 },
});
const moreMenuInner = css({
  minW: '210px',
  bg: 'bgCard',
  border: '1px solid token(colors.border)',
  borderRadius: 'lg',
  boxShadow: 'cardHover',
  p: '0.4rem',
  display: 'flex',
  flexDirection: 'column',
  gap: '0.15rem',
});
const menuGroup = css({ listStyle: 'none', m: 0, p: 0 });
const menuGroupLabel = css({
  fontFamily: 'sans',
  fontSize: '0.68rem',
  fontWeight: 700,
  textTransform: 'uppercase',
  letterSpacing: '0.1em',
  color: 'primary',
  px: '0.65rem',
  pt: '0.5rem',
  pb: '0.2rem',
  '& + ul': { mt: 0 },
});
const menuGroupDivider = css({ borderTop: '1px solid token(colors.border)', my: '0.25rem' });
const moreLink = css({
  display: 'block',
  px: '0.65rem',
  py: '0.45rem',
  fontSize: '0.9rem',
  color: 'textMuted',
  borderRadius: 'md',
  whiteSpace: 'nowrap',
  transition: 'color 150ms ease, background 150ms ease',
  _hover: { color: 'primary', bg: 'bgSubtle' },
  '&[aria-current=page]': { color: 'primary', fontWeight: 600 },
});
const mobileLink = css({
  display: 'block',
  py: '0.6rem',
  fontSize: '1rem',
  color: 'textMuted',
  '&[aria-current=page]': { color: 'primary', fontWeight: 600 },
});
const mobileGroupLabel = css({
  fontFamily: 'sans',
  fontSize: '0.65rem',
  fontWeight: 700,
  textTransform: 'uppercase',
  letterSpacing: '0.1em',
  color: 'primary',
  mt: '0.5rem',
  '&:first-child': { mt: 0 },
});
// Mobile collapsible-section header (DFIR / More).
const mobileSummary = css({
  display: 'flex',
  alignItems: 'center',
  justifyContent: 'space-between',
  py: '0.55rem',
  cursor: 'pointer',
  listStyle: 'none',
  fontFamily: 'sans',
  fontSize: '0.7rem',
  fontWeight: 700,
  textTransform: 'uppercase',
  letterSpacing: '0.1em',
  color: 'textMuted',
  '&::-webkit-details-marker': { display: 'none' },
  '&::marker': { display: 'none' },
  '& .mobile-section-chev': { transition: 'transform 200ms ease' },
});
---

<header
  class={css({
    position: 'sticky',
    top: 0,
    zIndex: 50,
    // Same dissolve recipe as the footer (Footer.astro): 55% surface + blur(5px),
    // so the background nodes and any content scrolling behind read through clearly
    // (a heavy blur smears the thin node lines into nothing). The gradient seam
    // below fades the header into the content (mirror of the footer's top seam).
    bg: 'color-mix(in srgb, token(colors.bg) 55%, transparent)',
    backdropFilter: 'blur(5px)',
    borderBottom: '1px solid token(colors.border)',
    _after: {
      content: '""',
      position: 'absolute',
      left: 0,
      right: 0,
      top: '100%',
      height: '1.25rem',
      pointerEvents: 'none',
      background: 'linear-gradient(to bottom, color-mix(in srgb, token(colors.bg) 55%, transparent), transparent)',
    },
  })}
>
  <nav
    class={css({
      maxW: '960px',
      mx: 'auto',
      px: '1.25rem',
      h: '64px',
      display: 'flex',
      alignItems: 'center',
      justifyContent: 'space-between',
      gap: '1rem',
    })}
  >
    <a
      href="/"
      class={css({
        display: 'inline-flex',
        alignItems: 'center',
        gap: '0.45rem',
        fontFamily: 'redaction50',
        fontWeight: 700,
        fontSize: '1.25rem',
        letterSpacing: '-0.01em',
        whiteSpace: 'nowrap',
      })}
    >
      <PixelStar size={17} twinkle={false} class={css({ flexShrink: 0 })} />
      <span class={css({ display: { base: 'inline', sm: 'none' } })}>{SITE.brandShort}</span>
      <span class={css({ display: { base: 'none', sm: 'inline' } })}>{SITE.brand}</span>
    </a>

    <div
      class={css({
        display: 'flex',
        alignItems: 'center',
        gap: { base: '0.5rem', md: '1.5rem' },
      })}
    >
      <ul
        class={css({
          display: { base: 'none', md: 'flex' },
          alignItems: 'center',
          gap: '1.5rem',
          listStyle: 'none',
          m: 0,
          p: 0,
        })}
      >
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
                class={css({
                  fontSize: '0.95rem',
                  color: 'textMuted',
                  fontWeight: 500,
                  transition: 'color 200ms ease',
                  borderBottom: '2px solid transparent',
                  pb: '2px',
                  _hover: { color: 'text' },
                  '&[aria-current=page]': {
                    color: 'primary',
                    borderBottomColor: 'primary',
                  },
                })}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        {dropdowns.map((d) => (
          <li class={`nav-more ${moreWrap}`}>
            <button
              type="button"
              id={`nav-${d.id}-btn`}
              aria-expanded="false"
              aria-controls={`nav-${d.id}-menu`}
              aria-label={`${d.label} links`}
              data-sound="tick"
              class={`nav-more-btn ${moreBtn} ${isDropdownActive(d) ? moreBtnActive : ''}`}
            >
              {d.label}
              <Icon name="chevron-down" size={13} strokeWidth={2.5} class="nav-more-chev" />
            </button>
            <div id={`nav-${d.id}-menu`} class={`nav-more-menu ${moreMenuOuter}`}>
              <div class={moreMenuInner}>
                {d.id === 'dfir' && (
                  <>
                    <a href="/dfir/" aria-current={isActive('/dfir/') ? 'page' : undefined} class={`nav-declassify ${moreLink}`}>
                      Browse all DFIR pages →
                    </a>
                    <div class={menuGroupDivider} />
                  </>
                )}
                {d.groups.map((g, i) => (
                  <>
                    {i > 0 && <div class={menuGroupDivider} />}
                    {g.category && <p class={`nav-declassify ${menuGroupLabel}`}>{g.category}</p>}
                    <ul class={menuGroup} aria-label={g.category ?? d.label}>
                      {g.links.map((link) => (
                        <li>
                          <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined} class={`nav-declassify ${moreLink}`}>
                            {link.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </>
                ))}
              </div>
            </div>
          </li>
        ))}
      </ul>

      <button
        type="button"
        data-search-trigger
        aria-label="Search"
        title="Search (⌘K)"
        class={css({
          display: { base: 'none', md: 'inline-flex' },
          alignItems: 'center',
          gap: '0.45rem',
          h: '34px',
          pl: '0.6rem',
          pr: '0.4rem',
          borderRadius: 'md',
          border: '1px solid token(colors.border)',
          bg: 'bgSubtle',
          color: 'textMuted',
          cursor: 'pointer',
          transition: 'all 150ms ease',
          _hover: { color: 'text', borderColor: 'primary', transform: 'translateY(-1px)' },
        })}
      >
        <Icon name="search" size={15} />
        <kbd
          data-cmdk-hint
          aria-hidden="true"
          class={css({
            fontFamily: 'mono',
            fontSize: '0.68rem',
            lineHeight: 1,
            color: 'textMuted',
            bg: 'bgCard',
            border: '1px solid token(colors.border)',
            borderRadius: 'sm',
            px: '0.3rem',
            py: '0.18rem',
          })}
        >⌘K</kbd>
      </button>

      <SoundToggle />

      <ThemePicker />

      {/* Standalone light/dark/system switch — furthest-right control */}
      <ModeToggle />

      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class={css({
          display: { base: 'inline-flex', md: 'none' },
          alignItems: 'center',
          justifyContent: 'center',
          w: '38px',
          h: '38px',
          borderRadius: 'md',
          border: '1px solid token(colors.border)',
          bg: 'transparent',
          color: 'text',
          cursor: 'pointer',
        })}
      >
        <Icon name="menu" size={20} />
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <ul
    id="mobile-menu"
    hidden
    class={css({
      display: { base: 'flex', md: 'none' },
      flexDirection: 'column',
      gap: '0.25rem',
      listStyle: 'none',
      m: 0,
      px: '1.25rem',
      py: '0.75rem',
      borderTop: '1px solid token(colors.border)',
      bg: 'bg',
    })}
  >
    <li>
      <button
        type="button"
        data-search-trigger
        class={css({
          display: 'flex',
          alignItems: 'center',
          gap: '0.5rem',
          w: '100%',
          py: '0.6rem',
          fontSize: '1rem',
          color: 'textMuted',
          bg: 'transparent',
          border: 'none',
          cursor: 'pointer',
          textAlign: 'left',
          _hover: { color: 'primary' },
        })}
      >
        <Icon name="search" size={16} /> Search
      </button>
    </li>
    {
      NAV_LINKS.map((link) => (
        <li>
          <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined} class={mobileLink}>
            {link.label}
          </a>
        </li>
      ))
    }
    {
      dropdowns.map((d) => (
        <li class={css({ borderTop: '1px solid token(colors.border)' })}>
          <details class="nav-mobile-section" name="nav-mobile-accordion">
            <summary class={mobileSummary}>
              {d.label}
              <Icon name="chevron-down" size={15} class="mobile-section-chev" />
            </summary>
            <div class={css({ display: 'flex', flexDirection: 'column', pl: '0.5rem', pb: '0.3rem' })}>
              {d.id === 'dfir' && (
                <a href="/dfir/" aria-current={isActive('/dfir/') ? 'page' : undefined} class={mobileLink}>
                  Browse all DFIR pages →
                </a>
              )}
              {d.groups.map((g) => (
                <>
                  {g.category && <p class={mobileGroupLabel}>{g.category}</p>}
                  {g.links.map((link) => (
                    <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined} class={mobileLink}>
                      {link.label}
                    </a>
                  ))}
                </>
              ))}
            </div>
          </details>
        </li>
      ))
    }
  </ul>
</header>

<script>
  // @ts-nocheck — vanilla DOM client script
  (function () {
    var toggle = document.getElementById('mobile-menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;
    // Dismiss on outside click / Escape, mirroring ThemePicker. Listeners are
    // attached only while open (capture phase, so the toggle's own click that
    // opened it doesn't immediately re-close it) and removed on close.
    function onDocClick(e) {
      if (!menu.contains(e.target) && !toggle.contains(e.target)) close();
    }
    function onKey(e) {
      if (e.key === 'Escape') { close(); toggle.focus(); }
    }
    function open() {
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.addEventListener('click', onDocClick, true);
      document.addEventListener('keydown', onKey);
    }
    function close() {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      document.removeEventListener('click', onDocClick, true);
      document.removeEventListener('keydown', onKey);
    }
    toggle.addEventListener('click', function () {
      if (menu.hasAttribute('hidden')) open();
      else close();
    });

    // Desktop dropdowns (Analyst / More): hover/focus open via CSS; click toggles
    // for touch. One handler per .nav-more group; opening one closes the others.
    var groups = Array.prototype.slice.call(document.querySelectorAll('.nav-more'));
    groups.forEach(function (group) {
      var btn = group.querySelector('.nav-more-btn');
      var menu = group.querySelector('.nav-more-menu');
      if (!btn || !menu) return;
      function closeGroup() {
        menu.removeAttribute('data-open');
        btn.setAttribute('aria-expanded', 'false');
        document.removeEventListener('click', onDoc, true);
        document.removeEventListener('keydown', onEsc);
      }
      function onDoc(e) { if (!menu.contains(e.target) && !btn.contains(e.target)) closeGroup(); }
      function onEsc(e) { if (e.key === 'Escape') { closeGroup(); btn.focus(); } }
      btn.addEventListener('click', function () {
        var wasOpen = menu.hasAttribute('data-open');
        // Close any other open dropdown first.
        groups.forEach(function (g) {
          var m = g.querySelector('.nav-more-menu');
          var b = g.querySelector('.nav-more-btn');
          if (m) m.removeAttribute('data-open');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        if (wasOpen) return;
        menu.setAttribute('data-open', '');
        btn.setAttribute('aria-expanded', 'true');
        document.addEventListener('click', onDoc, true);
        document.addEventListener('keydown', onEsc);
      });
    });
  })();
</script>
