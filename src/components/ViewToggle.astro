---
// List / Matrix view switch for the ATT&CK Map and D3FEND Map. A single
// segmented-switch control — same visual language as ModeToggle's
// light/dark/system switch (bordered track, active segment gets bgCard +
// primary + shadow, inactive segments sit flat) — so it reads as ONE switch
// with an obvious current position, not two independent buttons. JS-armed:
// the switch stays hidden and the list view is the only visible content
// until the script runs, so a no-JS reader gets the complete, already-
// functional list view with no missing control and no broken half-state
// (same philosophy as CollapseAll). The choice persists per page via
// localStorage.
import { css } from 'styled-system/css';
import Icon from './Icon.astro';

interface Props {
  listTarget: string;
  matrixTarget: string;
  storageKey: string;
}
const { listTarget, matrixTarget, storageKey } = Astro.props;

const track = css({
  position: 'relative', // containing block + stacking context for the animated switch thumb (see AnimatedSwitch)
  zIndex: 0,
  display: 'none', // revealed by the script
  gap: '0.15rem',
  p: '0.2rem',
  bg: 'bgSubtle',
  border: '1px solid token(colors.border)',
  borderRadius: 'md',
  '&[data-ready]': { display: 'inline-flex' },
});
const segBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '0.35rem',
  px: '0.6rem',
  py: '0.3rem',
  fontFamily: 'sans',
  fontSize: '0.8rem',
  fontWeight: 600,
  borderRadius: 'sm',
  border: '1px solid transparent',
  bg: 'transparent',
  color: 'textMuted',
  cursor: 'pointer',
  transition: 'all 150ms ease',
  _hover: { color: 'text', transform: 'translateY(-1px)' },
  '&[data-active]': {
    bg: 'bgCard',
    color: 'primary',
    borderColor: 'border',
    boxShadow: 'card',
  },
  // Once armed, this button's own bg/border/shadow is suppressed by a
  // hand-written global rule in motion.css (Panda's css() can't express the
  // compound ancestor+self condition needed — see that rule's comment).
});
---

<div
  role="radiogroup"
  aria-label="View"
  class={track}
  data-view-toggle
  data-list-target={listTarget}
  data-matrix-target={matrixTarget}
  data-storage-key={storageKey}
>
  <button type="button" role="radio" aria-checked="true" data-active data-view-btn="list" data-sound="tick" class={segBtn}>
    <Icon name="list" size={14} /> List
  </button>
  <button type="button" role="radio" aria-checked="false" data-view-btn="matrix" data-sound="tick" class={segBtn}>
    <Icon name="grid" size={14} /> Matrix
  </button>
</div>

<script>
  // @ts-nocheck — vanilla DOM client script
  (function () {
    function init() {
      var groups = document.querySelectorAll('[data-view-toggle]:not([data-ready])');
      Array.prototype.forEach.call(groups, function (group) {
        var listEl = document.querySelector(group.getAttribute('data-list-target'));
        var matrixEl = document.querySelector(group.getAttribute('data-matrix-target'));
        var key = group.getAttribute('data-storage-key');
        var listBtn = group.querySelector('[data-view-btn="list"]');
        var matrixBtn = group.querySelector('[data-view-btn="matrix"]');
        if (!listEl || !matrixEl || !listBtn || !matrixBtn) return;

        function show(view) {
          var wantMatrix = view === 'matrix';
          if (wantMatrix) { listEl.hidden = true; matrixEl.hidden = false; }
          else { matrixEl.hidden = true; listEl.hidden = false; }
          [
            [listBtn, !wantMatrix],
            [matrixBtn, wantMatrix],
          ].forEach(function (pair) {
            var btn = pair[0], active = pair[1];
            if (active) btn.setAttribute('data-active', '');
            else btn.removeAttribute('data-active');
            btn.setAttribute('aria-checked', String(active));
          });
          try { localStorage.setItem(key, view); } catch (e) {}
        }

        listBtn.addEventListener('click', function () { show('list'); });
        matrixBtn.addEventListener('click', function () { show('matrix'); });

        var saved = null;
        try { saved = localStorage.getItem(key); } catch (e) {}
        if (saved === 'matrix') show('matrix');

        group.setAttribute('data-ready', '');
      });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
