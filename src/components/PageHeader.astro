---
// Section page header — optional breadcrumb trail, eyebrow label, title, and description.
import { css } from 'styled-system/css';
import Breadcrumbs from './Breadcrumbs.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  breadcrumbs?: { label: string; href?: string }[];
}
const { eyebrow, title, description, breadcrumbs } = Astro.props;
---

<header class={css({ mb: '2.5rem' })}>
  {breadcrumbs && breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
  {
    eyebrow && (
      <p
        class={css({
          fontFamily: 'sans',
          fontSize: '0.8rem',
          textTransform: 'uppercase',
          letterSpacing: '0.1em',
          color: 'primary',
          mb: '0.5rem',
        })}
      >
        {eyebrow}
      </p>
    )
  }
  <h1
    class={`declassify ${css({
      fontSize: { base: '2rem', md: '2.75rem' },
      fontWeight: 700,
      letterSpacing: '-0.02em',
      lineHeight: 1.1,
    })}`}
  >
    {title}
  </h1>
  {
    description && (
      <p class={css({ fontSize: '1.1rem', color: 'textMuted', mt: '0.75rem', maxW: '640px' })}>
        {description}
      </p>
    )
  }
</header>
