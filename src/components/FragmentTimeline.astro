---
// Decorative hero illustration: abstract evidence fragments settle in, then
// dashed tracers connect them down to a resolved timeline axis with event
// nodes — a visual echo of "reconstructing a timeline from scattered
// artifacts" without depicting any real case data (every shape is
// unlabeled/generic on purpose). Purely decorative: aria-hidden, no props,
// no real content — the hero heading/paragraph beside it carries the actual
// information. Settle-in animation lives in motion.css (`.ft-fragment`,
// `.ft-tracer`, `.ft-node`), staggered via inline animation-delay — the same
// per-element stagger technique PixelStar already uses for its twinkle.
// Colors reference the live theme's CSS custom properties directly
// (var(--colors-*)) since Panda's css() doesn't reach raw SVG attributes.
interface Props {
  class?: string;
}
const { class: cls } = Astro.props;

const FRAGMENTS = [
  { x: 40, y: 40, rot: -8 },
  { x: 150, y: 24, rot: 10 },
  { x: 258, y: 54, rot: -5 },
  { x: 344, y: 28, rot: 13 },
  { x: 418, y: 68, rot: -11 },
  { x: 92, y: 112, rot: 6 },
  { x: 300, y: 116, rot: -9 },
];
const NODES = [
  { x: 80, r: 5 },
  { x: 168, r: 5 },
  { x: 256, r: 5 },
  { x: 344, r: 5 },
  { x: 412, r: 7, current: true },
];
const AXIS_Y = 340;
---

<svg viewBox="0 0 480 420" class={`ft-svg ${cls ?? ''}`} aria-hidden="true" focusable="false">
  {/* Tracers: each fragment down to its axis node */}
  {
    FRAGMENTS.map((f, i) => (
      <line
        x1={f.x + 17}
        y1={f.y + 20}
        x2={NODES[i % NODES.length].x}
        y2={AXIS_Y}
        class="ft-tracer"
        style={`animation-delay:${260 + i * 70}ms; stroke: var(--colors-primary);`}
        stroke-width="1"
        stroke-dasharray="3 4"
      />
    ))
  }

  {/* Fragments — small unlabeled evidence-chip shapes */}
  {
    FRAGMENTS.map((f, i) => (
      <g transform={`translate(${f.x}, ${f.y}) rotate(${f.rot})`} class="ft-fragment" style={`animation-delay:${i * 70}ms`}>
        <rect
          width="34"
          height="20"
          rx="3"
          style="fill: var(--colors-bg-card); stroke: var(--colors-border);"
          stroke-width="1.5"
        />
      </g>
    ))
  }

  {/* Resolved timeline axis */}
  <line x1="40" y1={AXIS_Y} x2="440" y2={AXIS_Y} class="ft-axis" style="stroke: var(--colors-primary);" stroke-width="2" />

  {/* Event nodes along the axis */}
  {
    NODES.map((n, i) => (
      <circle
        cx={n.x}
        cy={AXIS_Y}
        r={n.r}
        class="ft-node"
        style={`animation-delay:${520 + i * 60}ms; fill: var(--colors-primary); --ft-end-opacity: ${n.current ? 1 : 0.55};`}
      />
    ))
  }
</svg>

<script>
  // @ts-nocheck — vanilla DOM script
  (function () {
    var motionOk = !window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!motionOk) return;
    var svgs = document.querySelectorAll('.ft-svg');
    if (!svgs.length) return;
    // Hand off to the idle pulse (motion.css) only once the settle-in above has
    // fully finished — last node's animation-delay (760ms) + its own 380ms
    // duration — so there's no visible jump between the two animations.
    setTimeout(function () {
      svgs.forEach(function (svg) {
        svg.classList.add('ft-idle');
      });
    }, 1300);
  })();
</script>
