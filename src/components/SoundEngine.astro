---
// Tiny Web Audio synth for opt-in interface sounds. No assets, no dependency —
// short oscillator "blips" generated on the fly. Sound is OFF by default and only
// ever plays after the user enables it (a user gesture), so autoplay policies and
// quiet-by-default expectations are both respected. Exposes window.__sound, used
// by SoundToggle; a delegated listener blips on header + copy-button clicks.
---

<script is:inline>
  (function () {
    if (window.__sound) return;
    var KEY = 'sound';
    var enabled = false;
    try { enabled = localStorage.getItem(KEY) === 'on'; } catch (e) {}

    var ctx = null;
    function ensureCtx() {
      if (ctx) return ctx;
      var AC = window.AudioContext || window['webkitAudioContext'];
      if (!AC) return null;
      try { ctx = new AC(); } catch (e) { ctx = null; }
      return ctx;
    }

    // One short, soft blip. Low gain + fast decay keep it a tick, not a beep.
    function blip(o) {
      if (!enabled) return;
      var c = ensureCtx();
      if (!c) return;
      if (c.state === 'suspended' && c.resume) c.resume();
      var t = c.currentTime;
      var dur = o.dur || 0.07;
      var osc = c.createOscillator();
      var gain = c.createGain();
      osc.type = o.type || 'sine';
      osc.frequency.setValueAtTime(o.freq || 600, t);
      if (o.freq2) osc.frequency.exponentialRampToValueAtTime(o.freq2, t + dur);
      gain.gain.setValueAtTime(0.0001, t);
      gain.gain.exponentialRampToValueAtTime(o.vol || 0.05, t + 0.005);
      gain.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      osc.connect(gain);
      gain.connect(c.destination);
      osc.start(t);
      osc.stop(t + dur + 0.02);
    }

    var SOUNDS = {
      tick: { freq: 520, freq2: 700, type: 'triangle', dur: 0.05, vol: 0.045 },
      on: { freq: 480, freq2: 900, type: 'sine', dur: 0.13, vol: 0.06 },
      copy: { freq: 720, freq2: 1080, type: 'triangle', dur: 0.08, vol: 0.05 },
    };

    window.__sound = {
      isEnabled: function () { return enabled; },
      play: function (name) { blip(SOUNDS[name] || SOUNDS.tick); },
      set: function (on) {
        enabled = !!on;
        try { localStorage.setItem(KEY, enabled ? 'on' : 'off'); } catch (e) {}
        document.dispatchEvent(new CustomEvent('soundchange'));
        // The toggle click is a user gesture, so this confirming chirp is allowed.
        if (enabled) { ensureCtx(); blip(SOUNDS.on); }
      },
      toggle: function () { this.set(!enabled); },
    };

    // Ambient blips on the chrome the user actually clicks. Capture phase so it
    // still fires if a handler stops propagation. The sound toggle is excluded —
    // set() already chirps when turning on, and off should be silent.
    document.addEventListener(
      'click',
      function (e) {
        if (!enabled) return;
        var el = e.target && e.target.closest ? e.target.closest('header button, header a[href], .copy-btn') : null;
        if (!el || el.closest('[data-sound-toggle]')) return;
        window.__sound.play(el.classList.contains('copy-btn') ? 'copy' : 'tick');
      },
      true,
    );
  })();
</script>
