---
import { css } from 'styled-system/css';
import { DARK_THEMES, LIGHT_THEMES, type Theme } from '../themes';
import Icon from './Icon.astro';

// The picker sets a *preferred* palette for each mode independently; it does not
// change the active light/dark mode (that's the ModeToggle's job).
const groups: { label: string; themes: Theme[] }[] = [
  { label: 'Dark mode', themes: DARK_THEMES },
  { label: 'Light mode', themes: LIGHT_THEMES },
];

// Each mode's palette list is its own vertical segmented switch — the shared
// site-wide AnimatedSwitch (src/scripts/animatedSwitch.ts) auto-wires any
// role="radiogroup" it finds, sliding a thumb behind the active item; a
// group with aria-orientation="vertical" (below) slides that thumb down the
// column instead of across a row, which is the same attribute these lists
// already need for their own arrow-key nav. `position:'relative', zIndex:0`
// on the group is the one CSS change every switch needs (see that file's
// retrofit contract).
const paletteGroup = css({ position: 'relative', zIndex: 0, display: 'flex', flexDirection: 'column', gap: '0.1rem' });
const itemClass = css({
  display: 'flex',
  alignItems: 'center',
  gap: '0.5rem',
  w: '100%',
  px: '0.45rem',
  py: '0.4rem',
  borderRadius: 'md',
  border: '1px solid transparent',
  bg: 'transparent',
  color: 'text',
  cursor: 'pointer',
  textAlign: 'left',
  transition: 'background 150ms ease, border-color 150ms ease',
  _hover: { bg: 'bgSubtle' },
  '&[data-active]': { borderColor: 'primary', bg: 'bgSubtle' },
  // Once armed, this button's own bg/border is suppressed by a hand-written
  // global rule in motion.css (Panda's css() can't express the compound
  // ancestor+self condition needed — see that rule's comment).
});
---

<div class={css({ position: 'relative' })} data-theme-picker>
  <button
    id="theme-picker-btn"
    type="button"
    aria-haspopup="true"
    aria-expanded="false"
    aria-label="Choose color theme"
    class={css({
      display: 'inline-flex',
      alignItems: 'center',
      gap: '0.3rem',
      h: '38px',
      px: '0.6rem',
      borderRadius: 'md',
      border: '1px solid token(colors.border)',
      bg: 'transparent',
      color: 'textMuted',
      cursor: 'pointer',
      transition: 'all 200ms ease',
      _hover: { color: 'primary', borderColor: 'primary', bg: 'bgSubtle', transform: 'translateY(-1px)' },
    })}
  >
    <Icon name="palette" size={18} />
    <Icon name="chevron-down" size={12} strokeWidth={2.5} class={css({ display: { base: 'none', sm: 'block' } })} />
  </button>

  <div
    id="theme-picker-menu"
    aria-label="Color themes"
    hidden
    class={css({
      // Mobile: the picker button sits mid-nav, so a button-anchored popover ran
      // off the left edge. Pin it across the top instead (fixed, symmetric 1rem
      // margins, just below the 64px-tall header). The header has backdrop-filter,
      // which makes IT the containing block for this fixed menu — so `top` is
      // measured from the header's own box, and `64px + 8px` lands 8px below it
      // automatically, even when the term-of-the-day ticker pushes the page down.
      position: { base: 'fixed', sm: 'absolute' },
      top: { base: 'calc(64px + 8px)', sm: 'calc(100% + 8px)' },
      left: { base: '1rem', sm: 'auto' },
      right: { base: '1rem', sm: 0 },
      zIndex: 60,
      w: { base: 'auto', sm: '380px' },
      p: '0.75rem',
      bg: 'bgCard',
      border: '1px solid token(colors.border)',
      borderRadius: 'lg',
      boxShadow: 'cardHover',
    })}
  >
    <p
      class={css({
        fontSize: '0.72rem',
        color: 'textMuted',
        px: '0.45rem',
        pb: '0.6rem',
        lineHeight: 1.4,
      })}
    >
      Your theme for each mode. Switch light/dark with the toggle.
    </p>
    <div class={css({ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '0.75rem' })}>
      {
        groups.map((group) => (
          <div>
            <p
              class={css({
                fontFamily: 'sans',
                fontSize: '0.62rem',
                fontWeight: 700,
                textTransform: 'uppercase',
                letterSpacing: '0.1em',
                color: 'textMuted',
                px: '0.45rem',
                pb: '0.4rem',
              })}
            >
              {group.label}
            </p>
            <div class={paletteGroup} role="radiogroup" aria-orientation="vertical" aria-label={group.label}>
              {group.themes.map((theme) => (
                <button
                  type="button"
                  role="radio"
                  aria-checked="false"
                  title={theme.blurb}
                  class={itemClass}
                  data-theme-id={theme.id}
                  data-theme-mode={theme.mode}
                >
                  <span
                    class={css({
                      display: 'inline-flex',
                      flexShrink: 0,
                      borderRadius: '5px',
                      overflow: 'hidden',
                      border: '1px solid token(colors.border)',
                      w: '24px',
                      h: '24px',
                    })}
                    aria-hidden="true"
                  >
                    <span style={`background:${theme.colors.bg};width:45%`} />
                    <span style={`background:${theme.colors.primary};width:30%`} />
                    <span style={`background:${theme.colors.accent};width:25%`} />
                  </span>
                  <span
                    class={css({
                      flex: 1,
                      minW: 0,
                      fontSize: '0.8rem',
                      fontWeight: 500,
                      whiteSpace: 'nowrap',
                      overflow: 'hidden',
                      textOverflow: 'ellipsis',
                    })}
                  >
                    {theme.name}
                  </span>
                  <Icon
                    name="check"
                    size={14}
                    strokeWidth={3}
                    class={`check-icon ${css({ flexShrink: 0, color: 'primary', visibility: 'hidden' })}`}
                  />
                </button>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  // @ts-nocheck — vanilla DOM client script
  (function () {
    var wrap = document.querySelector('[data-theme-picker]');
    if (!wrap || !window.__theme) return;
    var btn = document.getElementById('theme-picker-btn');
    var menu = document.getElementById('theme-picker-menu');
    var paletteItems = Array.prototype.slice.call(menu.querySelectorAll('[data-theme-id]'));
    // Two independent radiogroups (Dark mode, Light mode) — arrow-key cycling
    // below stays scoped to whichever one currently has focus, matching
    // standard radiogroup behavior (Tab moves *between* groups, arrow keys
    // move *within* one).
    var radioGroups = Array.prototype.slice.call(menu.querySelectorAll('[role="radiogroup"]'));

    function syncUI() {
      // Each column shows the preferred palette for its mode, independent of which
      // mode is currently active. Setting data-active is also what the shared
      // AnimatedSwitch (src/scripts/animatedSwitch.ts) reacts to — it slides
      // each group's thumb to whichever item this marks active, no extra
      // wiring needed here.
      var prefDark = window.__theme.getPalette('dark');
      var prefLight = window.__theme.getPalette('light');
      paletteItems.forEach(function (item) {
        var id = item.getAttribute('data-theme-id');
        var mode = item.getAttribute('data-theme-mode');
        var selected = id === (mode === 'dark' ? prefDark : prefLight);
        if (selected) item.setAttribute('data-active', '');
        else item.removeAttribute('data-active');
        item.setAttribute('aria-checked', selected ? 'true' : 'false');
        var check = item.querySelector('.check-icon');
        if (check) check.style.visibility = selected ? 'visible' : 'hidden';
      });
    }

    function open() {
      menu.removeAttribute('hidden');
      btn.setAttribute('aria-expanded', 'true');
      syncUI();
      document.addEventListener('click', onDocClick, true);
      document.addEventListener('keydown', onKey);
      // Move focus into the menu — land on the selected item per group when
      // possible, else the first item.
      var target = paletteItems[0];
      for (var i = 0; i < paletteItems.length; i++) {
        if (paletteItems[i].hasAttribute('data-active')) { target = paletteItems[i]; break; }
      }
      if (target) target.focus();
    }
    function close() {
      menu.setAttribute('hidden', '');
      btn.setAttribute('aria-expanded', 'false');
      document.removeEventListener('click', onDocClick, true);
      document.removeEventListener('keydown', onKey);
    }
    function onDocClick(e) { if (!wrap.contains(e.target)) close(); }
    function currentGroupItems() {
      var active = document.activeElement;
      var group = radioGroups.filter(function (g) { return g.contains(active); })[0];
      return group ? Array.prototype.slice.call(group.querySelectorAll('[data-theme-id]')) : paletteItems;
    }
    function moveFocus(delta) {
      var items = currentGroupItems();
      var idx = items.indexOf(document.activeElement);
      if (idx === -1) idx = 0;
      var next = (idx + delta + items.length) % items.length;
      items[next].focus();
    }
    function onKey(e) {
      if (e.key === 'Escape') { close(); btn.focus(); return; }
      // Arrow-key + Home/End cycling, scoped to whichever group currently has
      // focus, per the ARIA radiogroup pattern these roles advertise to
      // assistive tech.
      if (e.key === 'ArrowDown') { e.preventDefault(); moveFocus(1); return; }
      if (e.key === 'ArrowUp') { e.preventDefault(); moveFocus(-1); return; }
      if (e.key === 'Home') { e.preventDefault(); currentGroupItems()[0].focus(); return; }
      if (e.key === 'End') { e.preventDefault(); var items = currentGroupItems(); items[items.length - 1].focus(); return; }
    }

    btn.addEventListener('click', function () {
      if (menu.hasAttribute('hidden')) open();
      else close();
    });

    paletteItems.forEach(function (item) {
      item.addEventListener('click', function () {
        // Set the preference for this palette's mode. Keep the menu open so the
        // user can set both their light and dark themes in one go; syncUI runs
        // via the themechange event below.
        window.__theme.setPalette(item.getAttribute('data-theme-id'));
      });
    });

    // Stay in sync when the mode toggle (or a palette pick) changes state.
    document.addEventListener('themechange', syncUI);
    syncUI();
  })();
</script>
