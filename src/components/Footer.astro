---
// Site footer — brand + social, two link columns, and a version/commit line.
import { css } from 'styled-system/css';
import { SITE, SOCIALS, NAV_LINKS, MORE_LINKS } from '../consts';
import { VERSION, SHORT_COMMIT, COMMIT_URL } from '../utils/version';
import PixelStar from './PixelStar.astro';
import Icon from './Icon.astro';

const year = new Date().getFullYear();

const colHead = css({
  fontFamily: 'sans',
  fontSize: '0.7rem',
  textTransform: 'uppercase',
  letterSpacing: '0.12em',
  color: 'textMuted',
  mb: '0.9rem',
});
const fLink = css({
  display: 'block',
  fontSize: '0.9rem',
  color: 'textMuted',
  py: '0.22rem',
  transition: 'color 150ms ease',
  _hover: { color: 'primary' },
});
const socialBtn = css({
  display: 'inline-flex',
  alignItems: 'center',
  justifyContent: 'center',
  w: '34px',
  h: '34px',
  borderRadius: 'md',
  border: '1px solid token(colors.border)',
  color: 'textMuted',
  transition: 'color 200ms ease, border-color 200ms ease, transform 200ms ease',
  _hover: { color: 'primary', borderColor: 'primary', transform: 'translateY(-2px)' },
});

const moreLinks = MORE_LINKS;
---

<footer
  class={css({
    position: 'relative',
    borderTop: '1px solid token(colors.border)',
    mt: '5rem',
    // Translucent + frosted so the ambient node-field (and any content behind)
    // shows through as a soft blurred ghost — the page dissolves into the footer
    // instead of hitting a flat slab. Same dissolve recipe as the header (see
    // Navigation.astro): 55% surface + blur(5px) (lower opacity and a lighter blur
    // let the background nodes read through clearly — a heavy blur smears the thin
    // node lines into nothing). The gradient seam fades the content above into the
    // footer's top edge.
    bg: 'color-mix(in srgb, token(colors.bgSubtle) 55%, transparent)',
    backdropFilter: 'blur(5px)',
    _before: {
      content: '""',
      position: 'absolute',
      left: 0,
      right: 0,
      top: '-2.5rem',
      height: '2.5rem',
      pointerEvents: 'none',
      background: 'linear-gradient(to bottom, transparent, color-mix(in srgb, token(colors.bgSubtle) 55%, transparent))',
    },
  })}
>
  <div
    class={css({
      maxW: '960px',
      mx: 'auto',
      px: '1.25rem',
      py: '3rem',
      display: 'grid',
      gridTemplateColumns: { base: '1fr', sm: '1.6fr 1fr 1fr' },
      gap: { base: '2rem', sm: '2.5rem' },
    })}
  >
    {/* Brand + social */}
    <div>
      <a
        href="/"
        class={css({ display: 'inline-flex', alignItems: 'center', gap: '0.45rem', fontFamily: 'redaction50', fontWeight: 700, fontSize: '1.2rem', color: 'text', letterSpacing: '-0.01em', _hover: { color: 'primary' } })}
      >
        <PixelStar size={16} class={css({ flexShrink: 0 })} />
        {SITE.brand}
      </a>
      <p class={css({ fontSize: '0.875rem', color: 'textMuted', mt: '0.6rem', lineHeight: 1.65, maxW: '320px' })}>
        {SITE.tagline} — writeups, labs, tooling, and a daily security term.
      </p>
      <div class={css({ display: 'flex', gap: '0.6rem', mt: '1.4rem' })}>
        <a href={SOCIALS.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class={socialBtn}><Icon name="linkedin" size={17} /></a>
        <a href={SOCIALS.github} target="_blank" rel="noopener" aria-label="GitHub" class={socialBtn}><Icon name="github" size={17} /></a>
        <a href={SOCIALS.credly} target="_blank" rel="noopener" aria-label="Credly" class={socialBtn}><Icon name="award" size={17} /></a>
        <a href="/rss.xml" aria-label="RSS feed" class={socialBtn}><Icon name="rss" size={16} /></a>
      </div>
    </div>

    {/* Explore */}
    <nav aria-label="Footer — site sections">
      <p class={colHead}>Explore</p>
      {NAV_LINKS.map((l) => <a href={l.href} class={fLink}>{l.label}</a>)}
    </nav>

    {/* More */}
    <nav aria-label="Footer — more">
      <p class={colHead}>More</p>
      {moreLinks.map((l) => <a href={l.href} class={fLink}>{l.label}</a>)}
    </nav>
  </div>

  {/* Bottom bar */}
  <div class={css({ borderTop: '1px solid token(colors.border)' })}>
    <div
      class={css({
        maxW: '960px',
        mx: 'auto',
        px: '1.25rem',
        py: '1.1rem',
        display: 'flex',
        flexDirection: { base: 'column', sm: 'row' },
        justifyContent: 'space-between',
        alignItems: { base: 'flex-start', sm: 'center' },
        gap: '0.6rem',
        fontSize: '0.8rem',
        color: 'textMuted',
      })}
    >
      <span>© {year} {SITE.author}. Built with Astro + Panda CSS.</span>

      {/* Live status line — a forensic/terminal touch. The UTC clock ties to the
          UTC-keyed Term of the Day, which rolls over at 00:00 UTC. */}
      <span
        class={css({ display: 'inline-flex', alignItems: 'center', gap: '0.4rem', fontFamily: 'mono', fontSize: '0.72rem', color: 'textMuted' })}
      >
        <span
          class={`totd-pulse-dot ${css({ w: '6px', h: '6px', borderRadius: 'full', bg: 'primary', flexShrink: 0 })}`}
          style="animation: totd-pulse 2.4s ease-in-out infinite;"
          aria-hidden="true"
        ></span>
        <span id="footer-utc">UTC&nbsp;--:--:--</span>
        <span aria-hidden="true" class={css({ color: 'border' })}>·</span>
        <span>static</span>
      </span>

      <a
        href={COMMIT_URL}
        target="_blank"
        rel="noopener"
        aria-label={`Version ${VERSION}${SHORT_COMMIT ? `, commit ${SHORT_COMMIT}` : ''} on GitHub`}
        class={css({
          fontFamily: 'mono',
          fontSize: '0.75rem',
          color: 'textMuted',
          display: 'inline-flex',
          alignItems: 'center',
          gap: '0.4rem',
          transition: 'color 150ms ease',
          _hover: { color: 'primary' },
        })}
      >
        <Icon name="github" size={13} />
        {VERSION}{SHORT_COMMIT ? ` · ${SHORT_COMMIT}` : ''}
      </a>
    </div>
  </div>

  <script is:inline>
    (function () {
      var el = document.getElementById('footer-utc');
      if (!el) return;
      function pad(n) { return n < 10 ? '0' + n : '' + n; }
      function tick() {
        if (document.hidden) return; // don't churn while backgrounded
        var d = new Date();
        el.textContent = 'UTC ' + pad(d.getUTCHours()) + ':' + pad(d.getUTCMinutes()) + ':' + pad(d.getUTCSeconds());
      }
      tick();
      setInterval(tick, 1000);
      document.addEventListener('visibilitychange', tick);
    })();
  </script>
</footer>
