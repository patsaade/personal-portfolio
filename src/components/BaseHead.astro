---
import { SITE, SOCIALS } from '../consts';
import { THEME_MODES, THEME_BG, DEFAULT_DARK, DEFAULT_LIGHT } from '../themes';
import { ogSlugForPath } from '../og/routes';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  /** Set when an article has a real update, distinct from its publish date. */
  updatedDate?: Date;
  /** Article-only: topic tags, surfaced as BlogPosting `keywords`. */
  tags?: string[];
  /** Article-only: the post's category, surfaced as BlogPosting `articleSection`. */
  section?: string;
  /** Override for pages that shouldn't be indexed (e.g. the 404 page). */
  robots?: string;
}

const {
  title,
  description = SITE.description,
  image,
  type = 'website',
  publishedDate,
  updatedDate,
  tags,
  section,
  robots = 'index, follow, max-image-preview:large',
} = Astro.props;

const pageTitle = title ? `${title} · ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE.url);
// Social card: a per-page image generated at build by /og/[...slug].png (matched
// to this route), unless a page passes an explicit `image`.
const ogImage = new URL(image ?? `/og/${ogSlugForPath(Astro.url.pathname)}.png`, Astro.site ?? SITE.url);
const ogImageAlt = title ? `${title} — ${SITE.author}` : `${SITE.author} — ${SITE.tagline}`;

// Structured data (JSON-LD): a Person + WebSite graph site-wide, plus a
// BlogPosting node on article pages. Helps search engines and rich results.
const personId = `${SITE.url}/#person`;
const graph: Record<string, unknown>[] = [
  {
    '@type': 'Person',
    '@id': personId,
    name: SITE.author,
    url: SITE.url,
    jobTitle: 'Senior Information Security Analyst',
    sameAs: [SOCIALS.linkedin, SOCIALS.github, SOCIALS.credly],
  },
  {
    '@type': 'WebSite',
    '@id': `${SITE.url}/#website`,
    url: SITE.url,
    name: SITE.title,
    description: SITE.description,
    inLanguage: 'en',
    publisher: { '@id': personId },
  },
];
if (type === 'article') {
  graph.push({
    '@type': 'BlogPosting',
    headline: title,
    description,
    image: ogImage.toString(),
    datePublished: publishedDate?.toISOString(),
    // Falls back to datePublished when the post has no real edit — dateModified
    // should never be absent or earlier than datePublished on an article.
    dateModified: (updatedDate ?? publishedDate)?.toISOString(),
    ...(tags && tags.length ? { keywords: tags.join(', ') } : {}),
    ...(section ? { articleSection: section } : {}),
    author: { '@id': personId },
    publisher: { '@id': personId },
    mainEntityOfPage: canonicalURL.toString(),
  });
}
// `.replace` escapes `<` so authored content can never break out of the <script> tag.
const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph }).replace(/</g, '\\u003c');
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />
<meta name="robots" content={robots} />
<meta name="theme-color" content="#1b1518" />
<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE.title}
  href={new URL('rss.xml', Astro.site ?? SITE.url)}
/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Preload the always-visible Redaction faces: body (grade 0) + wordmark (grade 50). -->
<link rel="preload" href="/fonts/redaction/redaction-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/redaction/redaction-50-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />

<!-- Structured data -->
<script type="application/ld+json" is:inline set:html={jsonLd} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:secure_url" content={ogImage} />
<meta property="og:site_name" content={SITE.title} />
{publishedDate && (
  <meta property="article:published_time" content={publishedDate.toISOString()} />
)}
{updatedDate && (
  <meta property="article:modified_time" content={updatedDate.toISOString()} />
)}

<!-- Twitter / X card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<!-- Theme controller. Runs before first paint to avoid flash; exposes window.__theme. -->
<script is:inline define:vars={{ THEME_MODES, THEME_BG, DEFAULT_DARK, DEFAULT_LIGHT }}>
  (function () {
    var root = document.documentElement;
    var mql = window.matchMedia('(prefers-color-scheme: dark)');

    function get(k) { try { return localStorage.getItem(k); } catch (e) { return null; } }
    function set(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }
    function del(k) { try { localStorage.removeItem(k); } catch (e) {} }

    function osMode() { return mql.matches ? 'dark' : 'light'; }
    function getMode() {
      var m = get('mode');
      return m === 'light' || m === 'dark' || m === 'system' ? m : 'system';
    }
    function effectiveMode() {
      var m = getMode();
      return m === 'system' ? osMode() : m;
    }
    // Palette is a per-mode *preference*: a chosen dark palette and a chosen light
    // palette are remembered independently. The color mode is controlled only by
    // the mode switch — picking a palette never flips light/dark.
    function paletteKey(mode) { return mode === 'dark' ? 'theme-dark' : 'theme-light'; }
    function getPalette(mode) {
      var v = get(paletteKey(mode));
      if (v && THEME_MODES[v] === mode) return v;
      return mode === 'dark' ? DEFAULT_DARK : DEFAULT_LIGHT;
    }
    function apply() {
      var em = effectiveMode();
      var pal = getPalette(em);
      root.setAttribute('data-mode', em);
      root.setAttribute('data-theme', pal);
      // Set color-scheme inline (not just via the theme CSS) so the browser paints
      // its canvas backdrop in the right scheme with zero CSS dependency. This kills
      // the white flash when *reloading* a dark page (the reload repaints the default
      // backdrop for a sub-frame before the page background is drawn).
      root.style.colorScheme = em;
      // Keep the mobile browser-chrome color in sync with the active palette (the
      // static meta is only the dark build-day fallback).
      var tc = document.querySelector('meta[name="theme-color"]');
      if (tc && THEME_BG[pal]) tc.setAttribute('content', THEME_BG[pal]);
      try {
        document.dispatchEvent(new CustomEvent('themechange'));
      } catch (e) {}
    }
    // User-initiated theme changes get a circular "wipe" reveal via the View
    // Transitions API, radiating from the control the user clicked. The raw apply()
    // (first paint + OS-theme change) never animates — only setMode/setPalette do —
    // and it degrades to an instant swap where the API is missing or motion is
    // reduced, so it's purely additive.
    var wipeOrigin = null;
    document.addEventListener('click', function (e) {
      // Remember where the pointer was so the wipe can radiate from it. Keyboard
      // activations report (0,0) — fall back to the target's center.
      if (e.clientX || e.clientY) wipeOrigin = { x: e.clientX, y: e.clientY };
      else if (e.target && e.target.getBoundingClientRect) {
        var r = e.target.getBoundingClientRect();
        wipeOrigin = { x: r.left + r.width / 2, y: r.top + r.height / 2 };
      } else wipeOrigin = null;
    }, true);
    function reducedMotion() {
      try { return window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) { return false; }
    }
    function applyAnimated() {
      if (!document.startViewTransition || reducedMotion()) { apply(); return; }
      var o = wipeOrigin || { x: window.innerWidth / 2, y: 0 };
      // Freeze element transitions so the circular reveal is the only motion —
      // theme-preload disables all transitions; restore once it settles.
      root.classList.add('theme-preload');
      var done = function () { root.classList.remove('theme-preload'); };
      var vt;
      try {
        vt = document.startViewTransition(function () { apply(); });
      } catch (e) { apply(); done(); return; }
      // Drive the wipe in JS — animate the ::view-transition-new(root) snapshot —
      // instead of a CSS keyframe reading custom props. The snapshot is
      // viewport-aligned, so the click point (clientX/Y) maps 1:1 and the circle
      // radiates from the actual control; custom-property inheritance into the
      // view-transition pseudo tree is too inconsistent to trust for the origin.
      vt.ready.then(function () {
        var x = o.x, y = o.y;
        var endRadius = Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y));
        try {
          root.animate(
            { clipPath: ['circle(0px at ' + x + 'px ' + y + 'px)', 'circle(' + endRadius + 'px at ' + x + 'px ' + y + 'px)'] },
            { duration: 500, easing: 'ease-out', pseudoElement: '::view-transition-new(root)' },
          );
        } catch (e) {}
      }).catch(function () {});
      vt.finished.then(done, done);
    }
    function setMode(m) {
      if (m === 'system') del('mode');
      else set('mode', m);
      applyAnimated();
    }
    function setPalette(id) {
      var mode = THEME_MODES[id];
      if (!mode) return;
      // Save as the preferred palette for that mode only — don't change the mode.
      set(paletteKey(mode), id);
      applyAnimated();
    }
    // Re-resolve when the OS theme flips — only matters while mode is 'system'.
    mql.addEventListener('change', function () {
      if (getMode() === 'system') apply();
    });

    window.__theme = {
      apply: apply,
      setMode: setMode,
      setPalette: setPalette,
      getMode: getMode,
      getPalette: getPalette,
    };
    apply();

    // The <html> ships with class "theme-preload", which disables all transitions
    // so applying the correct theme above never animates (no dark/light flash on
    // load). Drop it after the first paint — via double rAF — so manual theme
    // toggles still animate smoothly afterward.
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        root.classList.remove('theme-preload');
      });
    });
  })();
</script>
