---
// Article layout — header meta, prose + sticky table of contents, share buttons.
import '../styles/markdown.css';
import { css } from 'styled-system/css';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Badge from '../components/Badge.astro';
import PostMeta from '../components/PostMeta.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';
import { categoryIcon } from '../consts';
import { tagSlug } from '../utils/posts';

interface Props {
  title: string;
  excerpt: string;
  category: string;
  date: Date;
  updated?: Date;
  readTime?: number;
  difficulty?: string;
  tags?: string[];
  tools?: string[];
  headings: MarkdownHeading[];
  path: string;
  linkTags?: boolean; // link each tag to its /tags page (blog posts only)
  // Multi-part series this post belongs to (parts pre-sorted; one is `current`).
  series?: { name: string; parts: { title: string; href: string; n: number; current: boolean }[] };
}

const {
  title,
  excerpt,
  category,
  date,
  readTime,
  difficulty,
  tags = [],
  tools = [],
  headings,
  path,
  linkTags = false,
  series,
} = Astro.props;

const seriesCurrent = series?.parts.find((p) => p.current);

// Breadcrumb trail derived from the post's section (blog vs labs).
const section = path.startsWith('/labs') ? { label: 'Labs', href: '/labs/' } : { label: 'Blog', href: '/blog/' };
const crumbs = [{ label: 'Home', href: '/' }, section, { label: title }];
---

<BaseLayout
  title={title}
  description={excerpt}
  type="article"
  publishedDate={date}
>
  <div
    id="read-progress"
    aria-hidden="true"
    class={css({
      position: 'fixed',
      top: 0,
      left: 0,
      w: '100%',
      h: '3px',
      bg: 'primary',
      transformOrigin: 'left',
      transform: 'scaleX(0)',
      willChange: 'transform',
      zIndex: 90,
      pointerEvents: 'none',
    })}
  >
  </div>

  <article>
    <Breadcrumbs items={crumbs} />
    <header class={css({ mb: '2rem' })}>
      <div class={css({ display: 'flex', gap: '0.5rem', mb: '1rem', flexWrap: 'wrap' })}>
        <Badge variant="primary" icon={categoryIcon(category)}>{category}</Badge>
        {difficulty && <Badge variant="difficulty" icon="gauge">{difficulty}</Badge>}
      </div>

      <h1
        class={`declassify ${css({
          fontSize: { base: '2rem', md: '2.75rem' },
          fontWeight: 700,
          lineHeight: 1.15,
          letterSpacing: '-0.02em',
          mb: '1rem',
        })}`}
      >
        {title}
      </h1>

      <p class={css({ fontSize: '1.15rem', color: 'textMuted', mb: '1.25rem' })}>{excerpt}</p>

      <PostMeta date={date} readTime={readTime} difficulty={difficulty} author="Patrick Saade" />

      {
        tools.length > 0 && (
          <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.4rem', mt: '1rem' })}>
            {tools.map((t) => (
              <Badge variant="accent">{t}</Badge>
            ))}
          </div>
        )
      }
    </header>

    {
      series && (
        <aside
          aria-label="Series navigation"
          class={css({
            mb: '2rem',
            p: '1rem 1.25rem',
            bg: 'bgSubtle',
            border: '1px solid token(colors.border)',
            borderLeftWidth: '3px',
            borderLeftColor: 'primary',
            borderRadius: 'md',
          })}
        >
          <p
            class={css({
              fontFamily: 'sans',
              fontSize: '0.72rem',
              textTransform: 'uppercase',
              letterSpacing: '0.1em',
              color: 'primary',
              fontWeight: 700,
              mb: '0.6rem',
              display: 'flex',
              alignItems: 'center',
              gap: '0.4rem',
            })}
          >
            <Icon name="layers" size={14} /> Part {seriesCurrent?.n} of {series.parts.length} · {series.name}
          </p>
          <ol class={css({ listStyle: 'none', m: 0, p: 0, display: 'flex', flexDirection: 'column', gap: '0.3rem' })}>
            {series.parts.map((p) =>
              p.current ? (
                <li class={css({ fontSize: '0.9rem' })}>
                  <span aria-current="true" class={css({ fontWeight: 700, color: 'text', display: 'inline-flex', gap: '0.5rem' })}>
                    <span class={css({ color: 'primary' })}>{p.n}.</span>
                    {p.title}
                  </span>
                </li>
              ) : (
                <li class={css({ fontSize: '0.9rem' })}>
                  <a href={p.href} class={css({ color: 'textMuted', display: 'inline-flex', gap: '0.5rem', transition: 'color 150ms ease', _hover: { color: 'primary' } })}>
                    <span class={css({ color: 'primary' })}>{p.n}.</span>
                    {p.title}
                  </a>
                </li>
              ),
            )}
          </ol>
        </aside>
      )
    }

    <div
      class={css({
        display: 'grid',
        gridTemplateColumns: { base: '1fr', lg: 'minmax(0, 1fr) 220px' },
        gap: '2.5rem',
        alignItems: 'start',
      })}
    >
      <div class="prose">
        <slot />
      </div>

      <aside
        class={css({
          display: { base: 'none', lg: 'block' },
          position: 'sticky',
          top: '90px',
        })}
      >
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <div class={css({ mt: '2.5rem', pt: '1.5rem', borderTop: '1px solid token(colors.border)' })}>
      <ShareButtons title={title} path={path} />
      {
        tags.length > 0 && (
          <div class={css({ display: 'flex', flexWrap: 'wrap', gap: '0.4rem', mt: '1.25rem' })}>
            {tags.map((t) =>
              linkTags ? (
                <a href={`/tags/${tagSlug(t)}/`} class={css({ _hover: { opacity: 0.85 } })}>
                  <Badge>#{t}</Badge>
                </a>
              ) : (
                <Badge>#{t}</Badge>
              ),
            )}
          </div>
        )
      }
    </div>

    <slot name="footer" />
  </article>

  <script is:inline>
    (function () {
      // Reading-progress bar: scaleX with scroll through the article.
      var bar = document.getElementById('read-progress');
      var article = document.querySelector('article');
      if (bar && article) {
        var update = function () {
          var total = article.offsetHeight - window.innerHeight;
          var scrolled = Math.min(Math.max(-article.getBoundingClientRect().top, 0), total);
          bar.style.transform = 'scaleX(' + (total > 0 ? scrolled / total : 0) + ')';
        };
        update();
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update, { passive: true });
      }
      // Visually-hidden live region so screen readers hear the copy confirmation
      // (the button keeps a stable aria-label, so its name never carries it).
      var copyStatus = document.createElement('div');
      copyStatus.setAttribute('role', 'status');
      copyStatus.setAttribute('aria-live', 'polite');
      copyStatus.style.cssText =
        'position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;';
      document.body.appendChild(copyStatus);
      // Copy button on each code block.
      document.querySelectorAll('.prose pre').forEach(function (pre) {
        var code = pre.querySelector('code');
        if (!code) return;
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.textContent = 'Copy';
        btn.setAttribute('aria-label', 'Copy code to clipboard');
        btn.addEventListener('click', function () {
          navigator.clipboard.writeText(code.textContent || '').then(function () {
            btn.textContent = 'Copied';
            btn.setAttribute('data-copied', '');
            copyStatus.textContent = 'Code copied to clipboard';
            setTimeout(function () {
              btn.textContent = 'Copy';
              btn.removeAttribute('data-copied');
              copyStatus.textContent = '';
            }, 1600);
          }).catch(function () {});
        });
        pre.appendChild(btn);
      });
      // Scroll-reveal: fade/rise each top-level prose block as it enters view.
      // Only armed when IntersectionObserver is supported and motion is allowed,
      // so no-JS and reduced-motion readers always see fully-visible content.
      var prose = document.querySelector('.prose');
      var motionOk = !window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prose && 'IntersectionObserver' in window && motionOk) {
        prose.classList.add('reveal-ready');
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
        );
        Array.prototype.forEach.call(prose.children, function (el) {
          io.observe(el);
        });
      }
    })();
  </script>
</BaseLayout>
