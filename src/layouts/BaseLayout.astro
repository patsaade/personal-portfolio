---
// Base page shell — head, theme styles, sticky nav, main slot, footer, skip link.
import '../styles/fonts.css';
import '../styles/global.css';
import '../styles/motion.css'; // charm/decorative animations (see file header)
import { css } from 'styled-system/css';
import BaseHead from '../components/BaseHead.astro';
import ThemeStyles from '../components/ThemeStyles.astro';
import Background from '../components/Background.astro';
import Ticker from '../components/Ticker.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import HoverCards from '../components/HoverCards.astro';
import SoundEngine from '../components/SoundEngine.astro';
import Search from '../components/Search.astro';
import CursorFX from '../components/CursorFX.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { DEFAULT_DARK } from '../themes';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en" class="theme-preload" data-theme={DEFAULT_DARK} data-mode="dark">
  <head>
    <BaseHead {...props} />
    <ThemeStyles />
  </head>
  <body>
    <Background />

    {/* Defines window.__sound before the nav's SoundToggle script runs. */}
    <SoundEngine />

    <a
      href="#main"
      class={css({
        position: 'absolute',
        left: '-9999px',
        _focus: {
          left: '1rem',
          top: '1rem',
          zIndex: 100,
          bg: 'primary',
          color: 'onPrimary',
          px: '1rem',
          py: '0.5rem',
          borderRadius: 'md',
        },
      })}
    >
      Skip to content
    </a>

    <Ticker />
    <Navigation />

    <main
      id="main"
      class={css({
        maxW: '960px',
        mx: 'auto',
        px: '1.25rem',
        py: { base: '2rem', md: '3rem' },
        minH: '60vh',
        animation: 'fadeIn 400ms ease both',
      })}
    >
      <slot />
    </main>

    <Footer />

    {/* Site-wide hover/tap context cards (Floating UI). Auto-wraps companies,
        certs, and key tools; <Term> handles glossary terms. */}
    <HoverCards />

    {/* Site-wide ⌘K search palette (build-time index at /search-index.json). */}
    <Search />

    {/* Retro custom cursor + star-shine follower (fine-pointer only). */}
    <CursorFX />

    {/* Vercel Web Analytics is injected by the @astrojs/vercel adapter
        (webAnalytics.enabled in astro.config.mjs). Speed Insights below. */}
    <SpeedInsights />

    {/* Register the service worker for offline reading + fast repeat loads (see public/sw.js). */}
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>
  </body>
</html>
