# .vercelignore — files NOT uploaded to Vercel.
# The production build (`panda codegen && astro build`, per vercel.json) only needs
# source (src/, public/), the package manifests, and the Astro/Panda/PostCSS/TS config.
# Everything below is either regenerated by the build, dependency-installed, dev-only,
# secret, or reference-only — so it's excluded from the deploy.

# Reference-only / local-only — never built or served (also in .gitignore)
examples/
_local/
evidence/

# Build outputs & caches (Vercel rebuilds these)
dist/
.output/
.astro/
styled-system/

# Dependencies (Vercel installs fresh)
node_modules/

# Dev-only / internal — not used by the production build/deploy
test/
vitest.config.ts
docs/
CLAUDE.md
README.md
.github/
.nvmrc
scripts/
# Note: .npmrc is intentionally NOT ignored — Vercel needs it at install time
# (legacy-peer-deps=true).

# Local tooling & metadata
.claude/
.vercel
.gitignore

# Secrets & local env (never upload)
.env
.env.*
.env.local

# OS / logs
.DS_Store
._*
*.log
