# .vercelignore — files NOT uploaded to Vercel.
# The production build (`panda codegen && astro build`, per vercel.json) only needs
# source (src/, public/), the package manifests, and the Astro/Panda/PostCSS/TS config.
# Everything below is either regenerated by the build, dependency-installed, dev-only,
# secret, or reference-only — so it's excluded from the deploy.

# Reference-only / local-only — never built or served (also in .gitignore)
examples/
_local/
evidence/

# Build outputs & caches (Vercel rebuilds these)
dist/
.output/
.astro/
styled-system/

# Dependencies (Vercel installs fresh)
node_modules/

# Dev-only / internal — not used by the production build/deploy
test/
vitest.config.ts
docs/
CLAUDE.md
README.md
.github/
.nvmrc
scripts/
# Note: .npmrc is intentionally NOT ignored — Vercel needs it at install time
# (legacy-peer-deps=true).

# Local tooling & metadata
.claude/
.vercel
.gitignore

# Secrets & local env (never upload)
.env
.env.*
.env.local
*.pem
*.key
*.p12
*.pfx
id_rsa*
secrets*.json

# Forensic artifacts & archives — mirrors .gitignore. These are never committed, but
# .vercelignore is evaluated independently: its mere presence makes the Vercel CLI
# ignore .gitignore entirely for a local `vercel deploy` (a raw filesystem upload,
# unlike the git-integrated push deploys this project normally uses). Without these
# patterns here too, a stray lab evidence file or key sitting in the working tree
# would ship to Vercel on any local CLI deploy. Never used by the build either way.
*.raw
*.mem
*.vmem
*.vmsn
*.vmdk
*.dmp
*.lime
*.bin
*.e01
*.ex01
*.aff4
*.pcap
*.pcapng
*.zip
*.7z
*.tar.gz
*.tgz
*.rar

# OS / logs
.DS_Store
._*
*.log

# TypeScript incremental cache / test coverage output (see .gitignore)
*.tsbuildinfo
coverage/
