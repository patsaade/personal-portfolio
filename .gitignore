# ── Dependencies ──────────────────────────────────────────
node_modules/

# ── Build output & caches (regenerated) ───────────────────
dist/
.output/
.vercel/
.astro/

# Generated by Panda CSS (run `panda codegen`)
styled-system/

# TypeScript incremental build cache; Vitest coverage output (neither is on by
# default here, but both are one flag away and must never be committed).
*.tsbuildinfo
coverage/

# ── Local env, secrets & keys — never commit ──────────────
.env
.env.*
.envrc
.netrc
*.pem
*.key
*.gpg
*.p12
*.pfx
id_rsa*
id_ed25519*
id_ecdsa*
secrets*.json
# Cloud CLI credential caches — never legitimately part of this repo's own
# working tree, ignored defensively in case a tool ever writes here.
.aws/
.azure/
.gcloud/
# Infrastructure-as-code state can embed resource secrets/outputs; this repo
# has no IaC, but the pattern costs nothing and closes a common leak vector.
*.tfstate
*.tfstate.*
.terraform/

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Local tooling & editor config ─────────────────────────
.claude/
# AI/contributor guidance — kept on the local machine only, not in the public repo.
CLAUDE.md
# Maintenance/freshness process is merged into CLAUDE.md; ignore any stray standalone copy.
docs/MAINTENANCE.md
# graphify's generated knowledge graph (graph.html/GRAPH_REPORT.md/graph.json) —
# local analysis output, regenerated on demand, never part of the site.
graphify-out/
.vscode/
.idea/
*.swp
*~

# ── OS noise ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Local-only dirs (kept on disk, never pushed) ──────────
# Reference templates, scratch + private/WIP drafts, and downloaded lab data.
examples/
_local/
evidence/

# ── Forensic artifacts — never commit (large + may be sensitive) ──
# Acquisitions, dumps, and captures from labs/CTFs stay on the local machine.
*.raw
*.dd
*.img
*.mem
*.vmem
*.vmsn
*.vmdk
*.vhd
*.vhdx
*.vdi
*.qcow2
*.ova
*.ovf
*.dmp
*.lime
*.bin
*.e01
*.ex01
*.l01
*.lx01
*.ad1
*.aff4
*.pcap
*.pcapng
*.cap
*.evtx
# Browser network captures — can embed session tokens/cookies/auth headers,
# a well-known accidental-secret-leak vector when testing web-facing tools.
*.har

# ── Archives (usually downloaded lab/evidence bundles) ────
*.zip
*.7z
*.tar.gz
*.tgz
*.rar

# ── Editor/merge backup artifacts — stale content, sometimes a secret from
# before it was rotated out of the live file ───────────────
*.bak
*.orig
*.rej
