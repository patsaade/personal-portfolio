# ── Dependencies ──────────────────────────────────────────
node_modules/

# ── Build output & caches (regenerated) ───────────────────
dist/
.output/
.vercel/
.astro/

# Generated by Panda CSS (run `panda codegen`)
styled-system/

# ── Local env, secrets & keys — never commit ──────────────
.env
.env.*
.envrc
*.pem
*.key
*.p12
*.pfx
id_rsa*
secrets*.json

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Local tooling & editor config ─────────────────────────
.claude/
.vscode/
.idea/
*.swp
*~

# ── OS noise ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Local-only dirs (kept on disk, never pushed) ──────────
# Reference templates, scratch + private/WIP drafts, and downloaded lab data.
examples/
_local/
evidence/

# ── Forensic artifacts — never commit (large + may be sensitive) ──
# Acquisitions, dumps, and captures from labs/CTFs stay on the local machine.
*.raw
*.mem
*.vmem
*.vmsn
*.vmdk
*.dmp
*.lime
*.bin
*.e01
*.ex01
*.aff4
*.pcap
*.pcapng

# ── Archives (usually downloaded lab/evidence bundles) ────
*.zip
*.7z
*.tar.gz
*.tgz
*.rar
