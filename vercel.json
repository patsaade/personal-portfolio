{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "git fetch --unshallow 2>/dev/null || true; panda codegen && astro build",
  "redirects": [
    { "source": "/tags", "destination": "/blog/", "permanent": true },
    { "source": "/tags/", "destination": "/blog/", "permanent": true },
    { "source": "/tags/:tag", "destination": "/blog/?tag=:tag", "permanent": true },
    { "source": "/tags/:tag/", "destination": "/blog/?tag=:tag", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "base-uri 'self'; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" }
      ]
    }
  ]
}
